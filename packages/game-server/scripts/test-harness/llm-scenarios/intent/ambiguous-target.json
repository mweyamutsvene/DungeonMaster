{
  "name": "Intent: Ambiguous Target",
  "description": "LLM handles 'attack' with multiple enemies by selecting a valid target",
  "category": "intent",
  "steps": [
    {
      "type": "intent",
      "description": "Parse 'attack' with two monsters — should pick one valid target",
      "input": {
        "text": "I attack",
        "roster": {
          "characters": [{ "id": "char-001", "name": "Thorin Ironfist" }],
          "monsters": [
            { "id": "mon-001", "name": "Goblin Warrior" },
            { "id": "mon-002", "name": "Orc Brute" }
          ]
        }
      },
      "expect": {
        "kind": "attack",
        "promptSnapshot": "ambiguous-target"
      }
    },
    {
      "type": "intent",
      "description": "Parse 'attack the orc' with two monsters — should pick the orc",
      "input": {
        "text": "I attack the orc",
        "roster": {
          "characters": [{ "id": "char-001", "name": "Thorin Ironfist" }],
          "monsters": [
            { "id": "mon-001", "name": "Goblin Warrior" },
            { "id": "mon-002", "name": "Orc Brute" }
          ]
        }
      },
      "expect": {
        "kind": "attack",
        "targetName": "Orc",
        "targetType": "Monster"
      }
    }
  ]
