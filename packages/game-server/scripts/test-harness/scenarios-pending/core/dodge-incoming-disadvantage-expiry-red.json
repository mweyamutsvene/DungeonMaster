{
  "name": "RED: Dodge Incoming Attack Timing (Disadvantage Until Next Turn)",
  "description": "Expected RED until incoming attacks correctly respect Dodge duration. RAW 2024: Dodge should impose disadvantage on attacks against you until the start of your next turn.",
  "setup": {
    "character": {
      "name": "Shield Guardian",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16, "dexterity": 14, "constitution": 15,
          "intelligence": 10, "wisdom": 12, "charisma": 8
        },
        "maxHp": 44, "currentHp": 44, "armorClass": 18, "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword", "kind": "melee", "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 10,
            "intelligence": 10, "wisdom": 8, "charisma": 8
          },
          "maxHp": 21, "hp": 21, "armorClass": 15, "speed": 30,
          "challengeRating": 0.25, "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar", "kind": "melee", "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I take a defensive stance" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "queueMonsterActions",
      "comment": "Monster attacks during the same round that Dodge is active.",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Shield Guardian", "attackName": "Scimitar", "endTurn": true }
        ]
      }
    },
    {
      "type": "queueDiceRolls",
      "comment": "Deterministic disadvantaged pair: high + low should resolve to a miss against AC 18.",
      "input": {
        "values": [18, 2],
        "label": "red-dodge-incoming-disadvantage"
      }
    },
    {
      "type": "action",
      "comment": "Dodge should protect from this incoming attack until next turn starts.",
      "input": { "text": "dodge" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "actionComplete": true }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn"
    },
    {
      "type": "assertState",
      "comment": "RED expectation: no damage should be taken from the disadvantaged incoming attack while Dodge is active.",
      "expect": {
        "combatStatus": "Active",
        "characterHp": { "min": 44, "max": 44 },
        "characterPosition": { "x": 10, "y": 10 }
      }
    }
  ]
}
