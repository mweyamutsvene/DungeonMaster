{
  "name": "RED: Death Saves — Crit-at-0 and Stable-to-Damage",
  "description": "Pending RED coverage for two CombatRules branches: (1) incoming melee hit on a downed target should count as a crit and add 2 death save failures, and (2) a stable creature at 0 HP that takes damage should stop being stable and resume death saves.",
  "setup": {
    "character": {
      "name": "Doomed Hero",
      "className": "Fighter",
      "level": 1,
      "position": { "x": 0, "y": 0 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 10,
          "constitution": 10,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 1,
        "currentHp": 1,
        "armorClass": 10,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Dagger",
            "kind": "melee",
            "attackBonus": 2,
            "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
            "damageType": "piercing"
          }
        ],
        "features": [],
        "resourcePools": []
      }
    },
    "monsters": [
      {
        "name": "Deadly Foe",
        "position": { "x": 5, "y": 0 },
        "statBlock": {
          "abilityScores": {
            "strength": 20,
            "dexterity": 20,
            "constitution": 20,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 10
          },
          "hp": 100,
          "maxHp": 100,
          "armorClass": 18,
          "speed": 30,
          "position": { "x": 5, "y": 0 },
          "attacks": [
            {
              "name": "Greatsword",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 15,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 5 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "comment": "Start combat with low initiative so the monster KOs first.",
      "input": { "text": "I face the Deadly Foe" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "comment": "Low initiative. Monster goes first and drops hero to 0 HP.",
      "input": { "text": "2" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "waitForTurn",
      "comment": "Monster KOs hero; hero starts death save loop."
    },
    {
      "type": "rollResult",
      "comment": "Death save #1 success to establish 1/0 before incoming crit branch.",
      "input": { "text": "12" },
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "success",
        "deathSaves": { "successes": 1, "failures": 0 },
        "actionComplete": true
      }
    },
    {
      "type": "queueDiceRolls",
      "comment": "Queue deterministic hit + damage values for attack on downed target.",
      "input": { "values": [19, 2, 2], "label": "crit-at-0 attempt" }
    },
    {
      "type": "queueMonsterActions",
      "comment": "Force one monster attack on downed hero. Expected branch: unconscious melee hit counts as crit (+2 failures).",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Doomed Hero", "attackName": "Greatsword", "endTurn": true }
        ]
      }
    },
    {
      "type": "waitForTurn",
      "comment": "Resolve queued monster turn and return to hero."
    },
    {
      "type": "rollResult",
      "comment": "RED assertion: if crit-at-0 is supported, counter should now be 2 successes / 2 failures.",
      "input": { "text": "13" },
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "success",
        "deathSaves": { "successes": 2, "failures": 2 },
        "actionComplete": true
      }
    },
    {
      "type": "waitForTurn",
      "comment": "Cycle to hero turn for stabilization setup."
    },
    {
      "type": "rollResult",
      "comment": "Natural 20 reset to recover and prepare stable-to-damage branch from fresh counters.",
      "input": { "text": "20" },
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "revived",
        "deathSaves": { "successes": 0, "failures": 0 },
        "actionComplete": true
      }
    },
    {
      "type": "configureAi",
      "comment": "Use deterministic queued branches only.",
      "input": { "defaultBehavior": "endTurn" }
    },
    {
      "type": "queueDiceRolls",
      "comment": "Queue deterministic hit/damage to KO the revived hero again.",
      "input": { "values": [18, 2], "label": "re-KO" }
    },
    {
      "type": "queueMonsterActions",
      "comment": "Force KO after revival so we can stabilize from 0 failures.",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Doomed Hero", "attackName": "Greatsword", "endTurn": true }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "Pass hero turn for queued KO."
    },
    {
      "type": "waitForTurn",
      "comment": "Return to hero after queued KO resolves."
    },
    {
      "type": "rollResult",
      "comment": "Stabilization save #1.",
      "input": { "text": "12" },
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "success",
        "deathSaves": { "successes": 1, "failures": 0 },
        "actionComplete": true
      }
    },
    {
      "type": "waitForTurn",
      "comment": "Cycle to next save turn."
    },
    {
      "type": "rollResult",
      "comment": "Stabilization save #2.",
      "input": { "text": "14" },
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "success",
        "deathSaves": { "successes": 2, "failures": 0 },
        "actionComplete": true
      }
    },
    {
      "type": "waitForTurn",
      "comment": "Cycle to stabilization save."
    },
    {
      "type": "rollResult",
      "comment": "Stabilization save #3: become stable at 0 HP.",
      "input": { "text": "16" },
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "stabilized",
        "deathSaves": { "successes": 3, "failures": 0 },
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Stable checkpoint: 0 HP and combat still active.",
      "expect": {
        "characterHp": { "exact": 0 },
        "combatStatus": "Active"
      }
    },
    {
      "type": "configureAi",
      "comment": "Switch to attack branch for stable-to-damage regression.",
      "input": { "defaultBehavior": "attack" }
    },
    {
      "type": "queueDiceRolls",
      "comment": "Queue deterministic hit/damage on stable target.",
      "input": { "values": [18, 2], "label": "stable-to-damage" }
    },
    {
      "type": "queueMonsterActions",
      "comment": "Force one attack against stable 0 HP target.",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Doomed Hero", "attackName": "Greatsword", "endTurn": true }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "Pass turn so monster can apply post-stable damage."
    },
    {
      "type": "waitForTurn",
      "comment": "Resolve attack and return to hero turn."
    },
    {
      "type": "rollResult",
      "comment": "RED assertion: after stable target takes damage, hero should resume death saves.",
      "input": { "text": "11" },
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "success",
        "actionComplete": true
      }
    }
  ]
}
