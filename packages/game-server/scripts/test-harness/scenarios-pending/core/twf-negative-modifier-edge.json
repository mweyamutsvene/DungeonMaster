  "actions": [
    {
      "type": "initiate",
      "comment": "Start deterministic TWF test sequence.",
      "input": { "text": "I attack the training dummy" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "comment": "Win initiative and take turn first.",
      "input": { "text": "18" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "comment": "Main-hand attack (Attack action) with negative STR modifier weapon profile.",
      "input": { "text": "attack Training Dummy with my handaxe" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "comment": "Main-hand hit.",
      "input": { "text": "14" },
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "comment": "Main-hand damage: 3 + (-1) = 2. Dummy HP 20 -> 18.",
      "input": { "text": "3" },
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "comment": "Bonus off-hand attack should be legal after Attack action.",
      "input": { "text": "offhand attack" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "comment": "Off-hand hit.",
      "input": { "text": "13" },
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
