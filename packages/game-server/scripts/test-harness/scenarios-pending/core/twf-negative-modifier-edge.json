    },
    {
      "type": "rollResult",
      "comment": "RED EXPECTED-FAILURE BRANCH: off-hand damage should include negative modifier (2 + -1 = 1), not floor at base die. Expected Dummy HP 18 -> 17.",
      "input": { "text": "2" },
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "EXPECTED FAILURE until negative-mod off-hand branch is fidelity-complete. If engine drops the -1 modifier on off-hand, HP will be 16 instead of expected 17.",
      "expect": {
        "monsterHp": { "name": "Training Dummy", "min": 17, "max": 17 },
