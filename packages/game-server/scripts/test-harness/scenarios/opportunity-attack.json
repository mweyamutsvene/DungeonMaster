{
  "name": "Opportunity Attack: Goblin hits fleeing Fighter",
  "description": "A Fighter engages a Goblin, ends turn, survives goblin attack, then retreats triggering an opportunity attack. Tests the REACTION_CHECK flow across multiple turns.",
  "setup": {
    "character": {
      "name": "Cautious Colin",
      "className": "Fighter",
      "level": 3,
      "sheet": {
        "abilityScores": {
          "strength": 14,
          "dexterity": 18,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 28,
        "currentHp": 28,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 4,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 2 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Sentinel",
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 20,
          "hp": 20,
          "armorClass": 15,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I approach the goblin cautiously" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "comment": "Very high initiative ensures Fighter goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (35, 10)" },
      "comment": "Fighter moves adjacent to goblin (5ft away). 25ft movement used.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn - goblin's turn next (AI will act, may attack player)"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for monster turn processing to complete and control to return to player",
      "timeout": 5000
    },
    {
      "type": "action",
      "input": { "text": "move to (10, 10)" },
      "comment": "On player's next turn: retreat from (35,10) back to (10,10) - triggers OA!",
      "expect": {
        "type": "REACTION_CHECK"
      }
    },
    {
      "type": "reactionRespond",
      "input": { "choice": "use" },
      "comment": "Goblin uses its reaction for opportunity attack"
    },
    {
      "type": "moveComplete",
      "comment": "Complete the move - monster OA is auto-rolled.",
      "expect": {
        "success": true
      }
    },
    {
      "type": "assertState",
      "expect": {
        "characterHp": { "max": 28 }
      },
      "comment": "Fighter HP should be <= 28 (may have taken damage from goblin's turn + OA)"
    }
  ]
}
