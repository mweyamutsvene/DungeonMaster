  "actions": [
    {
      "comment": "=== ROUND 1 ===",
      "type": "queueDiceRolls",
      "input": { "values": [1] }
    },
    {
      "comment": "Queue monster actions: both attack Sir Marcus on their turns.",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Sir Marcus", "attackName": "Greataxe", "endTurn": true },
          { "action": "attack", "target": "Sir Marcus", "attackName": "Scimitar", "endTurn": true }
        ]
      }
    },
    {
      "type": "initiate",
      "actor": "Lyra",
      "input": { "text": "I sing a battle song" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "comment": "Lyra rolls 20 for initiative -> goes first.",
      "type": "rollResult",
      "actor": "Lyra",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "R1 BONUS: Bardic Inspiration granted to Sir Marcus. Consumes 1 of 4 uses. Per RAW, target ally receives a d8 they can add to one attack/save/check.",
      "type": "action",
      "actor": "Lyra",
      "input": { "text": "inspire Sir Marcus" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "ASSERT: Bardic Inspiration pool 4 -> 3 after granting to Sir Marcus.",
      "type": "assertState",
      "actor": "Lyra",
      "expect": {
        "resources": { "bardicInspiration": { "current": 3, "max": 4 } }
      }
    },
    {
      "comment": "R1 ACTION: Vicious Mockery cantrip on Orc Warchief. WIS save DC 15 — Warchief WIS +0, needs 15+. Expected damage on fail: 1d4 psychic + disadvantage on next attack.",
      "type": "action",
      "actor": "Lyra",
      "input": { "text": "cast Vicious Mockery at Orc Warchief" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "endTurn",
      "actor": "Lyra"
    },
    {
      "type": "waitForTurn",
      "actor": "Sir Marcus",
      "timeout": 15000
    },
    {
      "comment": "R1 Sir Marcus attacks Orc Warchief with Longsword. Uses granted BI d8 on the hit per RAW — BI die added to damage. Attack +5 vs AC 16.",
      "type": "action",
      "actor": "Sir Marcus",
      "input": { "text": "I attack the Orc Warchief with my Longsword" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "comment": "Attack roll 15 + 5 = 20 -> hit.",
      "type": "rollResult",
      "actor": "Sir Marcus",
      "input": { "text": "15" },
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "comment": "Damage: longsword 1d8+3 + BI 1d8 added. Player rolls 7 weapon damage; server should ADD BI d8 (expected ~5 average). RAW: BI added to damage on hit.",
      "type": "rollResult",
      "actor": "Sir Marcus",
      "input": { "text": "7" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "ASSERT: Orc Warchief HP reduced by at least weapon damage + BI die. Minimum = 10 (weapon 7+3? actually roll 7 = 7+3-mod?), max = weapon+BI max. Use wide window to account for damage RNG and any Vicious Mockery psychic damage already applied.",
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Orc Warchief", "min": 70, "max": 94 }
      }
    },
    {
      "type": "endTurn",
      "actor": "Sir Marcus"
    },
    {
      "type": "waitForTurn",
      "actor": "Shade",
      "timeout": 15000
    },
    {
      "comment": "R1 Shade fires Shortbow at Bandit. Queued crit (natural 20).",
      "type": "action",
      "actor": "Shade",
      "input": { "text": "I attack the Bandit with my Shortbow" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "comment": "Nat 20 -> auto crit.",
      "type": "rollResult",
      "actor": "Shade",
      "input": { "text": "20" },
      "expect": { "hit": true, "isCritical": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "comment": "Crit damage: 2d6+3 sneak attack may apply. Roll 8 -> 11 damage, plenty to drop Bandit (HP 11).",
      "type": "rollResult",
      "actor": "Shade",
      "input": { "text": "8" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "ASSERT: Bandit dead after Shade's crit.",
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Bandit", "max": 0 }
      }
    },
    {
      "type": "endTurn",
      "actor": "Shade"
    },
    {
      "comment": "=== ROUND 2 === Wait through monster turns (Warchief attacks Marcus).",
      "type": "waitForTurn",
      "actor": "Lyra",
      "timeout": 15000
    },
    {
      "comment": "Queue Warchief to attack Marcus again.",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Sir Marcus", "attackName": "Greataxe", "endTurn": true }
        ]
      }
    },
    {
      "comment": "R2 BONUS: Bardic Inspiration to Shade. Pool 3 -> 2.",
      "type": "action",
      "actor": "Lyra",
      "input": { "text": "inspire Shade" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "actor": "Lyra",
      "expect": {
        "resources": { "bardicInspiration": { "current": 2, "max": 4 } }
      }
    },
    {
      "comment": "R2 ACTION: Healing Word on Sir Marcus — 2d4 + CHA (4) per 2024 baseline. Consumes L1 slot.",
      "type": "action",
      "actor": "Lyra",
      "input": { "text": "cast Healing Word on Sir Marcus" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "ASSERT: L1 slot 4 -> 3 after Healing Word.",
      "type": "assertState",
      "actor": "Lyra",
      "expect": {
        "resources": { "spellSlot_1": { "current": 3, "max": 4 } }
      }
    },
    {
      "type": "endTurn",
      "actor": "Lyra"
    },
    {
      "comment": "Skip through Marcus/Shade/monster turns to end round 2 cleanly. Lyra will need her turn again to reach rest state.",
      "type": "waitForTurn",
      "actor": "Sir Marcus",
      "timeout": 15000
    },
    {
      "type": "endTurn",
      "actor": "Sir Marcus"
    },
    {
      "type": "waitForTurn",
      "actor": "Shade",
      "timeout": 15000
    },
    {
      "type": "endTurn",
      "actor": "Shade"
    },
    {
      "comment": "=== SHORT REST: Font of Inspiration refresh check ===",
      "type": "rest",
      "input": { "restType": "short" },
      "expect": {
        "poolsRefreshed": ["bardicInspiration"]
      }
    },
    {
      "comment": "ASSERT: Font of Inspiration (L5 feature) refilled bardicInspiration pool to max 4 on a SHORT rest.",
      "type": "assertState",
      "actor": "Lyra",
      "expect": {
        "resources": { "bardicInspiration": { "current": 4, "max": 4 } }
      }
    }
  ]
}
