{
  "name": "Rogue Uncanny Dodge: Halve Attack Damage",
  "description": "A level 5 Rogue with Uncanny Dodge uses their reaction to halve damage from a melee attack. Monster has a very high attack bonus and the Rogue has very low AC to guarantee the hit. Tests: Uncanny Dodge reaction detection, two-phase attack flow, reaction consumption, and damage halving.",
  "setup": {
    "character": {
      "name": "Shadow",
      "className": "Rogue",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 18,
          "constitution": 14,
          "intelligence": 12,
          "wisdom": 13,
          "charisma": 14
        },
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 5,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "piercing",
            "properties": ["finesse", "light"]
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Orc Brute",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 16,
            "dexterity": 12,
            "constitution": 16,
            "intelligence": 7,
            "wisdom": 11,
            "charisma": 10
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 13,
          "speed": 30,
          "challengeRating": 2,
          "experienceValue": 450,
          "attacks": [
            {
              "name": "Greataxe",
              "kind": "melee",
              "attackBonus": 10,
              "damage": { "diceCount": 1, "diceSides": 12, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "attack"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I ready myself against the orc" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High initiative to ensure Rogue goes first",
      "expect": { "combatStarted": true }
    },
    {
      "comment": "End turn without acting — monster will attack on its turn",
      "type": "endTurn"
    },
    {
      "comment": "Wait for monster to attack and trigger Uncanny Dodge reaction prompt. AC 5 with +10 attack guarantees a hit.",
      "type": "waitForReaction",
      "input": { "reactionType": "uncanny_dodge" },
      "timeout": 10000
    },
    {
      "comment": "Use Uncanny Dodge reaction — halves the incoming damage, consumes reaction",
      "type": "reactionRespond",
      "input": { "choice": "use" }
    },
    {
      "comment": "Wait for monster turn to finish and control to return to player",
      "type": "waitForTurn",
      "timeout": 10000
    },
    {
      "comment": "Verify Rogue survived. Greataxe damage is 1d12+3 (4-15), halved by Uncanny Dodge = 2-7. HP: 38 - (2-7) = 31-36. Use wide range to be safe.",
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 23, "max": 37 }
      }
    }
  ]
}
