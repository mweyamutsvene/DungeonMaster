        "skills": {
          "stealth": 10
        },
        "attacks": [
          {
            "name": "Shortbow",
            "kind": "ranged",
            "range": "80/320",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
