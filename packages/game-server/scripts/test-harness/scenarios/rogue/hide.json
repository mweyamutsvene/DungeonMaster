          },
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "piercing"
          }
        ],
        "features": [
          { "name": "Sneak Attack", "description": "Deal extra 3d6 damage when you have advantage" },
          { "name": "Cunning Action", "description": "Dash, Disengage, or Hide as a bonus action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Unaware Guard",
        "position": { "x": 25, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 12,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 10
          },
          "maxHp": 22,
          "hp": 22,
          "armorClass": 16,
          "speed": 30,
          "passivePerception": 10,
          "challengeRating": 0.5,
          "experienceValue": 100,
          "attacks": [
            {
              "name": "Longsword",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
