  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare to strike from the shadows" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "hide" },
      "comment": "Use Cunning Action to Hide as a bonus action - Stealth check vs DC 15 or passive Perception",
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Hide"
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Unaware Guard with shortbow" },
      "comment": "Attack with advantage due to Hidden condition - sneak attack eligible",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "16" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "Damage including sneak attack dice",
      "expect": { "actionComplete": true }
    },
    {
      "type": "endTurn"
    }
  ]
