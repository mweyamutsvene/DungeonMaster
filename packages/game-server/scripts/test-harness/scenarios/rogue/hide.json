{
  "name": "Rogue Hide: Stealth to gain advantage",
  "description": "A Rogue uses Cunning Action to Hide as a bonus action, gains the Hidden condition, and then attacks with advantage.",
  "setup": {
    "character": {
      "name": "Shadow Swift",
      "className": "Rogue",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 18,
          "constitution": 14,
          "intelligence": 12,
          "wisdom": 12,
          "charisma": 14
        },
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 15,
        "speed": 30,
