{
  "name": "Warlock: Hex Concentration Save After Taking Damage",
  "description": "Regression test for concentration save on Hex: Warlock casts Hex (concentration), then takes damage from a scripted monster attack. The server must trigger a Constitution saving throw to maintain concentration. Tests that concentration saves fire correctly for Warlock Pact Magic spells, not just Wizard spell slots. From warlock test run: no concentration save was prompted after 12 damage with Hex active.",
  "setup": {
    "character": {
      "name": "Malachar the Dark",
      "className": "Warlock",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "level": 5,
        "abilityScores": {
          "strength": 8,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 18
        },
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 14,
        "speed": 30,
        "proficiencyBonus": 3,
        "spellcastingAbility": "charisma",
        "spellSaveDC": 15,
        "spellAttackBonus": 7,
        "spellSlots": { "3": 2 },
        "preparedSpells": [
          { "name": "Eldritch Blast", "level": 0 },
          { "name": "Hex", "level": 1 }
        ],
        "attacks": []
      }
    },
    "monsters": [
      {
        "name": "Shadow Construct",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 14,
            "constitution": 13,
            "intelligence": 6,
            "wisdom": 10,
            "charisma": 8
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 12,
          "speed": 40,
          "challengeRating": 2,
          "experienceValue": 450,
          "attacks": [
            {
              "name": "Shadow Claw",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 2, "diceSides": 6, "modifier": 2 },
              "damageType": "necrotic"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "Initiative 18+2=20, Warlock goes first",
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Cast Hex as bonus action on Shadow Construct — sets concentration",
      "type": "action",
      "input": { "text": "cast hex on Shadow Construct" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    },
    {
      "comment": "Verify Hex concentration is active",
      "type": "assertState",
      "expect": {
        "characterConcentration": "Hex"
      }
    },
    {
      "comment": "Cast Eldritch Blast with main action",
      "type": "action",
      "input": { "text": "cast eldritch blast at Shadow Construct" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "Beam 1: 15+7=22 vs AC 12 → hit",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "8" },
      "comment": "Beam 1 damage: 8 (1d10) + hex bonus (server-rolled). Shadow Construct takes damage."
    },
    {
      "comment": "Beam 2 auto-chains",
      "type": "rollResult",
      "input": { "text": "12" },
      "comment": "Beam 2: 12+7=19 vs AC 12 → hit",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "Beam 2 damage: 6 + hex bonus."
    },
    {
      "comment": "Queue Shadow Construct to attack Malachar — must trigger concentration save",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          {
            "action": "attack",
            "target": "Malachar the Dark",
            "attackName": "Shadow Claw",
            "endTurn": true
          }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn — Shadow Construct attacks with scripted decision"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Shadow Construct to attack and for concentration save to resolve",
      "timeout": 5000
    },
    {
      "comment": "Verify combat is still active and Malachar took damage",
      "type": "assertState",
      "expect": {
        "characterHp": { "max": 37 },
        "combatStatus": "Active"
      }
    }
  ]
}
