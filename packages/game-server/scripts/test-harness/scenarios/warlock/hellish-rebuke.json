{
  "name": "Warlock Hellish Rebuke: Retaliate After Damage",
  "description": "A Warlock with Hellish Rebuke prepared faces a monster attack. When the monster hits and deals damage, the server detects Hellish Rebuke eligibility and pauses for damage reaction. Player casts Hellish Rebuke (2d10 fire to attacker, DEX save for half). Tests damage reaction detection, two-phase damage reaction flow, pact magic slot consumption, and retaliatory damage.",
  "setup": {
    "character": {
      "name": "Vexra the Hexblade",
      "className": "Warlock",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10, "dexterity": 14, "constitution": 14,
          "intelligence": 10, "wisdom": 12, "charisma": 18
        },
        "maxHp": 30, "currentHp": 30, "armorClass": 5, "speed": 30,
        "proficiencyBonus": 2,
        "spellcastingAbility": "charisma",
        "spellSaveDC": 14,
        "spellAttackBonus": 6,
        "spellSlots": { "1": 2 },
        "preparedSpells": [
          { "name": "Hellish Rebuke", "level": 1 },
          { "name": "Eldritch Blast", "level": 0 }
        ],
        "attacks": [
          {
            "name": "Longsword", "kind": "melee", "range": "melee",
            "attackBonus": 2,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 0 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Bugbear Thug",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 15, "dexterity": 14, "constitution": 13,
            "intelligence": 8, "wisdom": 11, "charisma": 9
          },
          "maxHp": 60, "hp": 60, "armorClass": 16, "speed": 30,
          "challengeRating": 1, "experienceValue": 200,
          "attacks": [
            {
              "name": "Morningstar", "kind": "melee", "attackBonus": 10,
              "damage": { "diceCount": 2, "diceSides": 8, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "attack"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I face down the bugbear" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High initiative to ensure Warlock goes first",
      "expect": { "combatStarted": true }
    },
    {
      "comment": "End turn without acting - monster will attack on its turn",
      "type": "endTurn"
    },
    {
      "comment": "Wait for monster to attack and trigger Hellish Rebuke reaction",
      "type": "waitForReaction",
      "input": { "reactionType": "hellish_rebuke" },
      "timeout": 10000
    },
    {
      "comment": "Use Hellish Rebuke reaction - deal 2d10 fire to attacker",
      "type": "reactionRespond",
      "input": { "choice": "use" }
    },
    {
      "comment": "Wait for monster turn to finish and control to return to player",
      "type": "waitForTurn",
      "timeout": 10000
    },
    {
      "comment": "Warlock took piercing damage but retaliated with fire. Monster 60hp should have taken some fire damage from Hellish Rebuke (2d10, DEX save for half).",
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 1, "max": 29 },
        "monsterHp": { "name": "Bugbear Thug", "min": 1, "max": 59 }
      }
    }
  ]
}
