{
  "name": "Warlock Eldritch Blast Multi-Beam + Hellish Rebuke Reaction (Queue Integration)",
  "description": "Tests the pending action queue when a Hellish Rebuke damage reaction fires between the two beams of an Eldritch Blast (Warlock level 5). The Warlock fires beam 1 at Lyra (Warlock 3 with Hellish Rebuke). After taking force damage from beam 1, Lyra uses Hellish Rebuke as a reaction, dealing 2d10 fire to the caster. The queued beam 2 then auto-promotes from the queue and executes. Verifies: (1) HR reaction fires correctly mid-multi-beam spell chain, (2) queued beam 2 proceeds after reaction resolves, (3) both characters take appropriate damage.",
  "setup": {
    "characters": [
      {
        "name": "Malachar the Dark",
        "className": "Warlock",
        "level": 5,
        "position": { "x": 10, "y": 10 },
        "sheet": {
          "level": 5,
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 14,
            "intelligence": 10, "wisdom": 12, "charisma": 18
          },
          "maxHp": 38, "currentHp": 38, "armorClass": 14, "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "charisma",
          "spellSaveDC": 15,
          "spellAttackBonus": 7,
          "spellSlots": { "3": 2 },
          "preparedSpells": [
            { "name": "Eldritch Blast", "level": 0 }
          ],
          "attacks": []
        }
      },
      {
        "name": "Lyra the Hexblade",
        "className": "Warlock",
        "level": 3,
        "position": { "x": 25, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 10, "dexterity": 8, "constitution": 14,
            "intelligence": 10, "wisdom": 12, "charisma": 18
          },
          "maxHp": 30, "currentHp": 30, "armorClass": 5, "speed": 30,
          "proficiencyBonus": 2,
          "spellcastingAbility": "charisma",
          "spellSaveDC": 14,
          "spellAttackBonus": 6,
          "spellSlots": { "1": 2 },
          "preparedSpells": [
            { "name": "Hellish Rebuke", "level": 1 }
          ],
          "attacks": []
        }
      }
    ],
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 50, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10, "dexterity": 4, "constitution": 18,
            "intelligence": 1, "wisdom": 6, "charisma": 1
          },
          "maxHp": 100, "hp": 100, "armorClass": 10, "speed": 0,
          "challengeRating": 0, "experienceValue": 0,
          "attacks": [
            {
              "name": "None", "kind": "melee",
              "attackBonus": 0,
              "damage": { "diceCount": 1, "diceSides": 1, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I ready my eldritch power" },
      "comment": "Malachar initiates combat",
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "Malachar rolls 20 + 2 DEX = 22 initiative. Always goes first (Lyra max 19 with DEX 8, Dummy max 17 with DEX 4).",
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Cast Eldritch Blast at Lyra — at level 5, fires 2 beams (each is a separate spell attack)",
      "type": "action",
      "input": { "text": "cast Eldritch Blast at Lyra the Hexblade" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "comment": "Beam 1 attack roll: 15 + 7 = 22 vs AC 5 — HIT",
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Beam 1 damage: 8 force. Lyra: 30 - 8 = 22 HP. Beam 2 is queued. HR damage reaction detected.",
      "type": "rollResult",
      "input": { "text": "I rolled 8" },
      "expect": { "actionComplete": false }
    },
    {
      "comment": "Wait for Lyra's Hellish Rebuke damage reaction. Queue holds: [reaction_pending, ATTACK(beam 2/2)].",
      "type": "waitForReaction",
      "input": { "reactionType": "hellish_rebuke" },
      "timeout": 5000
    },
    {
      "comment": "Lyra uses Hellish Rebuke — 2d10 fire damage to Malachar, DEX save DC 14 for half.",
      "type": "reactionRespond",
      "input": { "choice": "use" }
    },
    {
      "comment": "Beam 2 attack roll (auto-promoted from queue after HR resolves): 12 + 7 = 19 vs AC 5 — HIT",
      "type": "rollResult",
      "input": { "text": "I rolled 12" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Beam 2 damage: 6 force. Lyra: 22 - 6 = 16 HP. Both beams complete — queue fully drained.",
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "actor": "Malachar the Dark",
      "comment": "Malachar took fire damage from Hellish Rebuke (2d10, DEX save DC 14 for half). Starts at 38 HP.",
      "expect": {
        "characterHp": { "min": 18, "max": 37 }
      }
    },
    {
      "type": "assertState",
      "actor": "Lyra the Hexblade",
      "comment": "Lyra took 8 + 6 = 14 force damage from both beams. 30 - 14 = 16 HP remaining.",
      "expect": {
        "characterHp": { "min": 12, "max": 18 }
      }
    },
    {
      "type": "endTurn",
      "comment": "Malachar ends his turn after both beams with HR reaction mid-chain."
    }
  ]
}
