{
  "name": "Rogue R2: Cunning Escape Artist — All 3 Cunning Actions + Uncanny Dodge",
  "description": "Level 5 Thief Rogue Lyra fights a Bandit Captain and a Bandit across 4 rounds. Tests all three Cunning Action variants: Disengage (R1 bonus before repositioning out of melee), Hide from legitimate cover leading to a ranged Sneak Attack via advantage (R2 bonus before attack), and Dash for repositioning (R3 bonus before Shortbow attack). Uncanny Dodge reaction is triggered in R2's monster turn using a queued guaranteed-hit ranged hit. Verifies CA bonus-action economy, SA eligibility from Hidden advantage, and Uncanny Dodge halving damage.",
  "setup": {
    "character": {
      "name": "Lyra",
      "className": "Rogue",
      "subclass": "Thief",
      "level": 5,
      "position": { "x": 5, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 18,
          "constitution": 14,
          "intelligence": 12,
          "wisdom": 12,
          "charisma": 14
        },
        "maxHp": 100,
        "currentHp": 100,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 3,
        "skills": { "stealth": 10 },
        "attacks": [
          {
            "name": "Rapier",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
            "damageType": "piercing",
            "properties": ["finesse"]
          },
          {
            "name": "Shortbow",
            "kind": "ranged",
            "range": "80/320",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "piercing"
          }
        ],
        "features": [
          { "name": "Sneak Attack", "description": "3d6 extra damage with advantage or ally adjacent to target" },
          { "name": "Cunning Action", "description": "Dash, Disengage, or Hide as bonus action" },
          { "name": "Uncanny Dodge", "description": "Halve damage from one attack as a reaction" }
        ]
      }
    },
    "monsters": [
      {
        "comment": "Bandit Captain with melee and ranged attacks.",
        "name": "Bandit Captain",
        "position": { "x": 10, "y": 10 },
        "statBlock": {
          "type": "humanoid",
          "abilityScores": {
            "strength": 15,
            "dexterity": 16,
            "constitution": 14,
            "intelligence": 12,
            "wisdom": 11,
            "charisma": 14
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 15,
          "speed": 30,
          "passivePerception": 10,
          "challengeRating": 2,
          "experienceValue": 450,
          "actions": [
            { "name": "Multiattack", "description": "The captain makes two scimitar attacks." }
          ],
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
              "damageType": "slashing"
            },
            {
              "name": "Shortbow",
              "kind": "ranged",
              "range": "80/320",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "comment": "Bandit with melee and ranged attacks.",
        "name": "Bandit",
        "position": { "x": 10, "y": 9 },
        "statBlock": {
          "type": "humanoid",
          "abilityScores": {
            "strength": 11,
            "dexterity": 12,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 10
          },
          "maxHp": 80,
          "hp": 80,
          "armorClass": 12,
          "speed": 30,
          "passivePerception": 10,
          "challengeRating": 0.125,
          "experienceValue": 25,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 1 },
              "damageType": "slashing"
            },
            {
              "name": "Shortbow",
              "kind": "ranged",
              "range": "80/320",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 1 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "attack"
    }
  },
  "actions": [

    {
      "comment": "=== ROUND 1: Attack + Cunning Action: Disengage (CA1) ===",
      "type": "initiate",
      "input": { "text": "I attack the Bandit Captain with my Rapier" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "comment": "High initiative roll so Lyra acts first.",
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true }
    },

    {
      "comment": "R1 main action: attack Bandit Captain with Rapier. No SA guaranteed here (Bandit is enemy faction, not party ally).",
      "type": "action",
      "input": { "text": "attack Bandit Captain with Rapier" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "comment": "Attack roll 14 + 7 = 21 vs AC 15 — hit.",
      "type": "rollResult",
      "input": { "text": "14" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Damage roll: submit weapon die value. Server adds +4 modifier.",
      "type": "rollResult",
      "input": { "text": "5" },
      "expect": { "actionComplete": true }
    },

    {
      "comment": "R1 bonus action: Cunning Action Disengage (CA1 tested). Prevents opportunity attacks on movement.",
      "type": "action",
      "input": { "text": "cunning action disengage" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Use the protected movement from Disengage to withdraw to a legal ranged position for the later Hide turn.",
      "type": "action",
      "input": { "text": "move to (35, 10)" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Lyra took no damage this round after using Disengage to leave melee safely.",
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 100, "max": 100 },
        "monsterHp": { "name": "Bandit Captain", "min": 85, "max": 100 }
      }
    },

    {
      "comment": "Queue R1 monster turns: Captain fires two Shortbow shots, Bandit fires one Shortbow shot at range.",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": false },
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": true },
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": true }
        ]
      }
    },
    {
      "comment": "End R1 — monsters act.",
      "type": "endTurn"
    },
    {
      "comment": "Wait for all monster turns to complete.",
      "type": "waitForTurn",
      "timeout": 15000
    },
    {
      "comment": "R1 aftermath: monsters may have hit (broad range; Uncanny Dodge not yet used this round).",
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 70, "max": 100 },
        "combatStatus": "Active"
      }
    },

    {
      "comment": "Add half cover between Lyra and the bandits so the Hide attempt is backed by real battlefield cover.",
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 20, "y": 10, "terrain": "cover-half" }
        ]
      }
    },
    {
      "comment": "=== ROUND 2: Cunning Action: Hide (CA2) + Sneak Attack from advantage + Uncanny Dodge ===",
      "type": "action",
      "input": { "text": "cunning action hide" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Verify Lyra has the Hidden condition after Cunning Action: Hide from half cover.",
      "type": "assertState",
      "expect": {
        "characterConditions": { "hasConditions": ["Hidden"] }
      }
    },

    {
      "comment": "R2 main action: attack Bandit Captain with Shortbow while hidden (advantage). SA eligible via advantage.",
      "type": "action",
      "input": { "text": "attack Bandit Captain with Shortbow" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true, "advantage": true }
    },
    {
      "comment": "Attack roll 15 + 7 = 22 vs AC 15 — hit. Advantage from Hidden state.",
      "type": "rollResult",
      "input": { "text": "15" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Damage roll: player submits combined weapon + Sneak Attack dice (1d6 + 3d6). Server adds +4.",
      "type": "rollResult",
      "input": { "text": "14" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Clear the temporary cover before the enemy ranged attacks so later hit math is unchanged.",
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 20, "y": 10, "terrain": "normal" }
        ]
      }
    },

    {
      "comment": "Queue a guaranteed-hit die roll (18) so the Captain's first Shortbow attack will hit Lyra and trigger Uncanny Dodge eligibility.",
      "type": "queueDiceRolls",
      "input": { "values": [18] }
    },
    {
      "comment": "Queue R2 monster turns: Captain fires two Shortbow shots and Bandit fires one Shortbow shot. First Captain roll uses queued 18 (18+5=23 vs AC 15 = hit).",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": false },
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": true },
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": true }
        ]
      }
    },
    {
      "comment": "End R2 — Captain's guaranteed ranged hit triggers Uncanny Dodge prompt.",
      "type": "endTurn"
    },
    {
      "comment": "Wait for the server to pause on Uncanny Dodge reaction (Captain's first Shortbow shot hits with the queued 18).",
      "type": "waitForReaction",
      "input": { "reactionType": "uncanny_dodge" },
      "timeout": 15000
    },
    {
      "comment": "Use Uncanny Dodge reaction to halve the incoming damage (CA2 + Uncanny Dodge tested).",
      "type": "reactionRespond",
      "input": { "choice": "use" }
    },
    {
      "comment": "Wait for remaining monster turns (Captain's 2nd attack + Bandit) to complete.",
      "type": "waitForTurn",
      "timeout": 15000
    },
    {
      "comment": "R2 aftermath: Uncanny Dodge halved the first hit. HP range is broad due to remaining monster attacks.",
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 50, "max": 100 },
        "combatStatus": "Active"
      }
    },

    {
      "comment": "=== ROUND 3: Cunning Action: Dash (CA3) + Shortbow ranged attack ===",
      "type": "action",
      "input": { "text": "cunning action dash" },
      "expect": { "actionComplete": true }
    },

    {
      "comment": "R3 main action: Shortbow attack on Bandit Captain from range (tests ranged attack after Dash repositioning).",
      "type": "action",
      "input": { "text": "attack Bandit Captain with Shortbow" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "comment": "Attack roll 12 + 7 = 19 vs AC 15 — hit.",
      "type": "rollResult",
      "input": { "text": "12" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Damage: 1d6 weapon die + 4 modifier.",
      "type": "rollResult",
      "input": { "text": "5" },
      "expect": { "actionComplete": true }
    },

    {
      "comment": "Queue R3 monster turns: Captain fires two Shortbow shots and Bandit fires one Shortbow shot.",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": false },
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": true },
          { "action": "attack", "target": "Lyra", "attackName": "Shortbow", "endTurn": true }
        ]
      }
    },
    {
      "comment": "End R3.",
      "type": "endTurn"
    },
    {
      "comment": "Wait for monster turns.",
      "type": "waitForTurn",
      "timeout": 15000
    },
    {
      "comment": "R3 aftermath: three Cunning Actions tested (Disengage, Hide, Dash). HP still viable.",
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 20, "max": 100 },
        "combatStatus": "Active"
      }
    },

    {
      "comment": "=== ROUND 4: Final verification attack ===",
      "type": "action",
      "input": { "text": "attack Bandit Captain with Shortbow" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "comment": "Attack roll 16 + 7 = 23 vs AC 15 — hit.",
      "type": "rollResult",
      "input": { "text": "16" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Damage roll.",
      "type": "rollResult",
      "input": { "text": "6" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Final state check: combat still active, Bandit Captain has taken cumulative damage across all 4 rounds.",
      "type": "assertState",
      "expect": {
        "combatStatus": "Active",
        "monsterHp": { "name": "Bandit Captain", "min": 40, "max": 100 }
      }
    }

  ]
}
