{
  "name": "Bardic Inspiration consumption on failed d20 roll",
  "description": "Bard grants Bardic Inspiration to Fighter. Fighter attacks high-AC target, rolls low (miss). Roll-interrupt hook pauses resolution and offers BI die. Fighter uses BI, die is added, total now hits. Damage roll follows.",
  "setup": {
    "characters": [
      {
        "name": "Lyric the Bard",
        "className": "Bard",
        "subclass": "Lore",
        "level": 5,
        "position": { "x": 8, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 10, "dexterity": 14, "constitution": 12,
            "intelligence": 12, "wisdom": 10, "charisma": 18
          },
          "maxHp": 34, "currentHp": 34, "armorClass": 14, "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "charisma",
          "spellSaveDC": 15, "spellAttackBonus": 7,
          "spellSlots": { "1": 4, "2": 3, "3": 2 },
          "attacks": [
            { "name": "Rapier", "kind": "melee", "attackBonus": 5, "damage": { "diceCount": 1, "diceSides": 8, "modifier": 2 }, "damageType": "piercing" }
          ],
          "resourcePools": [
            { "name": "bardicInspiration", "current": 3, "max": 3 }
          ]
        }
      },
      {
        "name": "Thorin",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 10, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 18, "dexterity": 12, "constitution": 16,
            "intelligence": 10, "wisdom": 10, "charisma": 8
          },
          "maxHp": 54, "currentHp": 54, "armorClass": 18, "speed": 30,
          "proficiencyBonus": 3,
          "attacks": [
            { "name": "Longsword", "kind": "melee", "attackBonus": 7, "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 }, "damageType": "slashing" }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Armored Sentinel",
        "position": { "x": 11, "y": 10 },
        "statBlock": {
          "abilityScores": { "strength": 16, "dexterity": 10, "constitution": 14, "intelligence": 10, "wisdom": 10, "charisma": 10 },
          "maxHp": 60, "hp": 60, "armorClass": 18, "speed": 30,
          "challengeRating": 2,
          "attacks": [{ "name": "Halberd", "kind": "melee", "attackBonus": 5, "damage": { "diceCount": 1, "diceSides": 10, "modifier": 3 }, "damageType": "slashing" }]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Lyric the Bard",
      "input": { "text": "Lyric prepares an inspirational verse" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Lyric the Bard",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "waitForTurn",
      "actor": "Lyric the Bard",
      "timeout": 15000
    },
    {
      "comment": "Lyric grants Bardic Inspiration to Thorin as a bonus action. Pool 3 -> 2.",
      "type": "action",
      "actor": "Lyric the Bard",
      "input": { "text": "inspire Thorin" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "actor": "Lyric the Bard",
      "expect": { "characterResource": { "poolName": "bardicInspiration", "current": 2, "max": 3 } }
    },
    { "type": "endTurn", "actor": "Lyric the Bard" },

    {
      "type": "waitForTurn",
      "actor": "Thorin",
      "timeout": 15000
    },
    {
      "type": "action",
      "actor": "Thorin",
      "input": { "text": "attack Armored Sentinel" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Thorin",
      "input": { "text": "8" },
      "comment": "8 + 7 = 15 vs AC 18 -> miss. Thorin has BI available -> roll-interrupt fires.",
      "expect": { "hit": false, "requiresPlayerInput": true }
    },
    {
      "type": "queueDiceRolls",
      "input": { "values": [5], "label": "BI die (d8=5): 15+5=20 >= AC 18 -> hit" }
    },
    {
      "type": "rollInterruptResolve",
      "actor": "Thorin",
      "input": { "choice": "bardic-inspiration" },
      "comment": "Use BI: d8=5, total 15+5=20 vs AC 18 -> HIT. Needs damage roll.",
      "expect": { "hit": true, "requiresPlayerInput": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "actor": "Thorin",
      "input": { "text": "6" },
      "comment": "Damage: 1d8+4, roll 6 -> 10 damage",
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "actor": "Lyric the Bard",
      "expect": { "characterResource": { "poolName": "bardicInspiration", "current": 2, "max": 3 } },
      "comment": "BI consumed from Thorin's effect; Lyric's pool remains 2 (already spent on grant)."
    }
  ]
}
