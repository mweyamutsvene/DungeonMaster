{
  "name": "Fighter: Burst and Endurance — Action Surge + Second Wind + Extra Attack",
  "description": "A level 5 Champion Fighter fights an Orc Warchief and Hobgoblin across 4 rounds, exercising Action Surge (4 attacks in one round), Second Wind (bonus action self-heal), and Extra Attack every round. Monsters attack via queueMonsterActions. Tests resource depletion across a sustained fight.",
  "setup": {
    "character": {
      "name": "Sir Marcus",
      "className": "Fighter",
      "subclass": "Champion",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 100,
        "currentHp": 100,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
            "damageType": "slashing"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" },
          { "name": "Action Surge", "description": "Take an additional action (1/short rest)" },
          { "name": "Second Wind", "description": "Regain 1d10 + Fighter level HP as a bonus action (1/short rest)" }
        ],
        "resourcePools": [
          { "name": "actionSurge", "current": 1, "max": 1 },
          { "name": "secondWind", "current": 1, "max": 1 }
        ]
      }
    },
    "monsters": [
      {
        "name": "Orc Warchief",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "type": "humanoid",
          "abilityScores": {
            "strength": 18,
            "dexterity": 12,
            "constitution": 18,
            "intelligence": 11,
            "wisdom": 11,
            "charisma": 16
          },
          "maxHp": 120,
          "hp": 120,
          "armorClass": 16,
          "speed": 30,
          "challengeRating": 4,
          "attacks": [
            {
              "name": "Greataxe",
              "kind": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 1, "diceSides": 12, "modifier": 4 },
              "damageType": "slashing"
            },
            {
              "name": "Javelin",
              "kind": "ranged",
              "range": "30/120",
              "attackBonus": 6,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Hobgoblin Warrior",
        "position": { "x": 15, "y": 12 },
        "statBlock": {
          "type": "humanoid",
          "abilityScores": {
            "strength": 13,
            "dexterity": 12,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 9
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 18,
          "speed": 30,
          "challengeRating": 0.5,
          "attacks": [
            {
              "name": "Longsword",
              "kind": "melee",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 1 },
              "damageType": "slashing"
            },
            {
              "name": "Longbow",
              "kind": "ranged",
              "range": "150/600",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 1 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "comment": "=== ROUND 1: Open with standard attacks (Extra Attack: 2 hits) ===",
      "type": "initiate",
      "input": { "text": "I attack the Orc Warchief" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first"
    },

    {
      "comment": "R1 — Extra Attack 1/2: Attack Orc Warchief with Longsword",
      "type": "action",
      "input": { "text": "attack Orc Warchief with Longsword" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 7 = 22 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 4 = 10 slashing. Extra Attack chains to attack 2/2.",
      "expect": { "actionComplete": false }
    },
    {
      "type": "rollResult",
      "input": { "text": "14" },
      "comment": "Extra Attack 2/2: 14 + 7 = 21 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 4 = 9 slashing. Total R1: 19 damage to Orc (120 → 101).",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "R1 checkpoint: Orc took 19 damage, resources untouched",
      "expect": {
        "monsterHp": { "name": "Orc Warchief", "min": 90, "max": 110 },
        "characterResource": { "poolName": "actionSurge", "current": 1, "max": 1 },
        "characterResource2": { "poolName": "secondWind", "current": 1, "max": 1 }
      }
    },

    {
      "comment": "Queue monster turns: Orc Greataxe, Hobgoblin Longbow",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Sir Marcus", "attackName": "Greataxe", "endTurn": true },
          { "action": "attack", "target": "Sir Marcus", "attackName": "Longbow", "endTurn": true }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "End R1 player turn — monsters attack"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait through monster turns"
    },

    {
      "type": "assertState",
      "comment": "R1 aftermath: Sir Marcus possibly took some damage",
      "expect": {
        "characterHp": { "min": 50, "max": 100 },
        "combatStatus": "Active"
      }
    },

    {
      "comment": "=== ROUND 2: ACTION SURGE — Attack (2), then Action Surge, then Attack (2) = 4 total attacks ===",
      "type": "action",
      "input": { "text": "attack Orc Warchief with Longsword" },
      "comment": "R2 — First action: Extra Attack 1/2",
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "13" },
      "comment": "13 + 7 = 20 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "7" },
      "comment": "7 + 4 = 11 slashing. Extra Attack chains.",
      "expect": { "actionComplete": false }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "comment": "Extra Attack 2/2: 12 + 7 = 19 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "4" },
      "comment": "4 + 4 = 8 slashing. First action complete (2 attacks done).",
      "expect": { "actionComplete": true }
    },

    {
      "comment": "R2 — Now use Action Surge to gain a second action this turn",
      "type": "action",
      "input": { "text": "use action surge" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Action Surge consumed",
      "expect": {
        "characterResource": { "poolName": "actionSurge", "current": 0, "max": 1 }
      }
    },

    {
      "comment": "R2 — Second action (from Action Surge): Extra Attack 3/4",
      "type": "action",
      "input": { "text": "attack Orc Warchief with Longsword" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "16" },
      "comment": "16 + 7 = 23 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "8" },
      "comment": "8 + 4 = 12 slashing. Extra Attack chains to 4/4.",
      "expect": { "actionComplete": false }
    },
    {
      "type": "rollResult",
      "input": { "text": "11" },
      "comment": "Extra Attack 4/4: 11 + 7 = 18 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 4 = 10 slashing. Total R2: 41 damage to Orc (~60 HP remaining).",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "R2 checkpoint: Orc heavily damaged, Action Surge spent",
      "expect": {
        "monsterHp": { "name": "Orc Warchief", "min": 40, "max": 80 },
        "characterResource": { "poolName": "actionSurge", "current": 0, "max": 1 }
      }
    },

    {
      "comment": "Queue monster R2 turns: Orc Greataxe, Hobgoblin Longbow",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Sir Marcus", "attackName": "Greataxe", "endTurn": true },
          { "action": "attack", "target": "Sir Marcus", "attackName": "Longbow", "endTurn": true }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "End R2 player turn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait through monster R2 turns"
    },

    {
      "comment": "=== ROUND 3: Second Wind (bonus action heal) + Attack ===",
      "type": "action",
      "input": { "text": "use second wind" },
      "comment": "Second Wind: bonus action heal 1d10+5. Consumes resource.",
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Second Wind consumed, HP should have increased",
      "expect": {
        "characterResource": { "poolName": "secondWind", "current": 0, "max": 1 },
        "characterHp": { "min": 30, "max": 100 }
      }
    },

    {
      "comment": "R3 — Still have action. Attack Orc Warchief (Extra Attack 1/2)",
      "type": "action",
      "input": { "text": "attack Orc Warchief with Longsword" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "14" },
      "comment": "14 + 7 = 21 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "7" },
      "comment": "7 + 4 = 11 slashing. Extra Attack chains.",
      "expect": { "actionComplete": false }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "Extra Attack 2/2: 15 + 7 = 22 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 4 = 9 slashing. R3 total: 20 damage to Orc.",
      "expect": { "actionComplete": true }
    },

    {
      "comment": "Queue monster R3 turns",
      "type": "queueMonsterActions",
      "input": {
        "decisions": [
          { "action": "attack", "target": "Sir Marcus", "attackName": "Greataxe", "endTurn": true },
          { "action": "attack", "target": "Sir Marcus", "attackName": "Longsword", "endTurn": true }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "End R3 player turn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait through monster R3 turns"
    },

    {
      "comment": "=== ROUND 4: Standard attacks — both resources depleted ===",
      "type": "action",
      "input": { "text": "attack Orc Warchief with Longsword" },
      "comment": "R4 — Extra Attack 1/2",
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "16" },
      "comment": "16 + 7 = 23 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "8" },
      "comment": "8 + 4 = 12 slashing. Extra Attack chains.",
      "expect": { "actionComplete": false }
    },
    {
      "type": "rollResult",
      "input": { "text": "13" },
      "comment": "Extra Attack 2/2: 13 + 7 = 20 vs AC 16 → hit",
      "expect": { "hit": true, "rollType": "damage", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 4 = 10 slashing. R4 total: 22 damage.",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "Final: Both resources depleted, combat active, both monsters alive",
      "expect": {
        "characterResource": { "poolName": "actionSurge", "current": 0, "max": 1 },
        "characterResource2": { "poolName": "secondWind", "current": 0, "max": 1 },
        "combatStatus": "Active",
        "monstersAlive": 2
      }
    }
  ]
}
