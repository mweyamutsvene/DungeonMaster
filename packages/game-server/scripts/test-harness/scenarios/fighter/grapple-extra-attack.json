{
  "name": "Fighter Grapple + Extra Attack: Grapple then attack same turn",
  "description": "A Level 5 Fighter with Extra Attack grapples a Goblin via the tabletop dice flow (Unarmed Strike attack roll → inline saving throw) using 1 of 2 attacks, then attacks the same turn with the 2nd attack. Validates D&D 5e 2024 rule: grapple replaces ONE attack in a multi-attack action.",
  "setup": {
    "character": {
      "name": "Grimgar the Grappler",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 20,
          "dexterity": 12,
          "constitution": 16,
          "intelligence": 8,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 8,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 5 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Target",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 10,
          "speed": 30,
          "size": "Small",
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High roll so player goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "grapple Goblin Target" },
      "comment": "Tabletop dice flow: creates ATTACK pending action with contestType='grapple'. Unarmed Strike: STR +5, prof +3 = +8 vs AC 10. Contest DC 16.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 8 = 23 vs AC 10 → HIT. Server auto-resolves saving throw inline: target DEX save +2 vs DC 16 → should fail. Grappled applied. Uses 1 of 2 attacks.",
      "expect": {
        "hit": true,
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify the Goblin has Grappled condition after contest resolution",
      "expect": {
        "monsterConditions": {
          "name": "Goblin Target",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Goblin Target" },
      "comment": "2nd attack in the same turn (Extra Attack). canMakeAttack() allows it — only 1 of 2 attack slots used.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 8 = 23 vs AC 10 — hit",
      "expect": {
        "hit": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "1d8+5 = 11 slashing damage. All attacks used, action complete.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn"
    }
  ]
}
