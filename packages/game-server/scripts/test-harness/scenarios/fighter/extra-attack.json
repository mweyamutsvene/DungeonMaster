{
  "name": "Fighter Extra Attack: Two Attacks Per Action",
  "description": "A level 5 Fighter uses Extra Attack to make two melee attacks with one Attack action. Tests that the action economy allows multiple attacks for characters with the Extra Attack feature.",
  "setup": {
    "character": {
      "name": "Sir Marcus",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 35, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
            "damageType": "slashing"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 8,
            "constitution": 18,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 10,
          "speed": 0,
          "challengeRating": 0,
          "experienceValue": 0,
          "attacks": [
            {
              "name": "None",
              "kind": "melee",
              "attackBonus": 0,
              "damage": { "diceCount": 1, "diceSides": 1, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training dummy" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy" },
      "comment": "First attack of Extra Attack - should succeed",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 7 = 22 vs AC 10 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 4 = 10 damage. Extra Attack chains to attack 2/2.",
      "expect": {
        "actionComplete": false
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "comment": "Chained Extra Attack 2/2: 12 + 7 = 19 vs AC 10 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 4 = 9 damage. Both Extra Attacks complete!",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy" },
      "comment": "Third attack - SHOULD FAIL (Extra Attack only grants 2 attacks total)",
      "expect": {
        "error": true,
        "errorContains": "already spent"
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn after using both attacks"
    }
  ]
}
