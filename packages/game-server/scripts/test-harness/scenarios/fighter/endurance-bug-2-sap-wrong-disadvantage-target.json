{
  "name": "BUG-2 Regression: Dead Enemy Should Not Cause Ranged Disadvantage",
  "description": "After killing an adjacent enemy, a ranged/thrown attack against a distant enemy should NOT have disadvantage from the dead corpse counting as 'hostile within 5ft'. The original report attributed this to Sap, but the actual cause is the weapon auto-switch (BUG-1) to a thrown weapon combined with the dead adjacent enemy still counting as threatening.",
  "setup": {
    "character": {
      "name": "Valeria Steelhand",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 0, "y": 5 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 12,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 14,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          },
          {
            "name": "Handaxe",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["light", "thrown"],
            "thrown": "20/60"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action." },
          { "name": "Action Surge", "description": "Take one additional action on your turn." }
        ],
        "resourcePools": [
          { "name": "actionSurge", "current": 1, "max": 1 }
        ]
      }
    },
    "monsters": [
      {
        "name": "Hobgoblin Soldier A",
        "position": { "x": 5, "y": 5 },
        "statBlock": {
          "abilityScores": {
            "strength": 13,
            "dexterity": 12,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 9
          },
          "maxHp": 8,
          "hp": 8,
          "armorClass": 10,
          "speed": 30,
          "challengeRating": 0.5,
          "attacks": [
            {
              "name": "Longsword",
              "kind": "melee",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 1 },
              "damageType": "slashing"
            }
          ]
        }
      },
      {
        "name": "Hobgoblin Soldier B",
        "position": { "x": 20, "y": 5 },
        "statBlock": {
          "abilityScores": {
            "strength": 13,
            "dexterity": 12,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 9
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 16,
          "speed": 30,
          "challengeRating": 0.5,
          "attacks": [
            {
              "name": "Longsword",
              "kind": "melee",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 1 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "comment": "Start encounter",
      "type": "initiate",
      "input": { "text": "I attack Hobgoblin Soldier A with my longsword" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "comment": "Go first",
      "type": "rollResult",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Hit Soldier A — low HP, should die in one hit",
      "type": "action",
      "input": { "text": "I attack Hobgoblin Soldier A with my longsword" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "10 damage kills Soldier A (8 HP). EA auto-chains and auto-completes.",
      "type": "rollResult",
      "input": { "text": "7" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Confirm Soldier A is dead",
      "type": "assertState",
      "expect": { "monsterHp": { "name": "Hobgoblin Soldier A", "exact": 0 } }
    },
    {
      "comment": "Action Surge for fresh attacks",
      "type": "action",
      "input": { "text": "use action surge" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Throw handaxe at distant Soldier B (20ft away). Dead Soldier A at (5,5) is adjacent but should NOT cause 'hostile within 5ft' ranged disadvantage.",
      "type": "action",
      "input": { "text": "I throw my handaxe at Hobgoblin Soldier B" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true,
        "disadvantage": false
      }
    }
  ]
}
