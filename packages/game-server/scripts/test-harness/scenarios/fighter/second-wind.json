{
  "name": "Fighter Second Wind: Bonus action heal",
  "description": "A Fighter uses Second Wind as a bonus action to recover HP during combat. Tests the Second Wind resource spending and healing.",
  "setup": {
    "character": {
      "name": "Bruised Baldric",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 20,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
            "damageType": "slashing"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" },
          { "name": "Second Wind", "description": "Regain 1d10 + Fighter level HP as a bonus action (1/short rest)" }
        ],
        "resourcePools": [
          { "name": "secondWind", "current": 1, "max": 1 }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 8,
            "constitution": 18,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 200,
          "hp": 200,
          "armorClass": 10,
          "speed": 0,
          "challengeRating": 0,
          "experienceValue": 0,
          "attacks": []
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training dummy" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "use second wind" },
      "comment": "Second Wind - bonus action to heal 1d10 + Fighter level (5) HP",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy" },
      "comment": "Can still attack after using Second Wind (bonus action)",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn"
    },
    {
      "type": "action",
      "input": { "text": "use second wind" },
      "comment": "Second Wind should fail - already used this rest",
      "expect": {
        "error": true
      }
    }
  ]
}
