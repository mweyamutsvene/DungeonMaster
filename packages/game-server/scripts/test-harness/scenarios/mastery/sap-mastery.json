{
  "name": "Weapon Mastery: Sap (Longsword)",
  "description": "A Fighter with a Longsword (Sap mastery) hits a target. The target should receive the Sapped condition (disadvantage on next attack roll).",
  "setup": {
    "character": {
      "name": "Sap Fighter",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 35, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Orc Warrior",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 16,
            "dexterity": 12,
            "constitution": 16,
            "intelligence": 7,
            "wisdom": 11,
            "charisma": 10
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 13,
          "speed": 30,
          "challengeRating": 0.5,
          "attacks": [
            {
              "name": "Greataxe",
              "kind": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 12, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the orc with my longsword" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Orc Warrior with my longsword" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "Roll of 15 + 6 = 21 vs AC 13 = HIT. Sap mastery triggers on hit.",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 5" },
      "comment": "Damage roll: 5 + 3 = 8 damage. Sap mastery: target gets Sapped condition.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Orc should have Sapped condition from Sap mastery (disadvantage on next attack).",
      "expect": {
        "monsterConditions": { "name": "Orc Warrior", "hasConditions": ["Sapped"] }
      }
    }
  ]
}
