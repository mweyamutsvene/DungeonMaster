{
  "name": "Weapon Mastery: Topple (Maul)",
  "description": "A Fighter with a Maul (Topple mastery) hits and the target must make a CON save or be knocked Prone. The goblin has low CON (+0) so is likely to fail.",
  "setup": {
    "character": {
      "name": "Maul Fighter",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 35, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Maul",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 2, "diceSides": 6, "modifier": 4 },
            "damageType": "bludgeoning",
            "properties": ["heavy", "two-handed"]
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Brute",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 40,
          "hp": 40,
          "armorClass": 13,
          "speed": 30,
          "challengeRating": 0.5,
          "attacks": [
            {
              "name": "Club",
              "kind": "melee",
              "attackBonus": 2,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 1 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the goblin with my maul" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Goblin Brute with my maul" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "Roll of 15 + 7 = 22 vs AC 13 = HIT. Topple mastery triggers CON save.",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "Damage roll. After damage, Topple triggers: CON save DC 15 (8 + 4 STR + 3 prof).",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Goblin should have Prone condition from Topple mastery (low CON save).",
      "expect": {
        "monsterConditions": { "name": "Goblin Brute", "hasConditions": ["Prone"] }
      }
    }
  ]
}
