{
  "name": "Weapon Mastery: Nick (Scimitar off-hand)",
  "description": "A Fighter dual-wielding Shortsword (main) + Scimitar (off-hand, Nick mastery). After a main-hand attack, the off-hand attack with Nick does NOT consume the bonus action. Then Second Wind (a bonus action) is still available, proving Nick preserved the bonus action.",
  "setup": {
    "character": {
      "name": "Nick Fighter",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 35, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 14,
          "dexterity": 18,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 20,
        "armorClass": 17,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "piercing",
            "properties": ["finesse", "light"]
          },
          {
            "name": "Scimitar",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "slashing",
            "properties": ["finesse", "light"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" },
          { "name": "Second Wind", "description": "Regain 1d10 + Fighter level HP as a bonus action (1/short rest)" }
        ],
        "resourcePools": [
          { "name": "secondWind", "current": 1, "max": 1 }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 8,
            "constitution": 18,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 200,
          "hp": 200,
          "armorClass": 10,
          "speed": 0,
          "challengeRating": 0,
          "experienceValue": 0,
          "attacks": []
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training dummy" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Training Dummy with my shortsword" },
      "comment": "Main-hand attack with Shortsword. Required before off-hand attack.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "15 + 7 = 22 vs AC 10 = HIT",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 4" },
      "comment": "Damage: 4 + 4 = 8 damage",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "off-hand attack" },
      "comment": "Off-hand attack with Scimitar (Nick mastery). Should NOT consume bonus action.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 12" },
      "comment": "12 + 7 = 19 vs AC 10 = HIT",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 3" },
      "comment": "Off-hand damage: 3 + 0 = 3 (no ability modifier on off-hand)",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "use second wind" },
      "comment": "Second Wind is a bonus action. Should succeed because Nick preserved the bonus action from the off-hand attack.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Character HP should be above 20 (started at 20, Second Wind heals 1d10+5). Training Dummy took ~11 total damage.",
      "expect": {
        "characterHp": { "min": 21 }
      }
    }
  ]
}
