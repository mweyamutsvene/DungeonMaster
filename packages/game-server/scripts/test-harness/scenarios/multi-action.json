{
  "name": "Multi-Action Combat: Full Turn Tactics",
  "description": "A Fighter demonstrates multiple action types across several turns: Move, Attack, Dodge, Dash, and Disengage. Tests the complete action economy and turn management system.",
  "setup": {
    "character": {
      "name": "Marcus Battleborn",
      "className": "Fighter",
      "level": 5,
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Warhammer",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Hobgoblin Captain",
        "statBlock": {
          "abilityScores": {
            "strength": 15,
            "dexterity": 14,
            "constitution": 14,
            "intelligence": 12,
            "wisdom": 10,
            "charisma": 13
          },
          "maxHp": 39,
          "hp": 39,
          "armorClass": 17,
          "speed": 30,
          "challengeRating": 3,
          "experienceValue": 700,
          "attacks": [
            {
              "name": "Longsword",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 10, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I engage the hobgoblin" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 16" },
      "comment": "16 + 2 (DEX) = 18, goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (35, 10)" },
      "comment": "TURN 1: Move 25ft to close distance",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Hobgoblin Captain with my warhammer" },
      "comment": "TURN 1: Attack action",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 14" },
      "comment": "14 + 6 = 20 vs AC 17 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "6 + 3 = 9 damage. Hobgoblin: 39 - 9 = 30 HP",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn 1"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Hobgoblin's turn",
      "timeout": 5000
    },
    {
      "type": "action",
      "input": { "text": "dodge" },
      "comment": "TURN 2: Take Dodge action for defense",
      "expect": {
        "actionComplete": true,
        "type": "SIMPLE_ACTION_COMPLETE"
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn 2 - Hobgoblin attacks with disadvantage"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Hobgoblin's turn",
      "timeout": 5000
    },
    {
      "type": "action",
      "input": { "text": "I attack the Hobgoblin Captain with my warhammer" },
      "comment": "TURN 3: Another attack",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 12" },
      "comment": "12 + 6 = 18 vs AC 17 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 7" },
      "comment": "7 + 3 = 10 damage. Hobgoblin: 30 - 10 = 20 HP",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn 3"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Hobgoblin's turn",
      "timeout": 5000
    },
    {
      "type": "action",
      "input": { "text": "disengage" },
      "comment": "TURN 4: Disengage to retreat safely",
      "expect": {
        "actionComplete": true,
        "type": "SIMPLE_ACTION_COMPLETE"
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (10, 10)" },
      "comment": "TURN 4: Retreat 25ft - no opportunity attack because Disengaged",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn 4"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Hobgoblin's turn",
      "timeout": 5000
    },
    {
      "type": "action",
      "input": { "text": "dash" },
      "comment": "TURN 5: Dash to double movement speed",
      "expect": {
        "actionComplete": true,
        "type": "SIMPLE_ACTION_COMPLETE"
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (35, 10)" },
      "comment": "TURN 5: Use dashed movement to close distance again",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn 5"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Hobgoblin's turn",
      "timeout": 5000
    },
    {
      "type": "action",
      "input": { "text": "I attack the Hobgoblin Captain with my warhammer" },
      "comment": "TURN 6: Final attack to finish the fight",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "15 + 6 = 21 vs AC 17 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 8" },
      "comment": "8 + 3 = 11 damage. Hobgoblin: 20 - 11 = 9 HP",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Combat continues - Hobgoblin should have 9 HP remaining",
      "expect": {
        "combatStatus": "Active"
      }
    }
  ]
}
