{
  "name": "Monk Deflect Attacks: Ki Redirect on Full Deflection",
  "description": "A level 5 Monk with Deflect Attacks fully deflects incoming damage (reduced to 0), then auto-spends 1 ki to redirect: ranged Unarmed Strike (DEX + prof vs AC), dealing 2× Martial Arts die + DEX mod Force damage. Monster damage is kept very low (1d4+1, max 5) to guarantee full deflection (min reduction 1+3+5=9). Monster AC is low (5) to guarantee the redirect hits.",
  "setup": {
    "character": {
      "name": "Ren the Swift",
      "className": "Monk",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 16,
          "charisma": 8
        },
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 5,
        "speed": 45,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Unarmed Strike",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Weak Skeleton",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 6,
            "wisdom": 8,
            "charisma": 5
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 5,
          "speed": 30,
          "challengeRating": 0.125,
          "experienceValue": 25,
          "attacks": [
            {
              "name": "Feeble Scratch",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 1 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "attack"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare to defend" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High initiative to ensure Monk goes first",
      "expect": { "combatStarted": true }
    },
    {
      "comment": "End turn without acting — monster will attack on its turn",
      "type": "endTurn"
    },
    {
      "comment": "Wait for monster to attack and trigger Deflect Attacks reaction prompt",
      "type": "waitForReaction",
      "input": { "reactionType": "deflect_attacks" },
      "timeout": 10000
    },
    {
      "comment": "Use Deflect Attacks reaction — damage will be fully deflected (max 5 < min reduction 9), triggering ki redirect",
      "type": "reactionRespond",
      "input": { "choice": "use" }
    },
    {
      "comment": "Wait for monster turn to finish and control to return to player",
      "type": "waitForTurn",
      "timeout": 10000
    },
    {
      "comment": "Monk took zero damage — full deflection guaranteed (max dmg 5 < min reduction 9)",
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 38, "max": 38 }
      }
    },
    {
      "comment": "Monster should have taken redirect damage. d20+6 vs AC 5 always hits (min roll 7). Damage: 2d8+3 = min 5, max 19. So monster HP should be 31-45.",
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Weak Skeleton", "min": 31, "max": 45 }
      }
    },
    {
      "comment": "1 ki was spent on the redirect (from 5 max to 4 current)",
      "type": "assertState",
      "expect": {
        "characterResource": { "poolName": "ki", "current": 4 }
      }
    }
  ]
}
