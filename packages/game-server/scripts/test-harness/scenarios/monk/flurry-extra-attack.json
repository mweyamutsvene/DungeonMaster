{
  "name": "Monk Flurry + Extra Attack: Full 4-Attack Chain",
  "description": "A level 5 Monk uses the Attack action (2 attacks via Extra Attack), then Flurry of Blows as bonus action (2 more strikes). D&D 5e 2024: Extra Attack gives 2 attacks per Attack action, Flurry gives 2 unarmed strikes. Total should be 4 attacks. Also verifies ki is spent for Flurry (ki 5 → 4).",
  "setup": {
    "character": {
      "name": "Li Wei",
      "className": "Monk",
      "level": 5,
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 11,
          "wisdom": 16,
          "charisma": 8
        },
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 16,
        "speed": 45,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Unarmed Strike",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      },
      "position": { "x": 35, "y": 10 }
    },
    "monsters": [
      {
        "name": "Training Dummy Golem",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 8,
            "constitution": 16,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 12,
          "speed": 0,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Slam",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the golem" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first (18 + 3 DEX = 21)",
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy Golem" },
      "comment": "Extra Attack 1 of 2. Should request attack roll.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "14" },
      "comment": "14 + 6 = 20 vs AC 12 - hit!",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 3 = 8 damage. Attack 1 done, Action NOT spent yet (Extra Attack allows 2).",
      "expect": { "actionComplete": true }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy Golem" },
      "comment": "Extra Attack 2 of 2. Should still succeed — action not fully used.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "comment": "12 + 6 = 18 vs AC 12 - hit!",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 3 = 9 damage. Both Extra Attacks complete. Action fully spent.",
      "expect": { "actionComplete": true }
    },
    {
      "type": "action",
      "input": { "text": "flurry of blows" },
      "comment": "Bonus Action: Flurry of Blows — costs 1 ki, grants 2 unarmed strikes",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "14" },
      "comment": "Flurry strike 1: 14 + 6 = 20 vs AC 12 - hit!",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 3 = 9 damage. Second Flurry strike should auto-trigger.",
      "expect": { "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "10" },
      "comment": "Flurry strike 2: 10 + 6 = 16 vs AC 12 - hit!",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "4" },
      "comment": "4 + 3 = 7 damage. All 4 attacks resolved (2 Extra Attack + 2 Flurry)!",
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Ki should be 4/5 (spent 1 for Flurry of Blows)",
      "expect": {
        "characterResource": { "poolName": "ki", "current": 4 }
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn — used Action (2x Extra Attack) + Bonus Action (Flurry of Blows)"
    }
  ]
}
