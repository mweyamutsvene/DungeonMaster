{
  "name": "Monk Stunning Strike: Condition Expires at Start of Monk's Next Turn",
  "description": "TDD scenario for permanent stun bug. Monk stuns a monster (CON save fails), monster's turn is skipped (stunned), then at start of monk's next turn the Stunned condition should expire. After a second endTurn, the monster should no longer be stunned and can act.",
  "setup": {
    "character": {
      "name": "Ren Thunderfist",
      "className": "Monk",
      "level": 5,
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 11,
          "wisdom": 16,
          "charisma": 8
        },
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 16,
        "speed": 45,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Unarmed Strike",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      },
      "position": { "x": 10, "y": 10 }
    },
    "monsters": [
      {
        "name": "Weak Golem",
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 8,
            "constitution": 1,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 80,
          "hp": 80,
          "armorClass": 12,
          "speed": 20,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Slam",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "bludgeoning"
            }
          ],
          "saveProficiencies": [],
          "proficiencyBonus": 2,
          "position": { "x": 15, "y": 10 }
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the Weak Golem" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true },
      "comment": "Start combat"
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true, "rollType": "initiative" },
      "comment": "Initiative: 18 + 3 (DEX) = 21. Monk goes first (golem has -1 DEX)."
    },
    {
      "type": "action",
      "input": { "text": "attack Weak Golem" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true },
      "comment": "Normal melee attack — no stunning strike keyword"
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "expect": {
        "hit": true,
        "rollType": "damage",
        "requiresPlayerInput": true,
        "eligibleEnhancements": [{ "keyword": "stunning-strike" }]
      },
      "comment": "15 + 6 = 21 vs AC 12 → hit. Eligible for stunning strike."
    },
    {
      "type": "rollResult",
      "input": { "text": "5 with stunning strike" },
      "expect": {
        "actionComplete": true,
        "stunningStrike": {}
      },
      "comment": "5 + 3 = 8 damage. CON save DC 14, Golem has CON 1 (-5 mod). d20(18)-5=13 < DC 14 → fails → Stunned. EA chain auto-completed."
    },
    {
      "type": "assertState",
      "expect": {
        "monsterConditions": { "name": "Weak Golem", "hasConditions": ["Stunned"] }
      },
      "comment": "CRITICAL: Verify Stunned was actually applied (save failed). If this fails, the CON save succeeded — adjust scenario."
    },
    {
      "type": "endTurn",
      "comment": "End monk's turn. Monster is stunned → AI should skip its turn → back to monk."
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for monk's turn again. Monster was stunned so AI skips."
    },
    {
      "type": "assertState",
      "expect": {
        "monsterConditions": { "name": "Weak Golem", "doesNotHaveConditions": ["Stunned"] }
      },
      "comment": "BUG REPRODUCTION: Stunned should expire at start of monk's next turn. If this fails, the permanent stun bug is confirmed."
    }
  ]
}
