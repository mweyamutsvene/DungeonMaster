{
  "name": "Monk Wholeness of Body: Self-Healing Bonus Action",
  "description": "A level 6 Monk (Open Hand) takes damage, then uses Wholeness of Body as a bonus action to heal. Tests resource pool spending (wholeness_of_body, not ki) and HP restoration via bonus action.",
  "setup": {
    "character": {
      "name": "Li Wei",
      "className": "Monk",
      "level": 6,
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 11,
          "wisdom": 16,
          "charisma": 8
        },
        "subclass": "Open Hand",
        "maxHp": 45,
        "currentHp": 45,
        "armorClass": 16,
        "speed": 50,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Unarmed Strike",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy Golem",
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 8,
            "constitution": 16,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 12,
          "speed": 20,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Slam",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the golem" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first (18 + 3 DEX = 21)",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (35, 10)" },
      "comment": "Move 25ft to get within melee range of dummy at (40,10)",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Training Dummy Golem with an unarmed strike" },
      "comment": "Main action: Unarmed Strike",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 12" },
      "comment": "12 + 6 = 18 vs AC 12 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 5" },
      "comment": "5 + 3 (DEX) = 8 bludgeoning damage. Golem: 50 - 8 = 42 HP",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "use wholeness of body" },
      "comment": "Bonus Action: Wholeness of Body - heal Martial Arts die + WIS mod. No ki cost, uses wholeness_of_body pool. Since we're at full HP, healing may be partial, but the ability should complete.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn - used Action (attack) + Bonus Action (Wholeness of Body)"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Training Dummy's turn",
      "timeout": 5000
    },
    {
      "type": "assertState",
      "comment": "Verify combat continues",
      "expect": {
        "combatStatus": "Active"
      }
    }
  ]
}
