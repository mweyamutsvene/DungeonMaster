{
  "name": "Monk Step of the Wind: Dash as Bonus Action",
  "description": "A level 5 Monk attacks, then uses Step of the Wind with Dash choice (bonus action), spending 1 ki point. Tests the dash variant routing and immediate-completion bonus action flow.",
  "setup": {
    "character": {
      "name": "Li Wei",
      "className": "Monk",
      "level": 5,
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 11,
          "wisdom": 16,
          "charisma": 8
        },
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 16,
        "speed": 45,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Unarmed Strike",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy Golem",
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 8,
            "constitution": 16,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 12,
          "speed": 20,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Slam",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the golem" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first (18 + 3 DEX = 21)",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (35, 10)" },
      "comment": "Move 25ft to get within melee range of dummy at (40,10)",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Training Dummy Golem with an unarmed strike" },
      "comment": "Main action: Unarmed Strike",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 12" },
      "comment": "12 + 6 = 18 vs AC 12 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 5" },
      "comment": "5 + 3 (DEX) = 8 bludgeoning damage. Golem: 50 - 8 = 42 HP",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "use step of the wind dash" },
      "comment": "Bonus Action: Step of the Wind (Dash) - Dash as bonus, costs 1 ki, doubles jump distance.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn - used Action (attack) + Bonus Action (Step of the Wind Dash)"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Training Dummy's turn",
      "timeout": 5000
    },
    {
      "type": "assertState",
      "comment": "Verify combat continues",
      "expect": {
        "combatStatus": "Active"
      }
    }
  ]
}
