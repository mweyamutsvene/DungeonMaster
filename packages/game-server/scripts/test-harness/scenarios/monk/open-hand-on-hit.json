{
  "name": "Monk Open Hand Technique: Per-Hit Choice on Flurry (2024 Rules)",
  "description": "A level 5 Open Hand Monk uses Flurry of Blows. Each hit independently offers eligibleEnhancements including OHT choices. Player picks different techniques per strike via damage text keywords (topple on strike 1, addle on strike 2).",
  "setup": {
    "character": {
      "name": "Kai Openhand",
      "className": "Monk",
      "level": 5,
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 11,
          "wisdom": 16,
          "charisma": 8
        },
        "subclass": "Open Hand",
        "maxHp": 38,
        "currentHp": 38,
        "armorClass": 16,
        "speed": 45,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Unarmed Strike",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      },
      "position": { "x": 10, "y": 10 }
    },
    "monsters": [
      {
        "name": "Training Dummy Golem",
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 8,
            "constitution": 16,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 12,
          "speed": 20,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Slam",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "bludgeoning"
            }
          ],
          "position": { "x": 15, "y": 10 }
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the golem" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true },
      "comment": "Initiative: 18 + 3 (DEX) = 21. Player goes first."
    },
    {
      "type": "action",
      "input": { "text": "I attack the Training Dummy Golem with an unarmed strike" },
      "comment": "Main action: normal unarmed strike",
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "14" },
      "comment": "14 + 6 = 20 vs AC 12 → Hit",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 3 = 9 bludgeoning. Golem HP: 50 → 41",
      "expect": { "actionComplete": true }
    },
    {
      "type": "action",
      "input": { "text": "use flurry of blows" },
      "comment": "Bonus Action: Flurry of Blows — NO technique keyword declared upfront",
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "14" },
      "comment": "Flurry strike 1: 14 + 6 = 20 vs AC 12 → Hit. Server offers OHT + stunning strike.",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true,
        "eligibleEnhancements": [
          { "keyword": "open-hand-technique" },
          { "keyword": "stunning-strike" }
        ]
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6 with topple" },
      "comment": "Strike 1 damage: 6+3=9. Golem HP: 41→32. OHT Topple via damage text keyword.",
      "expect": {
        "requiresPlayerInput": true,
        "openHandTechnique": {}
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "10" },
      "comment": "Flurry strike 2: 10 + 6 = 16 vs AC 12 → Hit. Server offers OHT again (per-hit).",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true,
        "eligibleEnhancements": [
          { "keyword": "open-hand-technique" },
          { "keyword": "stunning-strike" }
        ]
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "4 with addle" },
      "comment": "Strike 2 damage: 4+3=7. Golem HP: 32→25. OHT Addle — different choice on strike 2.",
      "expect": {
        "actionComplete": true,
        "openHandTechnique": {}
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn — used Action (attack) + Bonus Action (Flurry of Blows w/ per-hit OHT)"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Training Dummy's turn",
      "timeout": 5000
    },
    {
      "type": "assertState",
      "comment": "Verify combat continues",
      "expect": { "combatStatus": "Active" }
    }
  ]
}
