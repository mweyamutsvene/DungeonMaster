{
  "name": "B3: Dash Provides Extra Movement",
  "description": "A Fighter uses Dash to gain extra movement, then moves further than their normal speed. Tests: (1) move 25ft, (2) Dash (adds 30ft to budget → 35ft remaining), (3) move another 30ft. Total movement = 55ft with 30ft speed + Dash. Without Dash, the second move would fail.",
  "setup": {
    "character": {
      "name": "Speedy Sam",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16, "dexterity": 14, "constitution": 14,
          "intelligence": 10, "wisdom": 10, "charisma": 10
        },
        "maxHp": 28, "currentHp": 28, "armorClass": 18, "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword", "kind": "melee", "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Target Dummy",
        "position": { "x": 60, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10, "dexterity": 10, "constitution": 10,
            "intelligence": 10, "wisdom": 10, "charisma": 10
          },
          "maxHp": 100, "hp": 100, "armorClass": 10, "speed": 0,
          "challengeRating": 0, "experienceValue": 0,
          "attacks": [
            {
              "name": "Slam", "kind": "melee", "attackBonus": 0,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for a sprint" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "--- Step 1: Move 25ft (uses 25 of 30ft movement) ---",
      "type": "action",
      "input": { "text": "move to (15, 10)" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Verify position after first move",
      "type": "assertState",
      "expect": { "characterPosition": { "x": 15, "y": 10 } }
    },
    {
      "comment": "--- Step 2: Dash (adds 30ft → total budget becomes 5 remaining + 30 = 35ft remaining) ---",
      "type": "action",
      "input": { "text": "dash" },
      "expect": { "actionComplete": true, "type": "SIMPLE_ACTION_COMPLETE" }
    },
    {
      "comment": "--- Step 3: Move 30ft more (within the 35ft remaining from Dash) ---",
      "type": "action",
      "input": { "text": "move to (21, 10)" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Verify final position — proves Dash allowed the extra movement",
      "type": "assertState",
      "expect": { "characterPosition": { "x": 21, "y": 10 } }
    }
  ]
}
