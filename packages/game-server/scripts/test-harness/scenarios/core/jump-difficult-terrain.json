{
  "name": "Jump into Difficult Terrain: Acrobatics Check → Prone",
  "description": "Tests that landing a jump in difficult terrain triggers a DC 10 DEX (Acrobatics) check. With DEX 2 (modifier -4), the seeded dice roll gives total 9 < 10 → fails → Prone condition applied. Character position still updates to landing spot.",
  "setup": {
    "character": {
      "name": "Clumsy Jumper",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 0, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 2,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 50, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 1,
            "wisdom": 1,
            "charisma": 1
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 10,
          "speed": 0,
          "attacks": []
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the dummy" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "Player initiative 20, monster initiative = seeded d20(13) + 0 = 13. Player goes first.",
      "expect": { "combatStarted": true }
    },
    {
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 25, "y": 10, "terrain": "difficult" }
        ]
      },
      "comment": "Place difficult terrain at (25, 10) — the landing position for a 16ft long jump from (10, 10)"
    },
    {
      "type": "action",
      "comment": "Move 10ft to get a running start",
      "input": { "text": "move to (10, 10)" },
      "expect": {
        "type": "MOVE_COMPLETE",
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "comment": "Long jump with running start — 16ft, lands at (25, 10) which is difficult terrain. Acrobatics check: seeded d20=13 + DEX(-4) = 9 < DC 10 → FAIL → Prone.",
      "input": { "text": "long jump" },
      "expect": {
        "type": "JUMP_COMPLETE",
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify character landed at (25, 10) and has Prone condition from failed Acrobatics check",
      "expect": {
        "characterPosition": { "x": 25, "y": 10 },
        "characterConditions": { "hasConditions": ["Prone"] }
      }
    },
    {
      "type": "endTurn"
    }
  ]
}
