{
  "name": "Hide: Lone Blinded Observer Still Allows Stealth",
  "description": "Regression test for hide vs blindness. A rogue attempts to Hide in the open against a single blinded enemy. By rule, the blinded enemy cannot see the rogue, so the hide attempt should be legal and then resolved by Stealth vs passive Perception. With Stealth +10 vs passive Perception 9, Hidden should be applied.",
  "setup": {
    "character": {
      "name": "Shade",
      "className": "Rogue",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 18,
          "constitution": 14,
          "intelligence": 12,
          "wisdom": 12,
          "charisma": 12
        },
        "maxHp": 34,
        "currentHp": 34,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 3,
        "skills": {
          "stealth": 10
        },
        "attacks": [
          {
            "name": "Shortbow",
            "kind": "ranged",
            "range": "80/320",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "piercing"
          }
        ],
        "features": [
          { "name": "Cunning Action", "description": "Dash, Disengage, or Hide as a bonus action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Blind Guard",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 12,
            "dexterity": 12,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 35,
          "hp": 35,
          "armorClass": 14,
          "speed": 30,
          "passivePerception": 9,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Spear",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I size up the blinded guard" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative so the rogue acts first.",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "applyCondition",
      "comment": "The only observer is Blinded before the hide attempt.",
      "input": {
        "target": "monster:Blind Guard",
        "condition": "Blinded",
        "duration": "1 minute",
        "source": "blind-hide-regression"
      }
    },
    {
      "type": "assertState",
      "comment": "Checkpoint: the guard is definitely Blinded.",
      "expect": {
        "monsterConditions": {
          "name": "Blind Guard",
          "hasConditions": ["Blinded"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "hide" },
      "comment": "No map cover is present. Hide should still be legal because the lone observer is Blinded, and Stealth +10 should beat passive Perception 9.",
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Hide"
      }
    },
    {
      "type": "assertState",
      "comment": "Rules expectation: lone blinded observer cannot keep the rogue clearly visible, so Hidden should be applied.",
      "expect": {
        "characterConditions": {
          "hasConditions": ["Hidden"]
        }
      }
    }
  ]
}