{
  "name": "Bane: Debuff on Enemies",
  "description": "A Cleric casts Bane targeting enemies, applying -1d4 on attack rolls and saving throws. Then attacks to verify combat continues. Tests debuff spell targeting enemies via ActiveEffect system.",
  "setup": {
    "character": {
      "name": "Father Aldric",
      "className": "Cleric",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 14, "dexterity": 10, "constitution": 14,
          "intelligence": 10, "wisdom": 18, "charisma": 12
        },
        "maxHp": 24, "currentHp": 24, "armorClass": 16, "speed": 30,
        "proficiencyBonus": 2,
        "spellcastingAbility": "wisdom",
        "spellSaveDC": 14,
        "spellAttackBonus": 6,
        "spellSlots": { "1": 4 },
        "preparedSpells": [
          {
            "name": "Bane",
            "level": 1,
            "concentration": true,
            "effects": [
              {
                "type": "penalty",
                "target": "attack_rolls",
                "diceValue": { "count": 1, "sides": 4 },
                "duration": "concentration",
                "appliesTo": "enemies"
              },
              {
                "type": "penalty",
                "target": "saving_throws",
                "diceValue": { "count": 1, "sides": 4 },
                "duration": "concentration",
                "appliesTo": "enemies"
              }
            ]
          }
        ],
        "attacks": [
          {
            "name": "Mace", "kind": "melee", "range": "melee",
            "attackBonus": 4,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 10,
            "intelligence": 10, "wisdom": 8, "charisma": 8
          },
          "maxHp": 21, "hp": 21, "armorClass": 15, "speed": 30,
          "challengeRating": 0.25, "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar", "kind": "melee", "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I curse the enemies" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "16" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Cast Bane targeting enemies — applies -1d4 on attack rolls and saving throws",
      "type": "action",
      "input": { "text": "cast Bane" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    },
    {
      "type": "endTurn"
    },
    { "type": "waitForTurn" },
    {
      "comment": "Combat continues after Bane applied",
      "type": "assertState",
      "expect": { "combatStatus": "Active" }
    },
    {
      "comment": "Attack to verify combat flow continues with debuffs active on enemies",
      "type": "action",
      "input": { "text": "I attack the Goblin with my mace" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" }
    }
  ]
}
