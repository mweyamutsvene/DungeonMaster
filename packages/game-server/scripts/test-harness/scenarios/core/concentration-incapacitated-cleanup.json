{
  "name": "Concentration cleanup on Incapacitated caster (Hold Person)",
  "description": "Wizard casts Hold Person on a humanoid target, then receives Incapacitated via DM override. 2024 behavior: concentration ends and linked Hold Person ActiveEffect source is removed from the target immediately.",
  "setup": {
    "character": {
      "name": "Elara",
      "className": "Wizard",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 10,
          "intelligence": 18, "wisdom": 12, "charisma": 10
        },
        "maxHp": 12, "currentHp": 12, "armorClass": 12, "speed": 30,
        "proficiencyBonus": 2,
        "saveProficiencies": [],
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 14,
        "spellAttackBonus": 6,
        "spellSlots": { "1": 4, "2": 2 },
        "preparedSpells": [
          { "name": "Hold Person", "level": 2 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff", "kind": "melee", "range": "melee",
            "attackBonus": 0,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Bandit Enforcer",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "type": "humanoid",
          "abilityScores": {
            "strength": 19, "dexterity": 8, "constitution": 16,
            "intelligence": 10, "wisdom": 10, "charisma": 10
          },
          "maxHp": 200, "hp": 200, "armorClass": 11, "speed": 30,
          "challengeRating": 2, "experienceValue": 450,
          "attacks": [
            {
              "name": "Greatclub", "kind": "melee", "attackBonus": 8,
              "damage": { "diceCount": 2, "diceSides": 8, "modifier": 4 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "comment": "Start combat.",
      "input": { "text": "I prepare for battle" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "comment": "Elara goes first.",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "comment": "Establish concentration and linked effect on target.",
      "input": { "text": "cast Hold Person on Bandit Enforcer" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    },
    {
      "type": "assertState",
      "comment": "Baseline: concentration and Hold Person source present before Incapacitated is applied.",
      "expect": {
        "characterConcentration": "Hold Person",
        "monsterConcentration": { "name": "Bandit Enforcer", "spell": null },
        "monsterActiveEffects": {
          "name": "Bandit Enforcer",
          "hasSources": ["Hold Person"]
        },
        "characterHp": { "min": 12, "max": 12 }
      }
    },
    {
      "type": "applyCondition",
      "comment": "Apply Incapacitated to caster. Expected behavior: concentration ends and linked effect source is removed.",
      "input": {
        "target": "character",
        "condition": "Incapacitated",
        "duration": "until_removed"
      }
    },
    {
      "type": "assertState",
      "comment": "After Incapacitated is applied to the caster, concentration is cleared and linked Hold Person source is removed.",
      "expect": {
        "characterConcentration": null,
        "monsterConcentration": { "name": "Bandit Enforcer", "spell": null },
        "monsterActiveEffects": {
          "name": "Bandit Enforcer",
          "doesNotHaveSources": ["Hold Person"]
        },
        "characterHp": { "min": 12, "max": 12 }
      }
    }
  ]
}
