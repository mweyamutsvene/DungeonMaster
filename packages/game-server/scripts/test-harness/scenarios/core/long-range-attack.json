    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "throw handaxe at Goblin Archer" },
      "comment": "Goblin Archer is 35ft away (normal range 20ft, long range 60ft). Pre-fix: returns 400 error. Post-fix: returns attack roll request with disadvantage for long-range throw.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true,
        "disadvantage": true
