    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 5 = 20 vs AC 13 → hit (rolling with disadvantage but still hits)",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 3 = 8 damage vs 7 HP → Goblin Archer dies",
      "expect": {
        "actionComplete": true,
        "combatEnded": true,
        "victoryStatus": "Victory"
