{
  "name": "Conditions 2024: clear timing for one-round injected conditions",
  "description": "Regression for DM-injected condition duration alias handling. A condition applied with duration 'round' should persist through intervening turns and clear at the affected combatant's next turn boundary.",
  "setup": {
    "character": {
      "name": "Timing Probe",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Passive Dummy",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 8,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 12,
          "speed": 30,
          "challengeRating": 1,
          "attacks": [
            {
              "name": "Club",
              "kind": "melee",
              "attackBonus": 2,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "comment": "Start combat for deterministic round-boundary timing checks.",
      "input": { "text": "I begin a timing test." },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "comment": "High initiative keeps deterministic player-first cadence.",
      "input": { "text": "19" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "applyCondition",
      "comment": "Apply Deafened for one round. Expected to expire by next player turn.",
      "input": {
        "target": "character",
        "condition": "Deafened",
        "duration": "round"
      }
    },
    {
      "type": "assertState",
      "comment": "Sanity: condition applies immediately.",
      "expect": {
        "combatStatus": "Active",
        "characterConditions": {
          "hasConditions": ["Deafened"]
        }
      }
    },
    {
      "type": "endTurn",
      "comment": "Advance through monster turn to complete one full round."
    },
    {
      "type": "waitForTurn",
      "comment": "Return to player turn for expiry assertion."
    },
    {
      "type": "assertState",
      "comment": "Deafened clears at the affected combatant's next turn boundary.",
      "expect": {
        "combatStatus": "Active",
        "characterConditions": {
          "doesNotHaveConditions": ["Deafened"]
        }
      }
    }
  ]
}
