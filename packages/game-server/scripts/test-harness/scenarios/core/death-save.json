{
  "name": "Death Saves: Basic stabilization",
  "description": "Validates the death save flow: character drops to 0 HP, makes death saving throws each turn (DC 10), accumulates successes/failures, and stabilizes at 3 successes. Tests: success, failure, and stabilization outcomes.",
  "setup": {
    "character": {
      "name": "Brave Adventurer",
      "className": "Fighter",
      "level": 1,
      "position": { "x": 0, "y": 0 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 10,
          "constitution": 10,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 1,
        "currentHp": 1,
        "armorClass": 10,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Dagger",
            "kind": "melee",
            "attackBonus": 2,
            "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
            "damageType": "piercing"
          }
        ],
        "features": [],
        "resourcePools": []
      }
    },
    "monsters": [
      {
        "name": "Deadly Foe",
        "position": { "x": 5, "y": 0 },
        "statBlock": {
          "abilityScores": {
            "strength": 20,
            "dexterity": 20,
            "constitution": 20,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 10
          },
          "hp": 100,
          "maxHp": 100,
          "armorClass": 18,
          "speed": 30,
          "position": { "x": 5, "y": 0 },
          "attacks": [
            {
              "name": "Greatsword",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 15,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 5 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I engage the Deadly Foe" },
      "comment": "Start combat — character rolls low initiative",
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 2" },
      "comment": "Character init = 2 (dex mod 0). Monster init = 15 (10+5 dex mod). Monster goes first.",
      "expect": { "combatStarted": true }
    },

    {
      "type": "waitForTurn",
      "comment": "Monster attacks first (higher init), KOs the character to 0 HP. AI orchestrator detects the dying character and sets DEATH_SAVE pending action."
    },

    {
      "type": "rollResult",
      "input": { "text": "I rolled 12" },
      "comment": "Death save #1: 12 >= DC 10 = success",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "success",
        "deathSaves": { "successes": 1, "failures": 0 },
        "actionComplete": true
      }
    },

    {
      "type": "waitForTurn",
      "comment": "Turn cycles: monster has no living enemies → endTurn → character's turn → DEATH_SAVE set again"
    },

    {
      "type": "rollResult",
      "input": { "text": "I rolled 5" },
      "comment": "Death save #2: 5 < DC 10 = failure",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "failure",
        "deathSaves": { "successes": 1, "failures": 1 },
        "actionComplete": true
      }
    },

    {
      "type": "waitForTurn",
      "comment": "Turn cycles again: monster endTurn → character's turn → DEATH_SAVE"
    },

    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "Death save #3: 15 >= DC 10 = success (2 total)",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "success",
        "deathSaves": { "successes": 2, "failures": 1 },
        "actionComplete": true
      }
    },

    {
      "type": "waitForTurn",
      "comment": "Turn cycles: monster endTurn → character's turn → DEATH_SAVE"
    },

    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "Death save #4: 18 >= DC 10 = 3rd success → STABILIZED!",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "stabilized",
        "deathSaves": { "successes": 3, "failures": 1 },
        "actionComplete": true
      }
    }
  ]
}
