{
  "name": "Pre-placed ground items: pickup and use",
  "description": "A Javelin is pre-placed on the battlefield. The Fighter moves to it, picks it up, and throws it at a monster.",
  "setup": {
    "character": {
      "name": "Tormund Ironhelm",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 12,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "versatileDamage": { "diceSides": 10 },
            "damageType": "slashing",
            "properties": ["Versatile"]
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Orc Warrior",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 16,
            "dexterity": 12,
            "constitution": 16,
            "intelligence": 7,
            "wisdom": 11,
            "charisma": 10
          },
          "maxHp": 60,
          "hp": 60,
          "armorClass": 13,
          "speed": 30,
          "attacks": [
            {
              "name": "Greataxe",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 12, "modifier": 3 }
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    },
    "groundItems": [
      {
        "name": "Javelin",
        "position": { "x": 15, "y": 10 },
        "weaponStats": {
          "name": "Javelin",
          "kind": "melee",
          "range": "melee",
          "attackBonus": 6,
          "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
          "damageType": "piercing",
          "properties": ["Thrown (Range 30/120)"]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for combat" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first",
      "expect": { "combatStarted": true }
    },

    {
      "type": "assertState",
      "comment": "Javelin should be pre-placed on the map.",
      "expect": {
        "groundItemCount": 1,
        "groundItemExists": { "name": "Javelin", "nearPosition": { "x": 15, "y": 10 } }
      }
    },

    {
      "type": "action",
      "input": { "text": "move to (15,10)" },
      "comment": "Move to the Javelin location",
      "expect": { "actionComplete": true }
    },
    {
      "type": "action",
      "input": { "text": "pick up javelin" },
      "comment": "Pick up the pre-placed Javelin",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Javelin picked up — no longer on the ground",
      "expect": {
        "groundItemCount": 0
      }
    },

    {
      "type": "action",
      "input": { "text": "throw javelin at Orc Warrior" },
      "comment": "Throw the picked-up Javelin at the Orc (25ft away — within 30ft normal range)",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "comment": "12 + 6 = 18 vs AC 13 → hit",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "4" },
      "comment": "4 + 3 = 7 damage (1d6+3 piercing)",
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Orc took 7 damage: 60 - 7 = 53 HP. Javelin lands on the ground at Orc's position.",
      "expect": {
        "monsterHp": { "name": "Orc Warrior", "min": 53, "max": 53 },
        "groundItemCount": 1,
        "groundItemExists": { "name": "Javelin", "nearPosition": { "x": 40, "y": 10 } }
      }
    }
  ]
}
