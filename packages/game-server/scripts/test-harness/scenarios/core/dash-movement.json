{
  "name": "Dash: Doubled movement budget",
  "description": "A Fighter uses the Dash action to double their movement speed, then moves 55ft (exceeding normal 30ft speed). Verifies that Dash correctly doubles movement budget to 60ft. Also tests that movement beyond the doubled budget is rejected.",
  "setup": {
    "character": {
      "name": "Swift Runner",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 14, "dexterity": 14, "constitution": 14,
          "intelligence": 10, "wisdom": 10, "charisma": 10
        },
        "maxHp": 28, "currentHp": 28, "armorClass": 16, "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword", "kind": "melee", "range": "melee",
            "attackBonus": 4,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 2 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Far Away Goblin",
        "position": { "x": 75, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 10,
            "intelligence": 10, "wisdom": 8, "charisma": 8
          },
          "maxHp": 50, "hp": 50, "armorClass": 15, "speed": 30,
          "challengeRating": 0.25,
          "attacks": [
            {
              "name": "Shortbow", "kind": "ranged", "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I charge forward" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High init to go first",
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "input": { "text": "dash" },
      "comment": "Dash action doubles movement to 60ft",
      "expect": {
        "actionComplete": true,
        "type": "SIMPLE_ACTION_COMPLETE"
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (65, 10)" },
      "comment": "Move 55ft (from x=10 to x=65). This exceeds normal 30ft but is within dashed 60ft budget.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "expect": {
        "characterPosition": { "x": 65, "y": 10 }
      },
      "comment": "Character moved 55ft to (65,10) — within doubled budget of 60ft"
    }
  ]
}
