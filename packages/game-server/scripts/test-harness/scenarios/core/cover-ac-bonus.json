{
  "name": "Cover: Half cover AC bonus",
  "description": "A goblin behind half cover gets +2 AC. Attacker rolls high enough to beat base AC but not the cover-boosted AC, resulting in a miss. Extra Attack auto-chains and also misses.",
  "setup": {
    "character": {
      "name": "Archer",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 5, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longbow",
            "kind": "ranged",
            "range": "150/600",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "piercing"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Sentry",
        "position": { "x": 20, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 7,
          "hp": 7,
          "armorClass": 15,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 }
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I shoot the goblin" },
      "expect": {
        "rollType": "initiative"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 15, "y": 10, "terrain": "cover-half" }
        ]
      },
      "comment": "Place half cover between archer and goblin (after combat starts)"
    },
    {
      "type": "action",
      "input": { "text": "shoot Goblin Sentry with longbow" },
      "comment": "Ranged attack against goblin behind half cover",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "9" },
      "comment": "9 + 7 = 16 vs AC 15 + 2 (half cover) = 17 → miss! Without cover this would hit. Extra Attack auto-chains and auto-completes (nat-1 miss).",
      "expect": {
        "hit": false
      }
    }
  ]
}
