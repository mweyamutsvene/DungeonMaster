{
  "name": "AI Melee Range Guard: Monster moves toward but can't reach",
  "description": "A melee monster with 5ft reach starts 40ft from the player. After moving 30ft (its full speed), it is still 10ft away and cannot attack. Verifies the monster moves toward the player and ends turn without dealing damage when out of melee reach. Reproduces BUG-H5/I1 from agent test plays.",
  "setup": {
    "character": {
      "name": "Thorin Ironfist",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 0, "y": 0 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 40, "y": 0 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 7,
          "hp": 7,
          "armorClass": 13,
          "speed": 30,
          "challengeRating": 0.25,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the goblin" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "comment": "High initiative so player goes first.",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "queueMonsterActions",
      "comment": "Script the goblin's turn: move toward player (from 40ft, speed 30 → lands at ~10ft = out of 5ft reach), then end turn. This is what the FIXED DeterministicAiDecisionMaker would produce for BUG-H5.",
      "input": {
        "decisions": [
          {
            "action": "moveToward",
            "target": "Thorin Ironfist",
            "desiredRange": 5,
            "endTurn": false
          },
          {
            "action": "endTurn"
          }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "Player ends turn without acting (40ft away, can't reach with melee). Monster executes queued decisions."
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for the goblin to execute queued actions (moveToward then endTurn) and player turn to come back."
    },
    {
      "type": "assertState",
      "comment": "Player should be at full HP since the goblin moved 30ft but ended 10ft away (out of 5ft melee reach) and ended turn without attacking.",
      "expect": {
        "characterHp": { "min": 42, "max": 42 },
        "monstersAlive": 1
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (5, 0)" },
      "comment": "Move toward the goblin (which is now at ~10,0 after moving 30ft toward the player).",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Goblin Scout" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "expect": {
        "hit": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 8" },
      "comment": "1d8+3 = 11 damage, overkills the 7HP goblin.",
      "expect": {
        "combatEnded": true,
        "victoryStatus": "Victory"
      }
    }
  ]
}
