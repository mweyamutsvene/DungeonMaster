{
  "name": "Heroism: Recurring Temp HP + Condition Immunity",
  "description": "A Cleric casts Heroism on self, granting recurring temp HP at start of each turn and immunity to Frightened. Tests recurring_temp_hp and condition_immunity ActiveEffect types with concentration.",
  "setup": {
    "character": {
      "name": "Paladin Kira",
      "className": "Cleric",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 14, "dexterity": 10, "constitution": 14,
          "intelligence": 10, "wisdom": 18, "charisma": 12
        },
        "maxHp": 24, "currentHp": 24, "armorClass": 16, "speed": 30,
        "proficiencyBonus": 2,
        "spellcastingAbility": "wisdom",
        "spellSaveDC": 14,
        "spellAttackBonus": 6,
        "spellSlots": { "1": 4 },
        "preparedSpells": [
          {
            "name": "Heroism",
            "level": 1,
            "effects": [
              {
                "type": "recurring_temp_hp",
                "target": "hit_points",
                "value": 4,
                "duration": "concentration",
                "triggerAt": "start_of_turn",
                "appliesTo": "self"
              },
              {
                "type": "condition_immunity",
                "target": "conditions",
                "conditionName": "Frightened",
                "duration": "concentration",
                "appliesTo": "self"
              }
            ]
          }
        ],
        "attacks": [
          {
            "name": "Mace", "kind": "melee", "range": "melee",
            "attackBonus": 4,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Skeleton",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10, "dexterity": 14, "constitution": 15,
            "intelligence": 6, "wisdom": 8, "charisma": 5
          },
          "maxHp": 30, "hp": 30, "armorClass": 13, "speed": 30,
          "challengeRating": 0.25, "experienceValue": 50,
          "attacks": [
            {
              "name": "Shortsword", "kind": "melee", "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I channel divine courage" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "16" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Cast Heroism on self — grants recurring temp HP + Frightened immunity",
      "type": "action",
      "input": { "text": "cast Heroism" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    },
    {
      "comment": "End turn, monster attacks",
      "type": "endTurn"
    },
    { "type": "waitForTurn" },
    {
      "comment": "Turn started — recurring temp HP should have been applied at start of turn",
      "type": "assertState",
      "expect": { "combatStatus": "Active" }
    },
    {
      "comment": "Attack to continue combat",
      "type": "action",
      "input": { "text": "I attack the Skeleton with my mace" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" }
    }
  ]
}
