{
  "name": "Move Toward: Difficult Terrain",
  "description": "Character uses 'move toward Goblin' with difficult terrain between them. A* pathfinding should account for double movement cost through difficult terrain cells, resulting in a partial move.",
  "setup": {
    "character": {
      "name": "Brave Fighter",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 15,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare to fight the goblin" },
      "expect": {
        "rollType": "initiative"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "18 + 2 (DEX) = 20 initiative, goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 20, "y": 10, "terrain": "difficult" },
          { "x": 25, "y": 10, "terrain": "difficult" },
          { "x": 30, "y": 10, "terrain": "difficult" }
        ]
      },
      "comment": "Difficult terrain strip at x=20-30 between fighter and goblin. Each cell costs 10ft instead of 5ft."
    },
    {
      "type": "action",
      "input": { "text": "move toward Goblin Scout" },
      "comment": "Fighter at (10,10), goblin at (40,10). Direct path 30ft but difficult terrain adds extra cost. With 30ft speed, fighter can't reach melee range — partial move expected.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Combat should still be active after partial move through difficult terrain",
      "expect": {
        "combatStatus": "Active"
      }
    }
  ]
}
