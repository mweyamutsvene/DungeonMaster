{
  "name": "TWF: Non-Light weapon rejects offhand attack",
  "description": "A Fighter wielding a Longsword (not Light) + Shortsword (Light) attempts an offhand attack. The TWF rules require BOTH weapons to be Light, so the offhand attack should be rejected.",
  "setup": {
    "character": {
      "name": "Heavy Hitter",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["versatile"]
          },
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "piercing",
            "properties": ["finesse", "light"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 1,
            "wisdom": 1,
            "charisma": 1
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 10,
          "speed": 0,
          "attacks": []
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training dummy" },
      "expect": {
        "rollType": "initiative"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy with my longsword" },
      "comment": "Main hand attack with Longsword",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 6 = 21 vs AC 10 - hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 3 = 9 damage",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "offhand attack" },
      "comment": "Offhand attack should FAIL because Longsword is not Light",
      "expect": {
        "error": true,
        "errorContains": "Light"
      }
    }
  ]
}
