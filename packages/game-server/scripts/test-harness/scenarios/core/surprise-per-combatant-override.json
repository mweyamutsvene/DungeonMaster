{
  "name": "Surprise: Per-combatant override applies initiative disadvantage to one PC",
  "description": "DM explicitly overrides surprise for one combatant using { surprised: [...] }. Shadow is marked surprised while ally Torchbearer is not, so the initiator receives initiative disadvantage.",
  "setup": {
    "character": {
      "name": "Shadow",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 5, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["Versatile (1d10)"]
          }
        ]
      }
    },
    "npcs": [
      {
        "name": "Torchbearer",
        "position": { "x": 6, "y": 10 },
        "faction": "party",
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 12,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 10
          },
          "maxHp": 18,
          "hp": 18,
          "armorClass": 12,
          "speed": 30,
          "attacks": [
            {
              "name": "Club",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 2,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Goblin Guard",
        "position": { "x": 10, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 15,
          "speed": 30,
          "passivePerception": 9,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "setSurprise",
      "comment": "Per-combatant override: only Shadow is surprised. This branch validates explicit DM override independent of Hidden auto-compute.",
      "input": { "surprise": { "surprised": ["Shadow"] } }
    },
    {
      "type": "initiate",
      "comment": "Because Shadow is specifically in the surprised list, initiative should request disadvantage.",
      "input": { "text": "I attack the goblin guard" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true,
        "advantage": false,
        "disadvantage": true
      }
    },
    {
      "type": "rollResult",
      "comment": "Submit initiative roll after disadvantage prompt.",
      "input": { "text": "I rolled a 12" },
      "expect": { "rollType": "initiative", "combatStarted": true }
    },
    {
      "type": "action",
      "comment": "Proceed with normal attack flow after initiative.",
      "input": { "text": "I attack the goblin guard with my longsword" },
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "comment": "Attack roll vs AC 15.",
      "input": { "text": "I rolled a 16" },
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "comment": "Damage roll.",
      "input": { "text": "I rolled a 6" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Checkpoint: override branch completed, HP and combat status remain deterministic.",
      "expect": {
        "combatStatus": "Active",
        "characterHp": { "min": 44, "max": 44 },
        "monsterHp": { "name": "Goblin Guard", "min": 1, "max": 29 }
      }
    }
  ]
}
