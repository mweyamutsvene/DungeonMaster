          "attacks": [
            {
              "name": "Quarterstaff", "kind": "melee",
              "attackBonus": 1,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "monsters": []
  },
  "actions": [
    {
      "comment": "=== SHORT REST: takes the takeSessionRest(short) path with hit-dice spending ===",
      "type": "rest",
      "input": {
        "restType": "short",
        "hitDiceSpending": {
          "Thorin": 2,
          "Sister Mira": 2,
          "Elara": 1
        }
      },
      "expect": {
        "poolsRefreshed": ["secondWind", "actionSurge", "channelDivinity:cleric"]
      }
    },
    {
      "type": "rest",
      "input": { "restType": "short" },
      "expect": {
        "characterHp": { "name": "Thorin", "min": 35, "max": 54 }
      },
      "comment": "Second short rest with no hit-dice spend — used only to pipe the characterHp check through the scenario's built-in rest expects. Thorin should have ~30 + 2d10+6 = 38-56 HP, capped at 54."
    },
    {
      "type": "rest",
      "input": { "restType": "short" },
      "expect": {
        "characterHp": { "name": "Sister Mira", "min": 24, "max": 40 }
      },
      "comment": "Mira HP check: 20 + 2d8+4 = 26-36 (starting from prev rest state)."
    },
    {
      "type": "rest",
      "input": { "restType": "short" },
      "expect": {
        "characterHp": { "name": "Elara", "min": 28, "max": 32 }
      },
      "comment": "Elara HP check: 25 + 1d6+2 = 28-33, capped at 32."
    }
  ]
}
