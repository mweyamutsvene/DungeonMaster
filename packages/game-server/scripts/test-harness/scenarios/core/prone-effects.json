{
  "name": "Prone Effects: Melee advantage after shove",
  "description": "Validates that shoving a target prone applies the Prone condition, and subsequent melee attacks against the prone target have advantage. D&D 5e: melee attacks within 5ft of a prone target have advantage.",
  "setup": {
    "character": {
      "name": "Grimgar the Strong",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 20,
          "dexterity": 12,
          "constitution": 16,
          "intelligence": 8,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Warhammer",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 8,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 5 },
            "damageType": "bludgeoning"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 10,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Dagger",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "shove Goblin Scout prone" },
      "comment": "Tabletop dice flow: Unarmed Strike +8 vs AC 10 (shove prone). Contest DC 16. L5 Fighter (Extra Attack) uses 1 of 2 attacks.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 8 = 23 vs AC 10 → HIT. Server auto-resolves save: target DEX +2 vs DC 16 → fail. Knocked Prone!",
      "expect": {
        "hit": true,
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify the Goblin Scout has the Prone condition applied",
      "expect": {
        "combatStatus": "Active",
        "monsterConditions": {
          "name": "Goblin Scout",
          "hasConditions": ["Prone"]
        }
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn - Goblin's AI turn: it will stand up from Prone (costs half speed) and then may attack/move"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Goblin's turn to pass, then our turn comes"
    },
    {
      "type": "assertState",
      "comment": "Verify Goblin no longer has Prone condition (AI stood up by moving during its turn)",
      "expect": {
        "combatStatus": "Active",
        "monsterConditions": {
          "name": "Goblin Scout",
          "doesNotHaveConditions": ["Prone"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Goblin Scout" },
      "comment": "Melee attack vs standing target - no advantage",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "comment": "12 + 8 = 20 vs AC 10 - hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 5 = 11 damage",
      "expect": {
        "actionComplete": true
      }
    }
  ]
}
