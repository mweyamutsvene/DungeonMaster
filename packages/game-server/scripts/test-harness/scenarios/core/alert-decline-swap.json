{
  "name": "Alert Feat: Decline Initiative Swap",
  "description": "A Fighter with the Alert feat declines the initiative swap offer. Tests that the swap offer appears but declining proceeds normally.",
  "setup": {
    "characters": [
      {
        "name": "Ranger",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 12, "dexterity": 16, "constitution": 14,
            "intelligence": 10, "wisdom": 14, "charisma": 8
          },
          "maxHp": 38, "currentHp": 38, "armorClass": 15, "speed": 30,
          "proficiencyBonus": 3,
          "featIds": ["feat_alert"],
          "attacks": [
            {
              "name": "Longbow", "kind": "ranged", "range": "150/600",
              "attackBonus": 6,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Cleric",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 14, "dexterity": 10, "constitution": 14,
            "intelligence": 10, "wisdom": 16, "charisma": 12
          },
          "maxHp": 38, "currentHp": 38, "armorClass": 16, "speed": 30,
          "proficiencyBonus": 3,
          "attacks": [
            {
              "name": "Mace", "kind": "melee", "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Bandit",
        "position": { "x": 10, "y": 5 },
        "statBlock": {
          "abilityScores": {
            "strength": 12, "dexterity": 12, "constitution": 12,
            "intelligence": 10, "wisdom": 10, "charisma": 10
          },
          "maxHp": 20, "hp": 20, "armorClass": 12, "speed": 30,
          "attacks": [
            {
              "name": "Shortsword", "kind": "melee", "range": "melee",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 1 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": { "strategy": "aggressive" }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Ranger",
      "input": { "text": "roll initiative" },
      "comment": "Ranger with Alert initiates.",
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "actor": "Ranger",
      "input": { "text": "14" },
      "comment": "Ranger rolls 14. Server offers swap (has Alert feat + ally).",
      "expect": { "combatStarted": true, "initiativeSwapOffer": true }
    },
    {
      "type": "rollResult",
      "actor": "Ranger",
      "input": { "text": "no swap" },
      "comment": "Decline the swap. Combat proceeds normally.",
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "actor": "Ranger",
      "input": { "text": "attack bandit with longbow" },
      "comment": "Ranger attacks.",
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "actor": "Ranger",
      "input": { "text": "15" },
      "comment": "Roll attack (hits AC 12).",
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "actor": "Ranger",
      "input": { "text": "6" },
      "comment": "Roll damage.",
      "expect": { "actionComplete": true }
    }
  ]
}
