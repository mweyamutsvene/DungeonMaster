{
  "name": "Death Save: Natural 20 Revival",
  "description": "A character drops to 0 HP, then rolls a Natural 20 on their death save. Per D&D 5e 2024 rules, this means they regain 1 HP and become conscious. Tests the critical success path.",
  "setup": {
    "character": {
      "name": "Lucky Survivor",
      "className": "Fighter",
      "level": 1,
      "position": { "x": 0, "y": 0 },
      "sheet": {
        "abilityScores": {
          "strength": 10, "dexterity": 10, "constitution": 10,
          "intelligence": 10, "wisdom": 10, "charisma": 10
        },
        "maxHp": 1, "currentHp": 1, "armorClass": 10, "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Dagger", "kind": "melee", "attackBonus": 2,
            "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
            "damageType": "piercing"
          }
        ],
        "features": [],
        "resourcePools": []
      }
    },
    "monsters": [
      {
        "name": "Deadly Foe",
        "position": { "x": 5, "y": 0 },
        "statBlock": {
          "abilityScores": {
            "strength": 20, "dexterity": 20, "constitution": 20,
            "intelligence": 10, "wisdom": 10, "charisma": 10
          },
          "hp": 100, "maxHp": 100, "armorClass": 18, "speed": 30,
          "position": { "x": 5, "y": 0 },
          "attacks": [
            {
              "name": "Greatsword", "kind": "melee", "range": "melee",
              "attackBonus": 15,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 5 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I face the Deadly Foe" },
      "comment": "Start combat — character rolls low initiative",
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "2" },
      "comment": "Init 2 (dex 0). Monster goes first (init 15+5=20). Monster KOs the 1 HP character.",
      "expect": { "combatStarted": true }
    },
    {
      "type": "waitForTurn",
      "comment": "Monster attacks, KOs character to 0 HP. Server sets DEATH_SAVE pending action."
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "Natural 20 death save → REVIVED! Regain 1 HP, become conscious.",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "revived",
        "deathSaves": { "successes": 0, "failures": 0 },
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 1 },
        "characterConditions": { "doesNotHaveConditions": ["Unconscious"] }
      },
      "comment": "Character revived: 1 HP, no longer Unconscious"
    }
  ]
}
