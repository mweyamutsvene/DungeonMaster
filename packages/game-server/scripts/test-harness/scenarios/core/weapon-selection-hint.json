{
  "name": "Weapon Selection: Explicit weapon hint selects correct weapon",
  "description": "Fighter with Longsword and Handaxe attacks using 'with my longsword'. Verifies the text parser correctly selects the named weapon from the character's attacks array. Reproduces BUG-H1 from agent test plays.",
  "setup": {
    "character": {
      "name": "Gareth Ironclaw",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 35, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          },
          {
            "name": "Handaxe",
            "kind": "melee",
            "range": "20/60",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["Light", "Thrown"]
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Warrior",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 12,
          "hp": 12,
          "armorClass": 15,
          "speed": 30,
          "challengeRating": 0.25,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the goblin" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "comment": "High initiative so player goes first.",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Goblin Warrior with my longsword" },
      "comment": "Explicit weapon hint 'longsword'. The server should use Longsword (1d8+3), not Handaxe (1d6+3). BUG-H1 regression: verify weapon hint routes to correct weapon.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "expect": {
        "hit": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 5" },
      "comment": "Longsword: 1d8+3 = 5+3 = 8 damage. The message should mention Longsword, not Handaxe. Goblin HP: 12→4. Extra Attack triggers (Fighter L5).",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn after first attack. Monster will endTurn via default behavior."
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for monster to end turn and player turn to come back."
    },
    {
      "type": "action",
      "input": { "text": "I attack the Goblin Warrior with my handaxe" },
      "comment": "Now test the Handaxe selection. This should use the Handaxe (1d6+3), not Longsword.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "expect": {
        "hit": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "Handaxe: 1d6+3 = 6+3 = 9 damage. Total: 8+9 = 17 damage on a 12 HP goblin → should be dead.",
      "expect": {
        "combatEnded": true,
        "victoryStatus": "Victory"
      }
    }
  ]
}
