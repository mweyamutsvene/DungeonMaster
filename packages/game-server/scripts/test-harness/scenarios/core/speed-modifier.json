{
  "name": "Speed Modifier: Longstrider Buff",
  "description": "A Wizard casts Longstrider (self-buff granting +10ft speed via ActiveEffect speed_modifier). Then moves 35ft — beyond normal 30ft limit but within boosted 40ft. Tests getEffectiveSpeed() includes ActiveEffect speed modifiers in movement validation.",
  "setup": {
    "character": {
      "name": "Swift Sage",
      "className": "Wizard",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 12,
          "intelligence": 18, "wisdom": 12, "charisma": 10
        },
        "maxHp": 18, "currentHp": 18, "armorClass": 12, "speed": 30,
        "proficiencyBonus": 2,
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 14,
        "spellAttackBonus": 6,
        "spellSlots": { "1": 4 },
        "preparedSpells": [
          { "name": "Longstrider", "level": 1 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff", "kind": "melee", "range": "melee",
            "attackBonus": 0,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 80, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10, "dexterity": 10, "constitution": 10,
            "intelligence": 1, "wisdom": 1, "charisma": 1
          },
          "maxHp": 100, "hp": 100, "armorClass": 5, "speed": 0,
          "challengeRating": 0,
          "attacks": [
            {
              "name": "Bump", "kind": "melee", "attackBonus": 0,
              "damage": { "diceCount": 1, "diceSides": 1, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for speed" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Cast Longstrider — +10ft speed modifier applied as ActiveEffect",
      "type": "action",
      "input": { "text": "cast Longstrider" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    },
    {
      "comment": "Move 35ft (7 cells from x=10 to x=17). Normal 30ft would block this. Longstrider +10ft allows 40ft total.",
      "type": "action",
      "input": { "text": "move to (17, 10)" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Verify character is at (17, 10) — proving 35ft was allowed with boosted speed",
      "type": "assertState",
      "expect": {
        "characterPosition": { "x": 17, "y": 10 }
      }
    }
  ]
}
