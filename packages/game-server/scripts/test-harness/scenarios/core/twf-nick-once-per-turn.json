{
  "name": "TWF: Nick only waives bonus once per turn",
  "description": "Nick offhand preserves bonus action once; after spending bonus action, another offhand in the same turn is blocked.",
  "setup": {
    "character": {
      "name": "Nick Fighter",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 35, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 14,
          "dexterity": 18,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 20,
        "armorClass": 17,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "piercing",
            "properties": ["finesse", "light"]
          },
          {
            "name": "Scimitar",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "slashing",
            "properties": ["finesse", "light"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" },
          { "name": "Second Wind", "description": "Regain 1d10 + Fighter level HP as a bonus action (1/short rest)" }
        ],
        "resourcePools": [
          { "name": "secondWind", "current": 1, "max": 1 }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 8,
            "constitution": 18,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 200,
          "hp": 200,
          "armorClass": 10,
          "speed": 0,
          "challengeRating": 0,
          "experienceValue": 0,
          "attacks": []
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training dummy" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Training Dummy with my shortsword" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "4" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "action",
      "input": { "text": "off-hand attack" },
      "comment": "Nick applies here and should preserve bonus action.",
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "3" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "action",
      "input": { "text": "use second wind" },
      "comment": "Should still work because first Nick offhand did not spend bonus action.",
      "expect": { "actionComplete": true }
    },
    {
      "type": "action",
      "input": { "text": "offhand attack" },
      "comment": "Nick can only waive once; bonus action already spent by Second Wind, so this offhand should fail.",
      "expect": {
        "error": true,
        "errorContains": "bonus action"
      }
    }
  ]
}
