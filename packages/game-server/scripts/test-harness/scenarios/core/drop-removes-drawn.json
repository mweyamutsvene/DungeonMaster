{
  "name": "Drop removes weapon from drawn",
  "description": "A Fighter drops their Longsword (free, no interaction cost), which removes it from drawnWeapons. Then picks it up (costs free interaction), which re-adds to drawnWeapons.",
  "setup": {
    "character": {
      "name": "Brynn Ironhold",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 20, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 12,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["Versatile"]
          },
          {
            "name": "Handaxe",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["Light", "Thrown (Range 20/60)"]
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 50, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10, "dexterity": 10, "constitution": 10,
            "intelligence": 1, "wisdom": 1, "charisma": 1
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 10,
          "speed": 0,
          "attacks": []
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "Fight!" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true }
    },

    {
      "type": "assertState",
      "comment": "Both weapons drawn at combat start",
      "expect": {
        "characterDrawnWeapons": {
          "has": ["Longsword", "Handaxe"]
        }
      }
    },

    {
      "type": "action",
      "input": { "text": "drop longsword" },
      "comment": "Drop is free (no action or interaction cost). Removes from drawn.",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "Longsword dropped — no longer drawn, on ground",
      "expect": {
        "characterDrawnWeapons": {
          "has": ["Handaxe"],
          "doesNotHave": ["Longsword"]
        },
        "groundItemCount": 1,
        "groundItemExists": { "name": "Longsword", "nearPosition": { "x": 20, "y": 10 } }
      }
    },

    {
      "type": "action",
      "input": { "text": "pick up longsword" },
      "comment": "Pick up uses free object interaction. Adds back to drawnWeapons.",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "Longsword picked up and drawn again. Ground clear.",
      "expect": {
        "characterDrawnWeapons": {
          "has": ["Longsword", "Handaxe"]
        },
        "groundItemCount": 0
      }
    }
  ]
}
