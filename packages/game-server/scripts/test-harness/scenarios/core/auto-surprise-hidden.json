{
  "name": "Surprise: Auto-computed from Hidden condition (stealth vs passive perception)",
  "description": "A Fighter with Hidden condition and stealthRoll sneaks up on a Goblin. The server auto-computes surprise because the fighter's stealth (18) beats the goblin's passive perception (9). The goblin rolls initiative with disadvantage.",
  "setup": {
    "character": {
      "name": "Shadow",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 5, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "conditions": [{ "condition": "Hidden", "duration": "until_removed" }],
        "resources": { "stealthRoll": 18 },
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["Versatile (1d10)"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Guard",
        "position": { "x": 10, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 15,
          "speed": 30,
          "passivePerception": 9,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "comment": "No setSurprise needed — server auto-computes from Hidden condition. Shadow's stealth 18 > Goblin's passive perception 9, so the goblin is surprised.",
      "input": { "text": "I attack the goblin guard" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "comment": "Roll initiative (high roll to go first)",
      "input": { "text": "I rolled a 18" },
      "expect": { "rollType": "initiative", "combatStarted": true }
    },
    {
      "type": "action",
      "comment": "Attack the surprised goblin",
      "input": { "text": "I attack the goblin guard with my longsword" },
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "comment": "Roll attack (hits AC 15)",
      "input": { "text": "I rolled a 16" },
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "comment": "Roll damage",
      "input": { "text": "I rolled a 6" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Goblin took damage from the surprise attack",
      "expect": {
        "monsterHp": { "name": "Goblin Guard", "min": 1, "max": 29 }
      }
    }
  ]
}
