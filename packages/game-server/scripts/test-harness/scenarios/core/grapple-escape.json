{
  "name": "Grapple Escape: Player grapples monster, monster escapes",
  "description": "Player grapples a monster via the tabletop dice flow (Unarmed Strike attack roll vs AC, then server auto-resolves STR/DEX save vs DC). On the monster's turn the AI attempts to escape the grapple (programmatic, unchanged). The monster has low STR so escape should fail.",
  "setup": {
    "character": {
      "name": "Strong Fighter",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 20,
          "dexterity": 10,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 28,
        "currentHp": 28,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 5 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Weak Goblin",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 10,
          "speed": 30,
          "size": "Small",
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "escapeGrapple"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High roll so player goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "grapple Weak Goblin" },
      "comment": "Tabletop dice flow: Unarmed Strike STR +5, prof +2 = +7 vs AC 10. Contest DC 15.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 7 = 22 vs AC 10 → HIT. Server auto-resolves save: target DEX +2 vs DC 15 → fail. Grappled!",
      "expect": {
        "hit": true,
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify Goblin has Grappled condition",
      "expect": {
        "monsterConditions": {
          "name": "Weak Goblin",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Goblin's turn — AI attempts escapeGrapple (Athletics/Acrobatics vs DC 15). Should fail."
    },
    {
      "type": "assertState",
      "comment": "After failed escape attempt, Goblin should still be Grappled",
      "expect": {
        "monsterConditions": {
          "name": "Weak Goblin",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Weak Goblin" },
      "comment": "Player attacks while goblin is still grappled",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 7 = 22 vs AC 10 — hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 5 = 10 damage",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn"
    }
  ]
}
