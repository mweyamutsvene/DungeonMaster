{
  "name": "Grapple Escape: deterministic monster fail + player success/fail branches",
  "description": "Covers grapple escape branches in one deterministic flow: monster fails to escape, player succeeds escaping a weak grappler, then player fails escaping an overwhelming grappler. Includes an action-economy checkpoint after failed escape.",
  "setup": {
    "character": {
      "name": "Strong Fighter",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 32,
          "dexterity": 10,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 28,
        "currentHp": 28,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 5 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Weak Goblin",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 10,
          "speed": 30,
          "size": "Small",
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      },
      {
        "name": "Titan Brute",
        "position": { "x": 30, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 54,
            "dexterity": 8,
            "constitution": 16,
            "intelligence": 6,
            "wisdom": 8,
            "charisma": 6
          },
          "maxHp": 80,
          "hp": 80,
          "armorClass": 12,
          "speed": 30,
          "size": "Large",
          "challengeRating": 5,
          "experienceValue": 1800,
          "attacks": [
            {
              "name": "Club",
              "kind": "melee",
              "attackBonus": 10,
              "damage": { "diceCount": 2, "diceSides": 8, "modifier": 8 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High roll so player goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "grapple Weak Goblin" },
      "comment": "Tabletop dice flow: Unarmed Strike STR +11, prof +2 = +13 vs AC 10. Contest DC 21.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 13 = 28 vs AC 10 -> HIT. Server auto-resolves save: target DEX +2 vs DC 21 -> fail. Grappled!",
      "expect": {
        "hit": true,
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify Goblin has Grappled condition",
      "expect": {
        "monsterConditions": {
          "name": "Weak Goblin",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "queueMonsterActions",
      "comment": "Force weak goblin to attempt escape; Titan Brute simply ends turn.",
      "input": {
        "decisions": [
          { "action": "escapeGrapple", "endTurn": true },
          { "action": "endTurn", "endTurn": true }
        ]
      }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Goblin's turn — AI attempts escapeGrapple (Athletics/Acrobatics vs DC 15). Should fail."
    },
    {
      "type": "assertState",
      "comment": "Failure branch 1: after failed monster escape attempt, goblin remains grappled.",
      "expect": {
        "combatStatus": "Active",
        "characterPosition": { "x": 10, "y": 10 },
        "monsterConditions": {
          "name": "Weak Goblin",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "applyCondition",
      "comment": "Apply Grappled to the character from weak grappler (low DC branch).",
      "input": {
        "target": "character",
        "condition": "Grappled",
        "duration": "1 minute",
        "sourceMonster": "Weak Goblin"
      }
    },
    {
      "type": "assertState",
      "comment": "Checkpoint before escape attempt: character is grappled and combat is active.",
      "expect": {
        "characterConditions": {
          "hasConditions": ["Grappled"]
        },
        "characterPosition": { "x": 10, "y": 10 },
        "combatStatus": "Active",
        "monsterConditions": {
          "name": "Weak Goblin",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "action",
      "comment": "Success branch: escape weak grappler (DC is very low).",
      "input": { "text": "escape grapple" },
      "expect": {
        "actionComplete": true,
        "type": "SIMPLE_ACTION_COMPLETE"
      }
    },
    {
      "type": "assertState",
      "comment": "After successful escape, character should no longer be grappled.",
      "expect": {
        "characterConditions": {
          "doesNotHaveConditions": ["Grappled"]
        },
        "characterPosition": { "x": 10, "y": 10 },
        "combatStatus": "Active"
      }
    },
    {
      "type": "endTurn",
      "comment": "Advance to next round so a fresh action is available for the failure branch."
    },
    {
      "type": "waitForTurn",
      "comment": "Wait through monster turns and return to player turn."
    },
    {
      "type": "applyCondition",
      "comment": "Apply Grappled from overwhelming grappler (very high DC branch).",
      "input": {
        "target": "character",
        "condition": "Grappled",
        "duration": "1 minute",
        "sourceMonster": "Titan Brute"
      }
    },
    {
      "type": "assertState",
      "comment": "Checkpoint before hard escape attempt: grappled by Titan Brute and still active combat.",
      "expect": {
        "characterConditions": {
          "hasConditions": ["Grappled"]
        },
        "characterPosition": { "x": 10, "y": 10 },
        "combatStatus": "Active",
        "monsterConditions": {
          "name": "Titan Brute",
          "doesNotHaveConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "action",
      "comment": "Failure branch 2: attempt to escape Titan Brute grapple; should fail and remain grappled.",
      "input": { "text": "escape grapple" },
      "expect": {
        "actionComplete": true,
        "type": "SIMPLE_ACTION_COMPLETE"
      }
    },
    {
      "type": "assertState",
      "comment": "Post-failure: character remains grappled and in place.",
      "expect": {
        "characterConditions": {
          "hasConditions": ["Grappled"]
        },
        "characterPosition": { "x": 10, "y": 10 },
        "combatStatus": "Active"
      }
    },
    {
      "type": "action",
      "comment": "Economy checkpoint: after spending action on escape, a second action in same turn should be rejected.",
      "input": { "text": "attack Weak Goblin" },
      "expect": {
        "error": true
      }
    },
    {
      "type": "assertState",
      "comment": "Final checkpoint: combat remains active after branch and economy validation.",
      "expect": {
        "combatStatus": "Active",
        "characterPosition": { "x": 10, "y": 10 },
        "characterConditions": {
          "hasConditions": ["Grappled"]
        }
      }
    }
  ]
}
