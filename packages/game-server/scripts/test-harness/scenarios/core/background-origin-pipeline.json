{
  "name": "Background pipeline applies origin feat and ASI",
  "description": "A Criminal background character gets Alert from background and can receive an initiative swap offer.",
  "setup": {
    "characters": [
      {
        "name": "Scout",
        "className": "Rogue",
        "level": 1,
        "background": "criminal",
        "asiChoice": {
          "dexterity": 2,
          "constitution": 1,
          "intelligence": 1
        },
        "sheet": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 14,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 12,
            "charisma": 10
          },
          "maxHp": 10,
          "currentHp": 10,
          "armorClass": 14,
          "speed": 30,
          "attacks": [
            {
              "name": "Shortsword",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Tank",
        "className": "Fighter",
        "level": 1,
        "sheet": {
          "abilityScores": {
            "strength": 16,
            "dexterity": 10,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 8
          },
          "maxHp": 14,
          "currentHp": 14,
          "armorClass": 16,
          "speed": 30
        }
      }
    ],
    "monsters": [
      {
        "name": "Training Orc",
        "statBlock": {
          "abilityScores": {
            "strength": 16,
            "dexterity": 10,
            "constitution": 14,
            "intelligence": 8,
            "wisdom": 10,
            "charisma": 8
          },
          "maxHp": 15,
          "hp": 15,
          "armorClass": 13,
          "speed": 30,
          "attacks": [
            {
              "name": "Greataxe",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 12, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "queueDiceRolls",
      "comment": "Deterministic non-Scout initiative rolls so Scout can offer initiative swap.",
      "input": { "values": [5, 4], "label": "initiative auto-rolls" }
    },
    {
      "type": "initiate",
      "actor": "Scout",
      "input": { "text": "roll initiative" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "15" },
      "expect": { "combatStarted": true, "initiativeSwapOffer": true }
    }
  ]
}
