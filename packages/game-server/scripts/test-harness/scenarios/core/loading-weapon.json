{
  "name": "Loading: Crossbow Extra Attack limitation",
  "description": "A Fighter with Extra Attack fires a Light Crossbow (Loading property). The first attack resolves normally. The second attack is rejected because loading weapons can only fire once per action regardless of Extra Attack.",
  "setup": {
    "character": {
      "name": "Kira",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 5, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 16,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Light Crossbow",
            "kind": "ranged",
            "range": "80/320",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "piercing",
            "properties": ["Ammunition", "Loading", "Two-Handed"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Sentry",
        "position": { "x": 20, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 15,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 }
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I ready my crossbow" },
      "expect": {
        "rollType": "initiative"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "shoot Goblin Sentry with light crossbow" },
      "comment": "First shot with Loading crossbow — should succeed",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 6 = 21 vs AC 15 → hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 3 = 9 damage",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Goblin took 9 damage: 30 - 9 = 21 HP",
      "expect": {
        "monsterHp": { "name": "Goblin Sentry", "min": 21, "max": 21 }
      }
    },
    {
      "type": "action",
      "input": { "text": "shoot Goblin Sentry with light crossbow" },
      "comment": "Second shot with Loading crossbow — should be rejected",
      "expect": {
        "error": true,
        "errorContains": "Loading"
      }
    }
  ]
}
