{
  "name": "Grappled Effects: Speed zero, no advantage",
  "description": "Validates that grappling a target via the tabletop dice flow applies the Grappled condition (speed becomes 0). Per D&D 5e 2024, Grappled does NOT grant advantage on attacks — only restricts movement. Tests grapple contest, condition assertion, and normal attack roll mode.",
  "setup": {
    "character": {
      "name": "Grimgar the Grappler",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 20,
          "dexterity": 12,
          "constitution": 16,
          "intelligence": 8,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Warhammer",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 8,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 5 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Victim",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 10,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Dagger",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High roll to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "grapple Goblin Victim" },
      "comment": "Tabletop dice flow: Unarmed Strike +8 vs AC 10. Contest DC 16. L5 Fighter uses 1 of 2 attacks.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 8 = 23 vs AC 10 → HIT. Server auto-resolves save: target DEX +2 vs DC 16 → fail. Grappled!",
      "expect": {
        "hit": true,
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify the Goblin Victim now has the Grappled condition",
      "expect": {
        "monsterConditions": {
          "name": "Goblin Victim",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Goblin Victim" },
      "comment": "Attack the grappled target (2nd attack from Extra Attack) - should be NORMAL roll (Grappled does NOT grant advantage per 5e 2024)",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true,
        "advantage": false,
        "disadvantage": false
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 8 = 23 vs AC 10 - hit",
      "expect": {
        "hit": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "6 + 5 = 11 damage",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn after grapple + attack (both attacks used via Extra Attack)."
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Goblin's turn. It can still attack (Grappled only restricts movement)."
    },
    {
      "type": "assertState",
      "comment": "Verify Goblin still has Grappled condition after its turn",
      "expect": {
        "monsterConditions": {
          "name": "Goblin Victim",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "endTurn"
    }
  ]
}
