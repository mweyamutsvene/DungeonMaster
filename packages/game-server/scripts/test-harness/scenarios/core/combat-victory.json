          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Shortsword",
              "kind": "melee",
              "attackBonus": 2,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 0 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Skeleton B",
        "position": { "x": 10, "y": 15 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 6,
            "wisdom": 8,
            "charisma": 5
          },
          "maxHp": 1,
          "hp": 1,
          "armorClass": 10,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Shortsword",
              "kind": "melee",
              "attackBonus": 2,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 0 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I charge into battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "comment": "High initiative — fighter goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Skeleton A with warhammer" },
      "comment": "Skeleton A is adjacent at (10,10). Player at (5,10) = 5ft away.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 7 = 22 vs AC 10 → hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "1" },
      "comment": "1 + 4 = 5 damage vs 1 HP → Skeleton A dies. Extra Attack remaining is auto-absorbed by runner.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Skeleton A dead, Skeleton B still alive",
      "expect": {
        "monstersAlive": 1
      }
    },
    {
      "type": "endTurn",
      "comment": "End player turn. Skeletons use endTurn behavior. Player turn returns."
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for all monster endTurn actions to complete",
      "timeout": 5000
    },
    {
      "type": "action",
      "input": { "text": "attack Skeleton B with warhammer" },
      "comment": "Skeleton B at (10,15) is within 5ft reach diagonally from player at (5,10)",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 7 = 22 vs AC 10 → hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "1" },
      "comment": "1 + 4 = 5 damage vs 1 HP → Skeleton B dies. Last enemy killed — combat must end with Victory. Post-fix: AI loop terminates cleanly.",
      "expect": {
        "actionComplete": true,
        "combatEnded": true,
        "victoryStatus": "Victory"
      }
    },
    {
      "type": "assertState",
      "comment": "All enemies dead — combat status must be Victory, not Active",
      "expect": {
        "combatStatus": "Victory",
        "monstersAlive": 0
      }
    }
  ]
