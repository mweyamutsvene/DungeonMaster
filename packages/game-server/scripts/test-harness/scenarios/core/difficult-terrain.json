{
  "name": "Difficult Terrain: Movement Cost Doubled",
  "description": "Validates that difficult terrain halves effective speed. Character has speed 30 and tries to move 20ft to a cell marked as difficult terrain. With speedModifier 0.5, effective speed is 15ft — movement should fail. Then tries 15ft — should succeed.",
  "setup": {
    "character": {
      "name": "Ranger Rick",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin",
        "position": { "x": 50, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 15,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle against the goblin" },
      "expect": {
        "rollType": "initiative"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "15 + 2 (DEX) = 17 initiative, goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 25, "y": 10, "terrain": "difficult" },
          { "x": 30, "y": 10, "terrain": "difficult" }
        ]
      },
      "comment": "Mark cells at (25, 10) and (30, 10) as difficult terrain"
    },
    {
      "type": "action",
      "input": { "text": "move to (25, 10)" },
      "comment": "Attempt to move 15ft to difficult terrain. Speed 30, modifier 0.5 → effective 15ft. Distance 15ft → should succeed.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Combat should still be active after successful move",
      "expect": {
        "combatStatus": "Active"
      }
    }
  ]
}
