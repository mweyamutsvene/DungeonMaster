{
  "name": "AI Hide + Search: Monster hides, player searches",
  "description": "A Goblin AI hides on its turn (gaining Hidden condition), then the player uses Search action to find it. Tests the AI hide executor, Hidden condition, and Search → reveal flow.",
  "setup": {
    "character": {
      "name": "Percival the Perceptive",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 16,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "skills": {
          "perception": 6
        },
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Sneaky Goblin",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 7,
          "hp": 7,
          "armorClass": 15,
          "speed": 30,
          "skills": {
            "stealth": 6
          },
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "hide"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "3" },
      "comment": "Low roll so goblin goes first and hides",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Goblin's turn — AI should attempt hide action"
    },
    {
      "type": "action",
      "input": { "text": "search" },
      "comment": "Player searches for hidden enemies — high Perception (+6) vs Goblin's Stealth",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn after search action"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for Goblin's next turn (configured to hide again)"
    },
    {
      "type": "action",
      "input": { "text": "attack Sneaky Goblin" },
      "comment": "Attack the goblin on next turn",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "18 + 6 = 24 vs AC 15 — hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "8" },
      "comment": "8 + 3 = 11 damage — kills goblin (7 HP)",
      "expect": {
        "actionComplete": true
      }
    }
  ]
}
