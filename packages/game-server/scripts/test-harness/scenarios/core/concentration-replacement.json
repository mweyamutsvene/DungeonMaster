{
  "name": "Concentration: New spell replaces old",
  "description": "A Wizard casts a concentration spell (Bless), then casts a second concentration spell (Hold Person). The first spell's concentration should be automatically dropped when the new concentration spell is cast. Tests concentration replacement mechanics.",
  "setup": {
    "character": {
      "name": "Focus Mage",
      "className": "Wizard",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 14,
          "intelligence": 18, "wisdom": 12, "charisma": 10
        },
        "maxHp": 32, "currentHp": 32, "armorClass": 12, "speed": 30,
        "proficiencyBonus": 3,
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 15,
        "spellAttackBonus": 7,
        "spellSlots": { "1": 4, "2": 3 },
        "preparedSpells": [
          { "name": "Bless", "level": 1 },
          { "name": "Hold Person", "level": 2 },
          { "name": "Fire Bolt", "level": 0 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff", "kind": "melee", "range": "melee",
            "attackBonus": 1,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Bandit",
        "position": { "x": 25, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 12, "dexterity": 12, "constitution": 12,
            "intelligence": 10, "wisdom": 10, "charisma": 10
          },
          "maxHp": 50, "hp": 50, "armorClass": 12, "speed": 30,
          "challengeRating": 0.125,
          "attacks": [
            {
              "name": "Scimitar", "kind": "melee", "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 1 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare my magic" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High init to go first",
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "input": { "text": "cast Bless" },
      "comment": "Cast Bless (concentration spell #1). Spends a level 1 slot, starts concentration on Bless.",
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "CastSpell"
      }
    },
    {
      "type": "endTurn"
    },
    { "type": "waitForTurn" },
    {
      "type": "action",
      "input": { "text": "cast Hold Person on Bandit" },
      "comment": "Cast Hold Person (concentration spell #2). This should automatically drop Bless concentration and begin concentrating on Hold Person. Spends a level 2 slot.",
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "CastSpell"
      }
    },
    {
      "type": "endTurn"
    },
    { "type": "waitForTurn" },
    {
      "type": "action",
      "input": { "text": "cast Fire Bolt at Bandit" },
      "comment": "Cast Fire Bolt cantrip — now a ranged spell attack (canonical catalog). Doesn't affect concentration.",
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "Fire Bolt attack roll: 15 + 7 (spellAttackBonus) = 22 vs AC 12 → hit",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 8" },
      "comment": "Fire Bolt damage: 8 fire damage",
      "expect": { "actionComplete": true }
    }
  ]
}
