{
  "name": "Damage Resistance/Immunity/Vulnerability",
  "description": "A Fighter validates three 2024 damage-defense branches in one deterministic sequence: resistance halves damage, resistance+vulnerability on the same type cancel, and immunity takes precedence over all other modifiers.",
  "setup": {
    "character": {
      "name": "Frost Knight",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Warhammer",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Fire Elemental",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 14,
            "constitution": 16,
            "intelligence": 6,
            "wisdom": 10,
            "charisma": 7
          },
          "maxHp": 102,
          "hp": 102,
          "armorClass": 5,
          "speed": 50,
          "challengeRating": 5,
          "experienceValue": 1800,
          "damageResistances": ["bludgeoning"],
          "damageImmunities": ["fire", "poison"],
          "damageVulnerabilities": ["cold"],
          "attacks": [
            {
              "name": "Touch",
              "kind": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 2, "diceSides": 6, "modifier": 3 },
              "damageType": "fire"
            }
          ]
        }
      },
      {
        "name": "Flux Elemental",
        "position": { "x": 14, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 14,
            "constitution": 16,
            "intelligence": 6,
            "wisdom": 10,
            "charisma": 7
          },
          "maxHp": 102,
          "hp": 102,
          "armorClass": 5,
          "speed": 50,
          "challengeRating": 5,
          "experienceValue": 1800,
          "damageResistances": ["bludgeoning"],
          "damageImmunities": ["fire", "poison"],
          "damageVulnerabilities": ["bludgeoning"],
          "attacks": [
            {
              "name": "Touch",
              "kind": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 2, "diceSides": 6, "modifier": 3 },
              "damageType": "fire"
            }
          ]
        }
      },
      {
        "name": "Immutable Elemental",
        "position": { "x": 13, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 14,
            "constitution": 16,
            "intelligence": 6,
            "wisdom": 10,
            "charisma": 7
          },
          "maxHp": 102,
          "hp": 102,
          "armorClass": 5,
          "speed": 50,
          "challengeRating": 5,
          "experienceValue": 1800,
          "damageResistances": ["bludgeoning"],
          "damageImmunities": ["bludgeoning", "fire", "poison"],
          "damageVulnerabilities": ["bludgeoning"],
          "attacks": [
            {
              "name": "Touch",
              "kind": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 2, "diceSides": 6, "modifier": 3 },
              "damageType": "fire"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the Fire Elemental" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      },
      "comment": "Start combat"
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "expect": {
        "combatStarted": true
      },
      "comment": "Initiative roll resolves. Character goes first."
    },
    {
      "type": "action",
      "input": { "text": "I attack the Fire Elemental with my warhammer" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      },
      "comment": "Declare attack with warhammer (bludgeoning damage type)"
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "expect": {
        "hit": true,
        "isCritical": false,
        "requiresPlayerInput": true
      },
      "comment": "Attack roll 18 + 6 = 24 → hits AC 5. Prompt for damage."
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "Damage roll 6 + modifier 3 = 9 raw bludgeoning → resisted to floor(9/2) = 4. HP: 102 → 98"
    },
    {
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Fire Elemental", "exact": 98 },
        "characterHp": { "min": 42, "max": 42 }
      },
      "comment": "Verify bludgeoning resistance: 9 raw → 4 after resistance (floor(9/2))"
    },
    {
      "type": "endTurn",
      "comment": "End turn so the next deterministic check uses a fresh Attack action."
    },
    {
      "type": "waitForTurn",
      "comment": "AI is scripted to end turns, so no incoming damage alters deterministic HP assertions."
    },
    {
      "type": "action",
      "input": { "text": "I attack the Flux Elemental with my warhammer" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      },
      "comment": "Resistance + vulnerability on bludgeoning should cancel to normal damage."
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 17" },
      "expect": {
        "hit": true,
        "isCritical": false,
        "requiresPlayerInput": true
      },
      "comment": "Attack roll hits AC 5."
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "Damage roll 6 + modifier 3 = 9 raw bludgeoning. Resistance and vulnerability cancel, so final damage stays 9. HP: 102 → 93"
    },
    {
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Flux Elemental", "exact": 93 },
        "characterHp": { "min": 42, "max": 42 }
      },
      "comment": "Verify cancel rule: resistance + vulnerability on same type results in normal damage."
    },
    {
      "type": "endTurn",
      "comment": "End turn before immunity precedence check."
    },
    {
      "type": "waitForTurn",
      "comment": "Return to Frost Knight turn with deterministic state unchanged."
    },
    {
      "type": "action",
      "input": { "text": "I attack the Immutable Elemental with my warhammer" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      },
      "comment": "Immunity should take precedence over vulnerability and resistance on the same damage type."
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 16" },
      "expect": {
        "hit": true,
        "isCritical": false,
        "requiresPlayerInput": true
      },
      "comment": "Attack roll hits AC 5."
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "Damage roll 6 + modifier 3 = 9 raw bludgeoning, but immunity precedence reduces final damage to 0. HP remains 102."
    },
    {
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Immutable Elemental", "exact": 102 },
        "characterHp": { "min": 42, "max": 42 }
      },
      "comment": "Verify immunity precedence over resistance and vulnerability per 2024 rules target."
    }
  ]
}
