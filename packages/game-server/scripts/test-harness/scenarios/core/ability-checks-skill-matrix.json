    ],
    "monsters": [
      {
        "name": "Watch Captain",
        "position": { "x": 20, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 12,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 20,
            "charisma": 10
          },
          "maxHp": 60,
          "hp": 60,
          "armorClass": 16,
          "speed": 30,
          "passivePerception": 16,
          "challengeRating": 3,
          "experienceValue": 700,
          "attacks": [
            {
              "name": "Spear",
              "kind": "melee",
              "attackBonus": 5,
