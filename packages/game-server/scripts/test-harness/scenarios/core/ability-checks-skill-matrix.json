            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Pip Halfstep",
      "comment": "Begin encounter from the half-proficiency actor to anchor deterministic turn flow.",
      "input": { "text": "I size up the watcher" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "actor": "Pip Halfstep",
      "comment": "High initiative to begin the matrix sequence cleanly.",
      "input": { "text": "19" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "setTerrain",
      "comment": "Place half cover between party and observer so Hide is legal and contested by Perception.",
      "input": {
        "terrainZones": [
          { "x": 15, "y": 10, "terrain": "cover-half" }
        ]
      }
    },
    {
      "type": "action",
      "actor": "Pip Halfstep",
      "comment": "Half-proficiency Stealth (+3) attempts to hide vs passive Perception 20.",
      "input": { "text": "hide" },
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Hide"
      }
    },
    {
      "type": "assertState",
      "actor": "Pip Halfstep",
      "comment": "Guaranteed-fail branch: low Stealth cannot beat passive 16, so actor remains visible.",
      "expect": {
        "characterConditions": {
          "doesNotHaveConditions": ["Hidden"]
        },
        "characterPosition": { "x": 10, "y": 10 }
      }
    },
    {
      "type": "endTurn",
      "actor": "Pip Halfstep",
      "comment": "Pass turn to next matrix actor."
    },
    {
      "type": "waitForTurn",
      "actor": "Tarin Scout",
      "comment": "Advance to proficient actor's turn."
    },
    {
      "type": "action",
      "actor": "Tarin Scout",
      "comment": "Proficiency Stealth (+5) attempts same hide check vs same observer.",
      "input": { "text": "hide" },
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Hide"
      }
    },
    {
      "type": "assertState",
      "actor": "Tarin Scout",
      "comment": "Guaranteed-success branch: Stealth floor beats passive 16, so actor is Hidden.",
      "expect": {
        "characterConditions": {
          "hasConditions": ["Hidden"]
        },
        "characterPosition": { "x": 11, "y": 10 }
      }
    },
    {
      "type": "endTurn",
      "actor": "Tarin Scout",
      "comment": "Pass turn to expertise actor."
    },
    {
      "type": "waitForTurn",
      "actor": "Nyx Expert",
      "comment": "Advance to expertise actor's turn."
    },
    {
      "type": "action",
      "actor": "Nyx Expert",
      "comment": "Expertise Stealth (+8) attempts same hide check vs same observer.",
      "input": { "text": "hide" },
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Hide"
      }
    },
    {
      "type": "assertState",
      "actor": "Nyx Expert",
      "comment": "Guaranteed-success branch: high Stealth floor beats passive 16, so actor is Hidden.",
      "expect": {
        "characterConditions": {
          "hasConditions": ["Hidden"]
        },
        "characterPosition": { "x": 12, "y": 10 }
      }
    },
    {
      "type": "action",
      "actor": "Nyx Expert",
      "comment": "Use Search to confirm check-driven utility action runs in same live flow after hide resolution.",
      "input": { "text": "search" },
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Search"
      }
    }
  ]
}
