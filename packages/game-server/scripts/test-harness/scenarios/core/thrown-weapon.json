{
  "name": "Thrown: Javelin thrown at distant target",
  "description": "A Fighter with a Javelin (melee, Thrown range 30/120) throws it at a Goblin 25ft away. This tests explicit throw intent with correct range handling and damage resolution.",
  "setup": {
    "character": {
      "name": "Ajax",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 5, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 12,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Javelin",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "piercing",
            "properties": ["Thrown (Range 30/120)"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 30, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 21,
          "hp": 21,
          "armorClass": 15,
          "speed": 30,
          "attacks": [
            {
              "name": "Shortbow",
              "kind": "ranged",
              "range": "80/320",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 }
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for combat" },
      "expect": {
        "rollType": "initiative"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "throw javelin at Goblin Scout" },
      "comment": "Thrown attack at 25ft — within normal range (30ft). Should resolve as ranged attack.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 6 = 21 vs AC 15 → hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "4" },
      "comment": "4 + 3 = 7 damage (1d6+3)",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Goblin took 7 damage: 21 - 7 = 14 HP",
      "expect": {
        "monsterHp": { "name": "Goblin Scout", "min": 14, "max": 14 }
      }
    }
  ]
}
