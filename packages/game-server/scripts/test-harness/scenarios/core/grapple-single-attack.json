{
  "name": "Grapple Single Attack: L3 Fighter grapple consumes full action",
  "description": "A Level 3 Fighter (no Extra Attack) grapples a Goblin via the tabletop dice flow. The grapple should consume the full action (1 of 1 attack). Validates backward compatibility: characters without Extra Attack cannot attack after grappling.",
  "setup": {
    "character": {
      "name": "Young Fighter",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 20,
          "dexterity": 12,
          "constitution": 14,
          "intelligence": 8,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 28,
        "currentHp": 28,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 5 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Victim",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 10,
          "speed": 30,
          "size": "Small",
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High roll so player goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "grapple Goblin Victim" },
      "comment": "Tabletop dice flow: Unarmed Strike STR +5, prof +2 = +7 vs AC 10. Contest DC 15.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 7 = 22 vs AC 10 → HIT. Server auto-resolves save: target DEX +2 vs DC 15 → fail. Grappled! L3 = 1 of 1 attack used.",
      "expect": {
        "hit": true,
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify Goblin has Grappled condition",
      "expect": {
        "monsterConditions": {
          "name": "Goblin Victim",
          "hasConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Goblin Victim" },
      "comment": "Attempt a 2nd attack — should FAIL because L3 Fighter has no Extra Attack (1 attack already used).",
      "expect": {
        "error": true,
        "errorContains": "already spent"
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn — action fully consumed by grapple (no Extra Attack at L3)."
    }
  ]
}
