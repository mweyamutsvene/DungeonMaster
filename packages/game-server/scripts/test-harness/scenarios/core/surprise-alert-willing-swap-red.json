{
  "name": "Surprise + Alert: only willing allies can swap initiative",
  "description": "Party is surprised (initiative disadvantage). Alert holder gets a swap offer, but unconscious allies are excluded from eligible targets and swap attempts to them are rejected.",
  "setup": {
    "characters": [
      {
        "name": "Vanguard",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 16,
            "dexterity": 14,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 12,
            "charisma": 10
          },
          "maxHp": 44,
          "currentHp": 44,
          "armorClass": 17,
          "speed": 30,
          "proficiencyBonus": 3,
          "featIds": ["feat_alert"],
          "attacks": [
            {
              "name": "Longsword",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      },
      {
        "name": "Ready Ally",
        "className": "Rogue",
        "level": 5,
        "position": { "x": 4, "y": 6 },
        "sheet": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 16,
            "constitution": 12,
            "intelligence": 12,
            "wisdom": 12,
            "charisma": 10
          },
          "maxHp": 34,
          "currentHp": 34,
          "armorClass": 15,
          "speed": 30,
          "proficiencyBonus": 3,
          "attacks": [
            {
              "name": "Dagger",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 3 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Fallen Ally",
        "className": "Wizard",
        "level": 5,
        "position": { "x": 4, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 10,
            "constitution": 12,
            "intelligence": 16,
            "wisdom": 12,
            "charisma": 10
          },
          "maxHp": 30,
          "currentHp": 30,
          "armorClass": 12,
          "speed": 30,
          "proficiencyBonus": 3,
          "conditions": ["Unconscious"],
          "attacks": [
            {
              "name": "Quarterstaff",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 2,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Raider",
        "position": { "x": 10, "y": 5 },
        "statBlock": {
          "abilityScores": {
            "strength": 14,
            "dexterity": 12,
            "constitution": 12,
            "intelligence": 8,
            "wisdom": 10,
            "charisma": 8
          },
          "maxHp": 27,
          "hp": 27,
          "armorClass": 13,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "setSurprise",
      "comment": "Party is surprised; Vanguard should roll initiative at disadvantage.",
      "input": { "surprise": "party" }
    },
    {
      "type": "queueDiceRolls",
      "comment": "Deterministic auto-initiative rolls: Ready Ally disadvantage (12,2 -> 2), Fallen Ally disadvantage (11,3 -> 3), Raider normal (17).",
      "input": { "values": [12, 2, 11, 3, 17], "label": "initiative auto-rolls" }
    },
    {
      "type": "initiate",
      "actor": "Vanguard",
      "comment": "Initiate combat while surprised; expect disadvantage roll prompt.",
      "input": { "text": "roll initiative" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true, "disadvantage": true }
    },
    {
      "type": "rollResult",
      "actor": "Vanguard",
      "comment": "Vanguard initiative: 14 + DEX 2 + Alert PB 3 = 19. Swap offer should appear because Ready Ally is willing.",
      "input": { "text": "14" },
      "expect": { "combatStarted": true, "initiativeSwapOffer": true }
    },
    {
      "type": "rollResult",
      "actor": "Vanguard",
      "comment": "Attempting to swap with unconscious ally should be rejected.",
      "input": { "text": "swap with Fallen Ally" },
      "expect": { "error": true, "errorContains": "No eligible swap target named" }
    },
    {
      "type": "rollResult",
      "actor": "Vanguard",
      "comment": "Decline swap and keep initiative.",
      "input": { "text": "no swap" },
      "expect": { "combatStarted": true, "currentTurnActor": "Vanguard" }
    },
    {
      "type": "action",
      "actor": "Vanguard",
      "comment": "Vanguard still has the turn and receives an attack roll prompt.",
      "input": { "text": "attack Raider with Longsword" },
      "expect": { "rollType": "attack" }
    }
  ]
}
