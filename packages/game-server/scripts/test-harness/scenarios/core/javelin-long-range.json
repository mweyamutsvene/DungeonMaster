{
  "name": "B5: Javelin Thrown at Long Range with Disadvantage",
  "description": "A Fighter throws a Javelin at a target at 35ft (beyond normal 30ft range, within long 120ft range). The attack should succeed with disadvantage per D&D 5e 2024 range rules. Also tests that an attack at normal range (30ft) does NOT have disadvantage.",
  "setup": {
    "character": {
      "name": "Javelin Jane",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16, "dexterity": 14, "constitution": 14,
          "intelligence": 10, "wisdom": 10, "charisma": 10
        },
        "maxHp": 28, "currentHp": 28, "armorClass": 18, "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Javelin", "kind": "melee", "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "piercing",
            "properties": ["thrown"]
          },
          {
            "name": "Longsword", "kind": "melee", "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Distant Goblin",
        "position": { "x": 45, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 10,
            "intelligence": 10, "wisdom": 8, "charisma": 8
          },
          "maxHp": 50, "hp": 50, "armorClass": 15, "speed": 30,
          "challengeRating": 0.25, "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar", "kind": "melee", "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I throw my javelin" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High init to go first. Fighter at (10,10) is 35ft from Goblin at (45,10).",
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Throw javelin at 35ft (beyond 30ft normal range, within 120ft long range) — should succeed with disadvantage",
      "type": "action",
      "input": { "text": "throw javelin at distant goblin" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true, "disadvantage": true }
    },
    {
      "comment": "Roll 15 + 5 = 20 vs AC 15 → HIT (even with disadvantage, roll is high)",
      "type": "rollResult",
      "input": { "text": "15" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Damage roll",
      "type": "rollResult",
      "input": { "text": "4" },
      "expect": { "actionComplete": true }
    },
    {
      "comment": "Verify goblin took damage",
      "type": "assertState",
      "expect": { "monsterHp": { "name": "Distant Goblin", "max": 49 } }
    }
  ]
}
