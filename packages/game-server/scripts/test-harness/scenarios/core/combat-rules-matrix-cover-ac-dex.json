{
  "name": "CombatRules Matrix: Cover AC + Dex Save",
  "description": "Deterministic matrix validating half-cover AC impact on attack rolls and cover interaction during Dex-save spell resolution.",
  "setup": {
    "characters": [
      {
        "name": "Archer Matrix",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 16,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 12,
            "charisma": 8
          },
          "maxHp": 44,
          "currentHp": 44,
          "armorClass": 16,
          "speed": 30,
          "proficiencyBonus": 3,
          "attacks": [
            {
              "name": "Longbow",
              "kind": "ranged",
              "range": "150/600",
              "attackBonus": 7,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Wizard Matrix",
        "className": "Wizard",
        "level": 5,
        "position": { "x": 5, "y": 12 },
        "sheet": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 14,
            "intelligence": 18,
            "wisdom": 12,
            "charisma": 10
          },
          "maxHp": 32,
          "currentHp": 32,
          "armorClass": 12,
          "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "intelligence",
          "spellSaveDC": 14,
          "spellAttackBonus": 7,
          "spellSlots": { "1": 4, "2": 3, "3": 2 },
          "preparedSpells": [
            { "name": "Burning Hands", "level": 1 }
          ],
          "attacks": [
            {
              "name": "Quarterstaff",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 1,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Cover Goblin",
        "position": { "x": 20, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 16,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 13,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Archer Matrix",
      "input": { "text": "I prepare my bow" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Archer Matrix",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "setTerrain",
      "comment": "Half-cover tile between PCs and target.",
      "input": {
        "terrainZones": [
          { "x": 15, "y": 10, "terrain": "cover-half" }
        ]
      }
    },

    {
      "type": "waitForTurn",
      "actor": "Archer Matrix",
      "comment": "Archer turn: verify AC bonus impact through a near-threshold attack.",
      "timeout": 10000
    },
    {
      "type": "action",
      "actor": "Archer Matrix",
      "input": { "text": "shoot Cover Goblin with longbow" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Archer Matrix",
      "input": { "text": "7" },
      "comment": "7 + 7 = 14. Base AC 13 would hit; half-cover AC 15 should cause miss.",
      "expect": { "hit": false, "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Checkpoint: no damage landed on cover-protected target.",
      "expect": {
        "monsterHp": { "name": "Cover Goblin", "exact": 30 }
      }
    },
    {
      "type": "endTurn",
      "actor": "Archer Matrix"
    },

    {
      "type": "waitForTurn",
      "actor": "Wizard Matrix",
      "comment": "Wizard turn: cast Dex-save spell through same cover line.",
      "timeout": 10000
    },
    {
      "type": "action",
      "actor": "Wizard Matrix",
      "input": { "text": "cast Burning Hands at Cover Goblin" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Checkpoint: spell slot consumed and HP changed in a bounded deterministic range.",
      "actor": "Wizard Matrix",
      "expect": {
        "characterResource": { "poolName": "spellSlot_1", "current": 3, "max": 4 },
        "monsterHp": { "name": "Cover Goblin", "min": 21, "max": 29 }
      }
    }
  ]
}
