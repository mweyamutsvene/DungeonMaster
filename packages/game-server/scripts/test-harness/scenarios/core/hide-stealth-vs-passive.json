{
  "name": "Hide: Cover present but passive Perception prevents Hidden",
  "description": "Regression test for Hide rework. A rogue attempts Hide with cover, but an observer with very high passive Perception should still notice them. This scenario should fail on legacy behavior that grants Hidden without passive-perception contest.",
  "setup": {
    "character": {
      "name": "Shade",
      "className": "Rogue",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 10,
          "constitution": 14,
          "intelligence": 12,
          "wisdom": 12,
          "charisma": 12
        },
        "maxHp": 34,
        "currentHp": 34,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 3,
        "skills": {
          "stealth": 0
        },
        "attacks": [
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "piercing"
          }
        ],
        "features": [
          { "name": "Cunning Action", "description": "Dash, Disengage, or Hide as a bonus action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Keen-Eyed Sentinel",
        "position": { "x": 20, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 12,
            "dexterity": 12,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 20,
            "charisma": 8
          },
          "maxHp": 35,
          "hp": 35,
          "armorClass": 15,
          "speed": 30,
          "passivePerception": 20,
          "challengeRating": 2,
          "experienceValue": 450,
          "attacks": [
            {
              "name": "Spear",
              "kind": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare to vanish" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 15, "y": 10, "terrain": "cover-half" }
        ]
      },
      "comment": "Half cover exists between rogue and sentinel, so hide is allowed but still contested by passive Perception."
    },
    {
      "type": "action",
      "input": { "text": "hide" },
      "comment": "Stealth should fail to beat passive Perception 20, so Hidden must not be applied.",
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Hide"
      }
    },
    {
      "type": "assertState",
      "comment": "Strong regression assertion: failing hide attempt must not apply Hidden condition.",
      "expect": {
        "characterConditions": {
          "doesNotHaveConditions": ["Hidden"]
        }
      }
    }
  ]
}
