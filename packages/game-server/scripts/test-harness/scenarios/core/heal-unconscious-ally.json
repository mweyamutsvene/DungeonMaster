{
  "name": "Multi-PC: Heal Unconscious Ally",
  "description": "Two PCs fight a goblin. Valeria (Fighter, 3 HP) gets KO'd by the goblin. Brother Aldric (Cleric) casts Cure Wounds to revive her. Tests multi-PC initiative, cross-PC healing, revival from 0 HP.",
  "setup": {
    "characters": [
      {
        "name": "Valeria",
        "className": "Fighter",
        "level": 3,
        "position": { "x": 10, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 16, "dexterity": 14, "constitution": 14,
            "intelligence": 10, "wisdom": 12, "charisma": 8
          },
          "maxHp": 28, "currentHp": 3, "armorClass": 8, "speed": 30,
          "proficiencyBonus": 2,
          "attacks": [
            {
              "name": "Longsword", "kind": "melee", "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      },
      {
        "name": "Brother Aldric",
        "className": "Cleric",
        "level": 3,
        "position": { "x": 8, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 14, "dexterity": 10, "constitution": 14,
            "intelligence": 10, "wisdom": 18, "charisma": 12
          },
          "maxHp": 24, "currentHp": 24, "armorClass": 16, "speed": 30,
          "proficiencyBonus": 2,
          "spellcastingAbility": "wisdom",
          "spellSaveDC": 14,
          "spellAttackBonus": 6,
          "spellSlots": { "1": 4, "2": 2 },
          "preparedSpells": [
            { "name": "Cure Wounds", "level": 1 },
            { "name": "Healing Word", "level": 1 }
          ],
          "attacks": [
            {
              "name": "Mace", "kind": "melee", "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Goblin Brute",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 14, "dexterity": 14, "constitution": 12,
            "intelligence": 8, "wisdom": 8, "charisma": 8
          },
          "maxHp": 50, "hp": 50, "armorClass": 13, "speed": 30,
          "challengeRating": 1, "experienceValue": 200,
          "attacks": [
            {
              "name": "Greatclub", "kind": "melee", "attackBonus": 8,
              "damage": { "diceCount": 2, "diceSides": 8, "modifier": 4 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "attack"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Brother Aldric",
      "input": { "text": "We stand against the goblin!" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true },
      "comment": "Aldric (Cleric) initiates — he rolls initiative"
    },
    {
      "type": "rollResult",
      "actor": "Brother Aldric",
      "input": { "text": "1" },
      "comment": "Very low initiative (1+0 DEX=1) so Aldric goes last. Valeria auto-rolls. Goblin auto-rolls. Expected order: Valeria > Goblin > Aldric.",
      "expect": { "combatStarted": true }
    },
    {
      "type": "endTurn",
      "actor": "Valeria",
      "comment": "Valeria goes first (highest init via auto-roll). She ends turn immediately."
    },
    {
      "type": "waitForTurn",
      "actor": "Brother Aldric",
      "comment": "Wait through goblin's turn. Goblin attacks Valeria (highest init = first in enemies list). With 3 HP, AC 8, goblin +8 attack / 2d8+4 damage → guaranteed KO."
    },
    {
      "type": "assertState",
      "actor": "Valeria",
      "comment": "Valeria should be knocked unconscious",
      "expect": {
        "characterHp": { "min": 0, "max": 0 },
        "characterConditions": {
          "hasConditions": ["unconscious"]
        }
      }
    },
    {
      "type": "action",
      "actor": "Brother Aldric",
      "input": { "text": "cast Cure Wounds on Valeria" },
      "comment": "Cleric casts Cure Wounds on the unconscious Fighter (2d8 + 4 WIS mod)",
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "CastSpell"
      }
    },
    {
      "type": "assertState",
      "actor": "Valeria",
      "comment": "Valeria should be revived with HP > 0 and no Unconscious condition",
      "expect": {
        "characterHp": { "min": 1, "max": 28 },
        "characterConditions": {
          "doesNotHaveConditions": ["unconscious"]
        }
      }
    },
    {
      "type": "endTurn",
      "actor": "Brother Aldric"
    }
  ]
}
