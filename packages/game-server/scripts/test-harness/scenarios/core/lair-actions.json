{
  "name": "Lair Actions: Boss triggers lair action during combat round",
  "description": "A Fighter fights a boss monster in its lair. Lair actions trigger once per round during AI processing, dealing save-based damage to enemy combatants. Tests that processLairActionsIfNeeded resolves lair action damage correctly.",
  "setup": {
    "character": {
      "name": "Delver Thane",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 15, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Greatsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 2, "diceSides": 6, "modifier": 4 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Cave Wyrm",
        "position": { "x": 10, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 18,
            "dexterity": 10,
            "constitution": 16,
            "intelligence": 6,
            "wisdom": 10,
            "charisma": 8
          },
          "maxHp": 68,
          "hp": 68,
          "armorClass": 15,
          "speed": 30,
          "challengeRating": 4,
          "experienceValue": 1100,
          "attacks": [
            {
              "name": "Bite",
              "kind": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 2, "diceSides": 6, "modifier": 4 },
              "damageType": "piercing"
            }
          ],
          "isInLair": true,
          "lairActions": [
            {
              "name": "Tremor",
              "description": "The ground shakes violently. Each creature must succeed on a DC 13 Dexterity saving throw or take 2d6 bludgeoning damage.",
              "saveDC": 13,
              "saveAbility": "dexterity",
              "damage": "2d6",
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "attack"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the wyrm!" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative so player goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "assertState",
      "comment": "Player starts at full HP before any lair action",
      "expect": {
        "characterHp": { "min": 44, "max": 44 }
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Cave Wyrm with my greatsword" },
      "comment": "Player at (15,10), wyrm at (10,10) - 5ft melee range",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 14" },
      "comment": "14 + 7 = 21 vs AC 15 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 8" },
      "comment": "8 + 4 = 12 damage (greatsword 2d6+4). Wyrm at 56 HP.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Cave Wyrm with my greatsword" },
      "comment": "Extra Attack at level 5 - second attack",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 12" },
      "comment": "12 + 7 = 19 vs AC 15 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "6 + 4 = 10 damage. Wyrm now at 46 HP.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End player turn — lair action should trigger (Tremor: DC 13 DEX save, 2d6 bludgeoning on fail, half on success) and then wyrm takes its normal AI turn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for lair action + wyrm's AI turn to complete",
      "timeout": 10000
    },
    {
      "type": "assertState",
      "comment": "Player should have taken damage from the lair action (2d6 = 2-12, half on save = 1-6). Also possibly from wyrm's normal attack. HP should be below starting 44.",
      "expect": {
        "characterHp": { "min": 0, "max": 43 },
        "combatStatus": "Active"
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Cave Wyrm with my greatsword" },
      "comment": "Round 2 - continue attacking",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 16" },
      "comment": "16 + 7 = 23 vs AC 15 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 10" },
      "comment": "10 + 4 = 14 damage. Wyrm at ~32 HP.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Cave Wyrm with my greatsword" },
      "comment": "Extra Attack - second hit",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "comment": "15 + 7 = 22 vs AC 15 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 9" },
      "comment": "9 + 4 = 13 damage. Wyrm at ~19 HP.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn",
      "comment": "End turn — lair action should trigger AGAIN this round (once per round), then wyrm's turn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for round 2 lair action + AI turn",
      "timeout": 10000
    },
    {
      "type": "action",
      "input": { "text": "I attack the Cave Wyrm with my greatsword" },
      "comment": "Round 3 - finish it off",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "18 + 7 = 25 vs AC 15 - hit!",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 11" },
      "comment": "11 + 4 = 15 damage - should kill the wyrm (total ~64 damage on 68 HP boss)",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Wyrm should be dead or nearly dead",
      "expect": {
        "monsterHp": { "name": "Cave Wyrm", "min": 0, "max": 5 }
      }
    }
  ]
}
