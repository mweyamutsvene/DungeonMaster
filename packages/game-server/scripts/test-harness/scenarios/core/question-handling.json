{
  "name": "Question Handling: LLM Intent Classification",
  "description": "Tests that the LLM correctly classifies different types of questions into the appropriate query subjects (hp, weapons, spells, features, stats, equipment, tactical, environment).",
  "setup": {
    "character": {
      "name": "Lyra Questioner",
      "className": "Wizard",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 18,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 32,
        "currentHp": 32,
        "armorClass": 12,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Quarterstaff",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 1,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ],
        "features": [
          { "name": "Arcane Recovery", "description": "Recover spell slots on short rest" },
          { "name": "Evocation Savant", "description": "Copy evocation spells at half cost" }
        ],
        "spells": [
          { "name": "Fire Bolt", "level": 0 },
          { "name": "Magic Missile", "level": 1 },
          { "name": "Shield", "level": 1 },
          { "name": "Fireball", "level": 3 }
        ],
        "equipment": [
          { "name": "Spellbook" },
          { "name": "Component Pouch" },
          { "name": "Scholar's Pack" },
          { "name": "Wand of the War Mage +1" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Target Dummy",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 1,
            "wisdom": 1,
            "charisma": 1
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 5,
          "speed": 0,
          "attacks": []
        }
      }
    ]
  },
  "actions": [
    {
      "type": "query",
      "input": { "text": "What's my HP?" },
      "comment": "HP question should classify as 'hp' subject",
      "expect": {
        "isQuery": true,
        "subject": "hp"
      }
    },
    {
      "type": "query",
      "input": { "text": "What weapons do I have?" },
      "comment": "Weapons question should classify as 'weapons' subject",
      "expect": {
        "isQuery": true,
        "subject": "weapons"
      }
    },
    {
      "type": "query",
      "input": { "text": "What spells do I know?" },
      "comment": "Spells question should classify as 'spells' subject",
      "expect": {
        "isQuery": true,
        "subject": "spells"
      }
    },
    {
      "type": "query",
      "input": { "text": "What class features do I have?" },
      "comment": "Features question should classify as 'features' subject",
      "expect": {
        "isQuery": true,
        "subject": "features"
      }
    },
    {
      "type": "query",
      "input": { "text": "What are my ability scores?" },
      "comment": "Stats question should classify as 'stats' subject",
      "expect": {
        "isQuery": true,
        "subject": "stats"
      }
    },
    {
      "type": "query",
      "input": { "text": "What items am I carrying?" },
      "comment": "Equipment question should classify as 'equipment' subject",
      "expect": {
        "isQuery": true,
        "subject": "equipment"
      }
    },
    {
      "type": "query",
      "input": { "text": "What's my armor class?" },
      "comment": "AC question should classify as 'ac' subject",
      "expect": {
        "isQuery": true,
        "subject": "ac"
      }
    },
    {
      "type": "query",
      "input": { "text": "Which enemy is closest to me?" },
      "comment": "Positioning question should classify as 'tactical' subject",
      "expect": {
        "isQuery": true,
        "subject": "tactical"
      }
    },
    {
      "type": "query",
      "input": { "text": "Is there any cover nearby?" },
      "comment": "Environment question should classify as 'environment' subject",
      "expect": {
        "isQuery": true,
        "subject": "environment"
      }
    },
    {
      "type": "query",
      "input": { "text": "What can I do on my turn?" },
      "comment": "Actions question should classify as 'actions' subject",
      "expect": {
        "isQuery": true,
        "subject": "actions"
      }
    }
  ]
}
