{
  "name": "Queued Monster Actions: Scripted Enemy Turn",
  "description": "Tests the queueMonsterActions feature by scripting exact enemy decisions. The goblin is queued to move toward the fighter, then attack with its scimitar, reproducing a specific action sequence.",
  "setup": {
    "character": {
      "name": "Thorin Ironfist",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Warrior",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 15,
          "speed": 30,
          "challengeRating": 0.25,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the goblin" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "move to (35, 10)" },
      "comment": "Move close to goblin",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "I attack the Goblin Warrior with my sword" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 6" },
      "comment": "9 damage (6+3) to goblin — leaves it at 41 HP (50-9)"
    },
    {
      "type": "queueMonsterActions",
      "comment": "Script the goblin's turn: move to (36,10) then attack Thorin",
      "input": {
        "decisions": [
          {
            "action": "moveToward",
            "target": "Thorin Ironfist",
            "desiredRange": 5,
            "endTurn": false
          },
          {
            "action": "attack",
            "target": "Thorin Ironfist",
            "attackName": "Scimitar",
            "endTurn": true
          }
        ]
      }
    },
    {
      "type": "endTurn",
      "comment": "End player turn — goblin uses queued decisions"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for the goblin to execute its queued actions and for player turn to come back"
    },
    {
      "type": "assertState",
      "expect": {
        "combatStatus": "Active",
        "monstersAlive": 1,
        "characterHp": { "min": 1, "max": 42 }
      }
    }
  ]
}
