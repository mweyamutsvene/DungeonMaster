{
  "name": "Grapple Tabletop Miss: Attack misses, no save step",
  "description": "Tests that when a grapple attack roll MISSES the target's AC, no saving throw occurs and the attack slot is consumed. The grapple simply fails on a miss — no contest resolution.",
  "setup": {
    "character": {
      "name": "Weak Grappler",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 14,
          "dexterity": 10,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 14,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 2 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Armored Hobgoblin",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 13,
            "dexterity": 12,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 9
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 18,
          "speed": 30,
          "challengeRating": 0.5,
          "experienceValue": 100,
          "attacks": [
            {
              "name": "Longsword",
              "kind": "melee",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 1 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High roll so player goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "grapple Armored Hobgoblin" },
      "comment": "Tabletop dice flow: Unarmed Strike STR +2, prof +3 = +5 vs AC 18. Contest DC 13 (8 + 2 + 3). High AC makes miss likely.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 5 = 10 vs AC 18 → MISS. No saving throw step occurs. Attack slot consumed, grapple fails.",
      "expect": {
        "hit": false,
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Verify the Hobgoblin does NOT have Grappled condition (grapple missed)",
      "expect": {
        "monsterConditions": {
          "name": "Armored Hobgoblin",
          "doesNotHaveConditions": ["Grappled"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Armored Hobgoblin" },
      "comment": "2nd attack (Extra Attack) — should still be allowed after missed grapple. canMakeAttack() permits it.",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "18 + 5 = 23 vs AC 18 — hit!",
      "expect": {
        "hit": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" },
      "comment": "1d8 + 2 = 8 damage",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "endTurn"
    }
  ]
}
