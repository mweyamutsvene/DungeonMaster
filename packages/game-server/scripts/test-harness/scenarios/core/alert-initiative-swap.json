{
  "name": "Alert Feat: Initiative Swap (D&D 5e 2024)",
  "description": "A Fighter with Alert starts combat while the party is surprised. Alert prevents initiative disadvantage for Scout, while allies still roll at disadvantage. Scout receives an initiative swap offer, invalid swap targets are rejected deterministically, and a valid swap updates turn order.",
  "setup": {
    "characters": [
      {
        "name": "Scout",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 10, "dexterity": 16, "constitution": 12,
            "intelligence": 10, "wisdom": 14, "charisma": 8
          },
          "maxHp": 38, "currentHp": 38, "armorClass": 15, "speed": 30,
          "proficiencyBonus": 3,
          "featIds": ["feat_alert"],
          "attacks": [
            {
              "name": "Shortbow", "kind": "ranged", "range": "80/320",
              "attackBonus": 6,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Tank",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 18, "dexterity": 8, "constitution": 16,
            "intelligence": 10, "wisdom": 12, "charisma": 10
          },
          "maxHp": 44, "currentHp": 44, "armorClass": 18, "speed": 30,
          "proficiencyBonus": 3,
          "attacks": [
            {
              "name": "Longsword", "kind": "melee", "range": "melee",
              "attackBonus": 7,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
              "damageType": "slashing"
            }
          ]
        }
      },
      {
        "name": "Fallen Ally",
        "className": "Wizard",
        "level": 5,
        "position": { "x": 4, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 8, "dexterity": 10, "constitution": 12,
            "intelligence": 16, "wisdom": 12, "charisma": 10
          },
          "maxHp": 30, "currentHp": 30, "armorClass": 12, "speed": 30,
          "proficiencyBonus": 3,
          "conditions": ["Unconscious"],
          "attacks": [
            {
              "name": "Quarterstaff", "kind": "melee", "range": "melee",
              "attackBonus": 2,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Orc Warrior",
        "position": { "x": 10, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 16, "dexterity": 12, "constitution": 16,
            "intelligence": 7, "wisdom": 11, "charisma": 10
          },
          "maxHp": 30, "hp": 30, "armorClass": 13, "speed": 30,
          "attacks": [
            {
              "name": "Greataxe", "kind": "melee", "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 12, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "setSurprise",
      "comment": "Mixed surprise state: Tank and Fallen Ally are surprised, Scout is not. This validates no-surprise behavior for the Alert holder in a mixed party.",
      "input": { "surprise": { "surprised": ["Tank", "Fallen Ally"] } }
    },
    {
      "type": "queueDiceRolls",
      "comment": "Deterministic auto-initiative rolls: Tank disadvantage (13,2 -> 2), Fallen Ally disadvantage (11,3 -> 3), Orc normal (17).",
      "input": { "values": [13, 2, 11, 3, 17], "label": "initiative auto-rolls" }
    },
    {
      "type": "initiate",
      "actor": "Scout",
      "input": { "text": "roll initiative" },
      "comment": "Scout (Alert) initiates while party is surprised; Scout should NOT roll initiative with disadvantage.",
      "expect": { "rollType": "initiative", "requiresPlayerInput": true, "disadvantage": false }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "15" },
      "comment": "Scout rolls 15 (15 + 3 DEX + 3 PB Alert = 21). Swap offer should appear.",
      "expect": { "combatStarted": true, "initiativeSwapOffer": true }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "swap with Orc Warrior" },
      "comment": "Invalid swap target: enemy is not an eligible ally target.",
      "expect": { "error": true, "errorContains": "No eligible swap target named" }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "swap with Fallen Ally" },
      "comment": "Invalid swap target: unconscious ally is not willing/eligible.",
      "expect": { "error": true, "errorContains": "No eligible swap target named" }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "swap with Tank" },
      "comment": "Valid swap with Tank succeeds; Tank takes current turn due swapped top initiative.",
      "expect": { "combatStarted": true, "currentTurnActor": "Tank" }
    },
    {
      "type": "assertState",
      "actor": "Scout",
      "comment": "Scout should not have surprised condition and combat should be active.",
      "expect": {
        "characterConditions": { "doesNotHaveConditions": ["Surprised"] },
        "combatStatus": "Active"
      }
    },
    {
      "type": "endTurn",
      "actor": "Tank",
      "comment": "After swapped Tank turn ends, the next combatant should be Orc Warrior based on deterministic initiative order.",
      "expect": { "nextCombatant": "Orc Warrior" }
    },
    {
      "type": "assertState",
      "comment": "Combat remains active after the swapped first turn ends.",
      "expect": { "combatStatus": "Active" }
    }
  ]
}
