{
  "name": "Alert Feat: Initiative Swap (D&D 5e 2024)",
  "description": "A Fighter with the Alert feat rolls initiative in a multi-PC party. After initiative is rolled, the server offers an initiative swap with a willing ally. The Scout swaps initiative with the Tank, changing the turn order. Tests: Alert feat swap offer, swap execution, updated turn order.",
  "setup": {
    "characters": [
      {
        "name": "Scout",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 10, "dexterity": 16, "constitution": 12,
            "intelligence": 10, "wisdom": 14, "charisma": 8
          },
          "maxHp": 38, "currentHp": 38, "armorClass": 15, "speed": 30,
          "proficiencyBonus": 3,
          "featIds": ["feat_alert"],
          "attacks": [
            {
              "name": "Shortbow", "kind": "ranged", "range": "80/320",
              "attackBonus": 6,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Tank",
        "className": "Fighter",
        "level": 5,
        "position": { "x": 5, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 18, "dexterity": 8, "constitution": 16,
            "intelligence": 10, "wisdom": 12, "charisma": 10
          },
          "maxHp": 44, "currentHp": 44, "armorClass": 18, "speed": 30,
          "proficiencyBonus": 3,
          "attacks": [
            {
              "name": "Longsword", "kind": "melee", "range": "melee",
              "attackBonus": 7,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Orc Warrior",
        "position": { "x": 10, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 16, "dexterity": 12, "constitution": 16,
            "intelligence": 7, "wisdom": 11, "charisma": 10
          },
          "maxHp": 30, "hp": 30, "armorClass": 13, "speed": 30,
          "attacks": [
            {
              "name": "Greataxe", "kind": "melee", "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 12, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": { "strategy": "aggressive" }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Scout",
      "input": { "text": "roll initiative" },
      "comment": "Scout (with Alert feat) initiates combat.",
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "15" },
      "comment": "Scout rolls 15 (15 + 3 DEX + 3 PB Alert = 21). Tank auto-rolls. Server should offer swap since Scout has Alert.",
      "expect": { "combatStarted": true, "initiativeSwapOffer": true }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "swap with Tank" },
      "comment": "Scout swaps initiative with Tank. Turn order should change.",
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "actor": "Scout",
      "input": { "text": "attack orc warrior with shortbow" },
      "comment": "Scout attacks the orc.",
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "15" },
      "comment": "Roll attack (hits AC 13).",
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "actor": "Scout",
      "input": { "text": "5" },
      "comment": "Roll damage.",
      "expect": { "actionComplete": true }
    }
  ]
}
