{
  "name": "Move Toward: Completely Blocked",
  "description": "Character uses 'move toward Goblin' but target is completely enclosed by walls. A* should detect no path exists and handle gracefully without throwing an unrecoverable error.",
  "setup": {
    "character": {
      "name": "Brave Fighter",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 15,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare to fight the goblin" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "18 + 2 (DEX) = 20 initiative, goes first",
      "expect": { "combatStarted": true }
    },
    {
      "type": "setTerrain",
      "input": {
        "terrainZones": [
          { "x": 35, "y": 5, "terrain": "wall" },
          { "x": 35, "y": 10, "terrain": "wall" },
          { "x": 35, "y": 15, "terrain": "wall" },
          { "x": 40, "y": 5, "terrain": "wall" },
          { "x": 40, "y": 15, "terrain": "wall" },
          { "x": 45, "y": 5, "terrain": "wall" },
          { "x": 45, "y": 10, "terrain": "wall" },
          { "x": 45, "y": 15, "terrain": "wall" }
        ]
      },
      "comment": "Complete wall enclosure around goblin at (40,10). All adjacent cells are walls. findAdjacentPosition should return null since no passable cell is within 5ft."
    },
    {
      "type": "action",
      "input": { "text": "move toward Goblin Scout" },
      "comment": "Goblin is completely enclosed by walls. Server returns ValidationError 'Cannot find a passable position' (400). We expect this error.",
      "expect": { "error": true, "errorContains": "passable position" }
    },
    {
      "type": "assertState",
      "comment": "Combat should still be active — the blocked move shouldn't end combat",
      "expect": { "combatStatus": "Active" }
    }
  ]
}
