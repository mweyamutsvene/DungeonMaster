{
  "name": "Dodge Action: ActiveEffect Application",
  "description": "A Fighter takes the Dodge action. Verifies Dodge completes successfully and ActiveEffects (disadvantage on attacks against dodger, advantage on DEX saves) are applied. Combat continues normally.",
  "setup": {
    "character": {
      "name": "Shield Guardian",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16, "dexterity": 14, "constitution": 15,
          "intelligence": 10, "wisdom": 12, "charisma": 8
        },
        "maxHp": 44, "currentHp": 44, "armorClass": 18, "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword", "kind": "melee", "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 10,
            "intelligence": 10, "wisdom": 8, "charisma": 8
          },
          "maxHp": 21, "hp": 21, "armorClass": 15, "speed": 30,
          "challengeRating": 0.25, "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar", "kind": "melee", "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I take a defensive stance" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Take the Dodge action — applies disadvantage/advantage ActiveEffects",
      "type": "action",
      "input": { "text": "dodge" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "actionComplete": true }
    },
    {
      "comment": "End turn, monster attacks (AI path). Dodge effects are on the character.",
      "type": "endTurn"
    },
    { "type": "waitForTurn" },
    {
      "comment": "Verify combat is still active and character survived",
      "type": "assertState",
      "expect": { "combatStatus": "Active", "characterHp": { "min": 1 } }
    },
    {
      "comment": "Now attack on the next turn to verify combat continues after Dodge",
      "type": "action",
      "input": { "text": "I attack the Goblin with my longsword" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "6" }
    }
  ]
}
