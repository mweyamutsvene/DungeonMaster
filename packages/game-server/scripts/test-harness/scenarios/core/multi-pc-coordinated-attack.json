{
  "name": "Multi-PC: Coordinated Attack",
  "description": "Two Fighters attack the same goblin in successive turns. Tests multi-PC initiative, turn sequencing, both PCs taking attack actions, and HP tracking on a shared target.",
  "setup": {
    "characters": [
      {
        "name": "Kael",
        "className": "Fighter",
        "level": 3,
        "position": { "x": 4, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 16, "dexterity": 14, "constitution": 14,
            "intelligence": 10, "wisdom": 12, "charisma": 8
          },
          "maxHp": 28, "currentHp": 28, "armorClass": 16, "speed": 30,
          "proficiencyBonus": 2,
          "attacks": [
            {
              "name": "Longsword", "kind": "melee", "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
              "damageType": "slashing"
            }
          ]
        }
      },
      {
        "name": "Lyra",
        "className": "Fighter",
        "level": 3,
        "position": { "x": 6, "y": 5 },
        "sheet": {
          "abilityScores": {
            "strength": 14, "dexterity": 16, "constitution": 14,
            "intelligence": 10, "wisdom": 12, "charisma": 8
          },
          "maxHp": 28, "currentHp": 28, "armorClass": 15, "speed": 30,
          "proficiencyBonus": 2,
          "attacks": [
            {
              "name": "Rapier", "kind": "melee", "range": "melee",
              "attackBonus": 5,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Goblin Warrior",
        "position": { "x": 5, "y": 5 },
        "statBlock": {
          "armorClass": 15,
          "maxHp": 30,
          "currentHp": 30,
          "speed": 30,
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 10,
            "intelligence": 10, "wisdom": 8, "charisma": 8
          },
          "attacks": [
            {
              "name": "Scimitar", "kind": "melee", "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": { "strategy": "aggressive" }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Kael",
      "input": { "text": "roll initiative" },
      "comment": "Kael initiates combat and rolls initiative.",
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "actor": "Kael",
      "input": { "text": "18" },
      "comment": "Kael rolls 18 (18+2 DEX=20). Lyra auto-rolls. Goblin auto-rolls. Kael should go first with such a high initiative."
    },
    {
      "type": "action",
      "actor": "Kael",
      "input": { "text": "attack goblin warrior with longsword" },
      "comment": "Kael attacks the goblin with longsword — initiates attack pending action.",
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "actor": "Kael",
      "input": { "text": "15" },
      "comment": "Attack roll 15 + 5 = 20 vs AC 15 → hit. Server will request damage roll.",
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "actor": "Kael",
      "input": { "text": "6" },
      "comment": "Damage roll: 6 + 3 = 9 slashing damage. Goblin HP: 30 → 21.",
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Verify goblin took damage from Kael's attack.",
      "expect": {
        "monsterHp": { "name": "Goblin Warrior", "max": 30 }
      }
    },
    {
      "type": "endTurn",
      "actor": "Kael",
      "comment": "Kael ends turn. Next is either Lyra or the goblin (depends on auto-roll)."
    },
    {
      "type": "waitForTurn",
      "actor": "Lyra",
      "comment": "Wait for Lyra's turn (goblin may act in between)."
    },
    {
      "type": "action",
      "actor": "Lyra",
      "input": { "text": "attack goblin warrior with rapier" },
      "comment": "Lyra attacks the same goblin with rapier.",
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "actor": "Lyra",
      "input": { "text": "14" },
      "comment": "Attack roll 14 + 5 = 19 vs AC 15 → hit. Server requests damage roll.",
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "actor": "Lyra",
      "input": { "text": "7" },
      "comment": "Damage roll: 7 + 3 = 10 piercing damage to goblin.",
      "expect": { "actionComplete": true }
    },
    {
      "type": "endTurn",
      "actor": "Lyra",
      "comment": "Lyra ends her turn. Both fighters attacked the goblin."
    }
  ]
}
