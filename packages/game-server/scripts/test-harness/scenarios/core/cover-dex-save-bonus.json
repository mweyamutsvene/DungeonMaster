{
  "name": "Cover: Half cover DEX save bonus",
  "description": "A goblin behind half cover gets +2 to DEX saves. Wizard casts Burning Hands (DEX save, DC 14). Seeded save d20=9, goblin DEX mod=+3. Without cover: 9+3=12 < 14 → FAIL. With half cover: 9+3+2=14 >= 14 → SUCCESS. Half damage on save: floor(13/2)=6. Goblin HP: 30 → 24.",
  "setup": {
    "character": {
      "name": "Elara the Wise",
      "className": "Wizard",
      "level": 3,
      "position": { "x": 5, "y": 10 },
      "sheet": {
