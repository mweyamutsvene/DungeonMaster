{
  "name": "Drop weapon during combat",
  "description": "A Fighter drops their Longsword, verifies it appears on the ground, then picks it back up.",
  "comment": "TODO: Fix server-side thrown weapon chaining — thrown weapons should not be reused for Extra Attack chain (weapon already thrown). Until then, use level 4 to avoid EA.",
  "setup": {
    "character": {
      "name": "Grim Stoneforge",
      "className": "Fighter",
      "level": 4,
      "position": { "x": 20, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 12,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "versatileDamage": { "diceSides": 10 },
            "damageType": "slashing",
            "properties": ["Versatile"]
          },
          {
            "name": "Handaxe",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["Light", "Thrown (Range 20/60)"]
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 13,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 }
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "Let's fight!" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "Go first",
      "expect": { "combatStarted": true }
    },

    {
      "type": "assertState",
      "comment": "No ground items at start",
      "expect": {
        "groundItemCount": 0
      }
    },

    {
      "type": "action",
      "input": { "text": "drop longsword" },
      "comment": "Drop the Longsword — costs no action (D&D 5e 2024: dropping is free)",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "Longsword should be on the ground at Fighter's position",
      "expect": {
        "groundItemCount": 1,
        "groundItemExists": { "name": "Longsword", "nearPosition": { "x": 20, "y": 10 } }
      }
    },

    {
      "type": "action",
      "input": { "text": "pick up longsword" },
      "comment": "Pick the Longsword back up (free object interaction)",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "Longsword picked back up — ground is clear",
      "expect": {
        "groundItemCount": 0
      }
    },

    {
      "type": "action",
      "input": { "text": "throw handaxe at Goblin Scout" },
      "comment": "Throw the Handaxe at the Goblin to test attack still works after drop/pickup cycle",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 5 = 20 vs AC 13 → hit",
      "expect": { "hit": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "4" },
      "comment": "4 + 3 = 7 damage",
      "expect": { "actionComplete": true }
    },

    {
      "type": "assertState",
      "comment": "Goblin took 7 damage (50-7=43). Handaxe on ground at Goblin's position (thrown). Longsword not on ground (picked back up).",
      "expect": {
        "monsterHp": { "name": "Goblin Scout", "min": 43, "max": 43 },
        "groundItemCount": 1,
        "groundItemExists": { "name": "Handaxe", "nearPosition": { "x": 40, "y": 10 } },
        "groundItemNotExists": { "name": "Longsword" }
      }
    }
  ]
}
