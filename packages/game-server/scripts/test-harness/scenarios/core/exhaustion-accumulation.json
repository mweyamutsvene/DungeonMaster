{
  "name": "Exhaustion Accumulation (2024: -2 per level on d20 Tests)",
  "description": "D&D 5e 2024 exhaustion: each of 10 levels imposes -2 on all d20 Tests (attack rolls, ability checks, saving throws) and -5 ft speed. Level 10 = death.\n\nThis scenario applies 3 levels of Exhaustion via DM override and verifies a subsequent attack roll takes a -6 penalty. Attack bonus +7, seeded roll d20=10, vs AC 13. With 3 levels of exhaustion (-6): 10 + 7 - 6 = 11 < 13 → miss. Without exhaustion: 10 + 7 = 17 → hit.",
  "setup": {
    "character": {
      "name": "Weary Wanderer",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18, "dexterity": 12, "constitution": 16,
          "intelligence": 10, "wisdom": 10, "charisma": 8
        },
        "maxHp": 54, "currentHp": 54, "armorClass": 18, "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword", "kind": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 12, "y": 10 },
        "statBlock": {
          "abilityScores": { "strength": 10, "dexterity": 10, "constitution": 10, "intelligence": 1, "wisdom": 1, "charisma": 1 },
          "maxHp": 100, "hp": 100, "armorClass": 13, "speed": 0,
          "challengeRating": 0,
          "attacks": [{ "name": "Slam", "kind": "melee", "attackBonus": 0, "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 }, "damageType": "bludgeoning" }]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I strike the training dummy" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Apply 3 levels of Exhaustion. Source 'exhaustion:3' tells the engine this is level 3. Penalty = -6 on d20 Tests (2024 RAW).",
      "type": "applyCondition",
      "input": {
        "target": "character",
        "condition": "Exhaustion",
        "duration": "until_removed",
        "source": "exhaustion:3"
      }
    },
    {
      "type": "assertState",
      "expect": {
        "characterConditions": { "hasConditions": ["Exhaustion"] }
      }
    },
    {
      "comment": "Attack roll with 3 levels of exhaustion: (d20 - 6) + 7 vs AC 13. Submit d20=10 → 10 - 6 + 7 = 11 → miss.",
      "type": "action",
      "input": { "text": "attack Training Dummy" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "10" },
      "comment": "d20=10, exhaustion -6, attack bonus +7 → total 11 vs AC 13 → MISS. Without the exhaustion wiring this would be 17 → hit.",
      "expect": { "hit": false }
    }
  ]
}
