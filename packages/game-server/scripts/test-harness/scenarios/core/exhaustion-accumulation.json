{
  "name": "Exhaustion Accumulation (2024): Turn-by-Turn Penalty Checkpoints",
  "description": "D&D 5e 2024 exhaustion applies a flat -2 per level on d20 Tests and -5 ft speed per level. This scenario applies exhaustion level 3 and validates repeated turn-by-turn checkpoints: attack penalty behavior, no disadvantage flag, 15 ft movement cap, position tracking, HP stability, and active combat status. Level-10 terminal death is tracked separately as a RED pending branch until lethal combat-state wiring is implemented.",
  "setup": {
    "character": {
      "name": "Weary Wanderer",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 12,
          "constitution": 16,
          "intelligence": 10,
          "wisdom": 10,
          "charisma": 8
        },
        "maxHp": 54,
        "currentHp": 54,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longbow",
            "kind": "ranged",
            "range": "150/600",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 4 },
            "damageType": "piercing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 1,
            "wisdom": 1,
            "charisma": 1
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 13,
          "speed": 0,
          "challengeRating": 0,
          "attacks": [
            {
              "name": "Slam",
              "kind": "melee",
              "attackBonus": 0,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I strike the training dummy" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "applyCondition",
      "comment": "Apply Exhaustion level 3 once (2024: -6 d20 Tests, speed 15).",
      "input": {
        "target": "character",
        "condition": "Exhaustion",
        "duration": "until_removed",
        "source": "exhaustion:3"
      }
    },
    {
      "type": "assertState",
      "comment": "Baseline exhausted checkpoint before repeated turn tests.",
      "expect": {
        "characterConditions": { "hasConditions": ["Exhaustion"] },
        "characterPosition": { "x": 10, "y": 10 },
        "characterHp": { "min": 54, "max": 54 },
        "combatStatus": "Active"
      }
    },
    {
      "type": "action",
      "comment": "Turn 1 attack checkpoint: with exhaustion level 3, use d20=11 to force a miss (11 + 7 - 6 = 12).",
      "input": { "text": "shoot Training Dummy with Longbow" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true,
        "disadvantage": false
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "11" },
      "expect": { "hit": false, "actionComplete": true }
    },
    {
      "type": "assertState",
      "expect": {
        "characterHp": { "min": 54, "max": 54 },
        "characterPosition": { "x": 10, "y": 10 },
        "combatStatus": "Active"
      }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn",
      "comment": "Advance through AI endTurn to next player turn."
    },
    {
      "type": "action",
      "comment": "Turn 2 movement checkpoint: level-3 exhaustion allows 15 ft (3 cells).",
      "input": { "text": "move to (13, 10)" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "expect": {
        "characterPosition": { "x": 13, "y": 10 },
        "characterHp": { "min": 54, "max": 54 },
        "combatStatus": "Active"
      }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn"
    },
    {
      "type": "action",
      "comment": "Turn 3 attack checkpoint: same exhaustion level with d20=12 should hit boundary (12 + 7 - 6 = 13).",
      "input": { "text": "shoot Training Dummy with Longbow" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true,
        "disadvantage": false
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "1" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Final green checkpoint for repeated exhausted turns.",
      "expect": {
        "characterConditions": { "hasConditions": ["Exhaustion"] },
        "characterPosition": { "x": 13, "y": 10 },
        "characterHp": { "min": 54, "max": 54 },
        "combatStatus": "Active"
      }
    }
  ]
}
