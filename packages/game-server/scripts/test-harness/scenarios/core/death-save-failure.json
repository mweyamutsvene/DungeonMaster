{
  "name": "Death Save: Three Failures — Death",
  "description": "A character drops to 0 HP and fails 3 death saves, resulting in death. Tests that 3 failures correctly mark the character as dead and end combat.",
  "setup": {
    "character": {
      "name": "Doomed Hero",
      "className": "Fighter",
      "level": 1,
      "position": { "x": 0, "y": 0 },
      "sheet": {
        "abilityScores": {
          "strength": 10, "dexterity": 10, "constitution": 10,
          "intelligence": 10, "wisdom": 10, "charisma": 10
        },
        "maxHp": 1, "currentHp": 1, "armorClass": 10, "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Dagger", "kind": "melee", "attackBonus": 2,
            "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 },
            "damageType": "piercing"
          }
        ],
        "features": [],
        "resourcePools": []
      }
    },
    "monsters": [
      {
        "name": "Deadly Foe",
        "position": { "x": 5, "y": 0 },
        "statBlock": {
          "abilityScores": {
            "strength": 20, "dexterity": 20, "constitution": 20,
            "intelligence": 10, "wisdom": 10, "charisma": 10
          },
          "hp": 100, "maxHp": 100, "armorClass": 18, "speed": 30,
          "position": { "x": 5, "y": 0 },
          "attacks": [
            {
              "name": "Greatsword", "kind": "melee", "range": "melee",
              "attackBonus": 15,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 5 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I face the Deadly Foe" },
      "expect": { "rollType": "initiative" }
    },
    {
      "type": "rollResult",
      "input": { "text": "2" },
      "comment": "Low init. Monster goes first and KOs the character.",
      "expect": { "combatStarted": true }
    },
    {
      "type": "waitForTurn",
      "comment": "Monster attacks, KOs character to 0 HP."
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "Death save #1: 5 < 10 → failure",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "failure",
        "deathSaves": { "successes": 0, "failures": 1 },
        "actionComplete": true
      }
    },
    {
      "type": "waitForTurn",
      "comment": "Monster turn → character's turn"
    },
    {
      "type": "rollResult",
      "input": { "text": "3" },
      "comment": "Death save #2: 3 < 10 → failure",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "failure",
        "deathSaves": { "successes": 0, "failures": 2 },
        "actionComplete": true
      }
    },
    {
      "type": "waitForTurn",
      "comment": "Monster turn → character's turn"
    },
    {
      "type": "rollResult",
      "input": { "text": "7" },
      "comment": "Death save #3: 7 < 10 → 3rd failure → DEAD!",
      "expect": {
        "rollType": "deathSave",
        "deathSaveResult": "dead",
        "deathSaves": { "successes": 0, "failures": 3 },
        "actionComplete": true
      }
    }
  ]
}
