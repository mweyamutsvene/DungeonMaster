{
  "name": "Frightened: Cannot Move Closer to Fear Source",
  "description": "D&D 5e 2024: A Frightened creature cannot willingly move closer to the source of its fear. Uses DM override to apply Frightened (since AI spellcasting doesn't resolve saves/conditions yet), then tests that movement toward the fear source is blocked and movement away is allowed.",
  "setup": {
    "character": {
      "name": "Timid Scout",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 14,
          "dexterity": 16,
          "constitution": 12,
          "intelligence": 10,
          "wisdom": 4,
          "charisma": 8
        },
        "maxHp": 28,
        "currentHp": 28,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "piercing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Fear Mage",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 12,
            "constitution": 14,
            "intelligence": 16,
            "wisdom": 16,
            "charisma": 18
          },
          "maxHp": 60,
          "hp": 60,
          "armorClass": 15,
          "speed": 30,
          "challengeRating": 3,
          "experienceValue": 700,
          "saveProficiencies": [],
          "attacks": [
            {
              "name": "Staff",
              "kind": "melee",
              "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I draw my weapon" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High initiative so player goes first — we need to apply Frightened then test movement on OUR turn.",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "applyCondition",
      "input": {
        "target": "character",
        "condition": "Frightened",
        "duration": "until_removed",
        "sourceMonster": "Fear Mage"
      },
      "comment": "DM override: apply Frightened condition with Fear Mage as source. Simulates a failed save against Cause Fear (AI spell path doesn't resolve saves yet)."
    },
    {
      "type": "assertState",
      "comment": "Verify character has the Frightened condition",
      "expect": {
        "characterConditions": { "hasConditions": ["Frightened"] }
      }
    },
    {
      "type": "action",
      "input": { "text": "move to 20, 10" },
      "comment": "Try to move closer to Fear Mage at (40,10) — from (10,10) to (20,10) reduces distance from 30ft to 20ft. Should be BLOCKED by Frightened.",
      "expect": {
        "error": true,
        "errorContains": "source of fear"
      }
    },
    {
      "type": "action",
      "input": { "text": "move to 5, 10" },
      "comment": "Move AWAY from Fear Mage — from (10,10) to (5,10) increases distance from 30ft to 35ft. Should be ALLOWED.",
      "expect": {
        "type": "MOVE_COMPLETE"
      }
    },
    {
      "type": "assertState",
      "comment": "Verify character moved away successfully and is still Frightened",
      "expect": {
        "characterPosition": { "x": 5, "y": 10 },
        "characterConditions": { "hasConditions": ["Frightened"] }
      }
    }
  ]
}
