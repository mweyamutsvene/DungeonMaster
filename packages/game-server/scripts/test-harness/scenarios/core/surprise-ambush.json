{
  "name": "Surprise: Ambush gives enemies initiative disadvantage",
  "description": "A Fighter ambushes enemies. The surprise='enemies' flag causes monsters to roll initiative with disadvantage (2d20 take lowest). The Fighter then attacks the surprised Goblin normally.",
  "setup": {
    "character": {
      "name": "Shadow",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 5, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing",
            "properties": ["Versatile (1d10)"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 10, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 15,
          "speed": 30,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "range": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "setSurprise",
      "comment": "DM sets surprise: enemies are caught off guard by the ambush",
      "input": { "surprise": "enemies" }
    },
    {
      "type": "initiate",
      "comment": "Ambush! Initiate combat — server reads surprise from encounter",
      "input": { "text": "I attack the goblin scout" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "comment": "Roll initiative (high roll to go first)",
      "input": { "text": "I rolled a 18" },
      "expect": { "rollType": "initiative", "combatStarted": true }
    },
    {
      "type": "action",
      "comment": "Attack the surprised goblin",
      "input": { "text": "I attack the goblin scout with my longsword" },
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "comment": "Roll attack (hits AC 15)",
      "input": { "text": "I rolled a 16" },
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "comment": "Roll damage",
      "input": { "text": "I rolled a 6" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "comment": "Goblin took damage from the ambush attack",
      "expect": {
        "monsterHp": { "name": "Goblin Scout", "min": 1, "max": 29 }
      }
    }
  ]
}
