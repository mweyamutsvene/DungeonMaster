{
  "name": "Goblin Nimble Escape: Hide as Bonus Action",
  "description": "A Goblin uses Nimble Escape to Hide as a bonus action after attacking. Validates AI-driven bonus action execution, hide wiring, and Hidden condition application.",
  "setup": {
    "character": {
      "name": "Thorin Ironfist",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 15,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 42,
        "currentHp": 42,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 40,
          "hp": 40,
          "armorClass": 15,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "skills": { "stealth": 6 },
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ],
          "bonusActions": [
            {
              "name": "Nimble Escape",
              "description": "Disengage or Hide as a bonus action"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "attack",
      "defaultBonusAction": "nimble_escape_hide"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the goblin" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      },
      "comment": "Start combat — initiative roll required"
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 15" },
      "expect": {
        "combatStarted": true
      },
      "comment": "Player rolls initiative — combat begins"
    },
    {
      "type": "action",
      "input": { "text": "I attack the Goblin Scout with my Longsword" },
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      },
      "comment": "Player attacks the goblin (5ft away)"
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      },
      "comment": "Hit — need damage roll"
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 5" },
      "expect": {
        "actionComplete": true
      },
      "comment": "Deal 5+3=8 damage — goblin still alive at 32 HP"
    },
    {
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Goblin Scout", "min": 25, "max": 35 }
      },
      "comment": "Verify goblin took damage but is still alive"
    },
    {
      "type": "endTurn",
      "comment": "End player turn — goblin's AI turn begins (attack + nimble escape hide)"
    },
    {
      "type": "waitForTurn",
      "timeout": 10000,
      "comment": "Wait for goblin AI to complete turn (attack + hide bonus action)"
    },
    {
      "type": "assertState",
      "expect": {
        "monsterConditions": {
          "name": "Goblin Scout",
          "hasConditions": ["Hidden"]
        }
      },
      "comment": "Goblin should now be Hidden via Nimble Escape"
    },
    {
      "type": "assertState",
      "expect": {
        "monstersAlive": 1
      },
      "comment": "Confirm goblin is still alive"
    }
  ]
}
