{
  "name": "Concentration: Broken by Damage (CON save)",
  "description": "A Wizard casts a concentration spell (Bless), asserts it is tracked, then takes damage from a monster. After taking damage, we verify the concentration save fired and the concentrationSpellName field was set/cleared appropriately.",
  "setup": {
    "character": {
      "name": "Elara",
      "className": "Wizard",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 10,
          "intelligence": 18, "wisdom": 12, "charisma": 10
        },
        "maxHp": 14, "currentHp": 14, "armorClass": 12, "speed": 30,
        "proficiencyBonus": 2,
        "saveProficiencies": [],
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 14,
        "spellAttackBonus": 6,
        "spellSlots": { "1": 4 },
        "preparedSpells": [
          { "name": "Bless", "level": 1, "concentration": true },
          { "name": "Fire Bolt", "level": 0 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff", "kind": "melee", "range": "melee",
            "attackBonus": 0,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Ogre",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 19, "dexterity": 8, "constitution": 16,
            "intelligence": 5, "wisdom": 7, "charisma": 7
          },
          "maxHp": 200, "hp": 200, "armorClass": 11, "speed": 40,
          "challengeRating": 2, "experienceValue": 450,
          "attacks": [
            {
              "name": "Greatclub", "kind": "melee", "attackBonus": 6,
              "damage": { "diceCount": 2, "diceSides": 8, "modifier": 4 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Cast Bless (concentration) — should set concentrationSpellName",
      "type": "action",
      "input": { "text": "cast Bless" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    },
    {
      "comment": "Assert concentration is now active on Bless",
      "type": "assertState",
      "expect": {
        "characterConcentration": "Bless"
      }
    },
    {
      "comment": "End turn so the Ogre attacks — high damage + low CON = likely broken",
      "type": "endTurn"
    },
    {
      "type": "waitForTurn"
    },
    {
      "comment": "After taking Ogre damage, cast Fire Bolt (cantrip) to continue the turn",
      "type": "action",
      "input": { "text": "cast Fire Bolt at Ogre" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    }
  ]
}
