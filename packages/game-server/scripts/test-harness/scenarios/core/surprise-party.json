{
  "name": "Surprise: Party ambushed — PC rolls initiative with disadvantage",
  "description": "Monsters ambush the party. The surprise='party' flag signals disadvantage on the PC's initiative roll request. The PC still acts normally on their turn.",
  "setup": {
    "character": {
      "name": "Scout",
      "className": "Fighter",
      "level": 3,
      "position": { "x": 5, "y": 5 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 28,
        "currentHp": 28,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 2,
        "attacks": [
          {
            "name": "Longsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 5,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
            "damageType": "slashing"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Ambush Goblin",
        "position": { "x": 10, "y": 5 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 20,
          "hp": 20,
          "armorClass": 13,
          "speed": 30,
          "attacks": [
            {
              "name": "Shortbow",
              "kind": "ranged",
              "range": "80/320",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "setSurprise",
      "comment": "DM sets surprise: the party is being ambushed",
      "input": { "surprise": "party" }
    },
    {
      "type": "initiate",
      "comment": "Party is ambushed — PC should get disadvantage signal on initiative",
      "input": { "text": "I attack the ambush goblin" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true, "disadvantage": true }
    },
    {
      "type": "rollResult",
      "comment": "Roll initiative (low roll representing the disadvantage)",
      "input": { "text": "I rolled a 5" },
      "expect": { "rollType": "initiative", "combatStarted": true }
    },
    {
      "type": "action",
      "comment": "PC still acts normally on their turn — no skipped turns in 2024",
      "input": { "text": "I attack the ambush goblin with my longsword" },
      "expect": { "rollType": "attack" }
    },
    {
      "type": "rollResult",
      "comment": "Roll attack (hits AC 13)",
      "input": { "text": "I rolled a 15" },
      "expect": { "hit": true, "rollType": "damage" }
    },
    {
      "type": "rollResult",
      "comment": "Roll damage",
      "input": { "text": "I rolled a 7" },
      "expect": { "actionComplete": true }
    }
  ]
}
