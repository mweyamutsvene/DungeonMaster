{
  "name": "Hide: One Blinded Enemy Does Not Hide You From Another",
  "description": "Regression guard for multi-observer hide logic. A rogue attempts to Hide in the open while one enemy is Blinded and another enemy can still see normally. The rogue should not gain Hidden, because at least one hostile observer still sees the rogue clearly.",
  "setup": {
    "character": {
      "name": "Shade",
      "className": "Rogue",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 10,
          "dexterity": 18,
          "constitution": 14,
          "intelligence": 12,
          "wisdom": 12,
          "charisma": 12
        },
        "maxHp": 34,
        "currentHp": 34,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 3,
        "skills": {
          "stealth": 10
        },
        "attacks": [
          {
            "name": "Shortbow",
            "kind": "ranged",
            "range": "80/320",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 4 },
            "damageType": "piercing"
          }
        ],
        "features": [
          { "name": "Cunning Action", "description": "Dash, Disengage, or Hide as a bonus action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Blind Guard",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 12,
            "dexterity": 12,
            "constitution": 14,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 35,
          "hp": 35,
          "armorClass": 14,
          "speed": 30,
          "passivePerception": 9,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Spear",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      },
      {
        "name": "Sighted Archer",
        "position": { "x": 20, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 14,
            "constitution": 12,
            "intelligence": 10,
            "wisdom": 10,
            "charisma": 8
          },
          "maxHp": 30,
          "hp": 30,
          "armorClass": 13,
          "speed": 30,
          "passivePerception": 10,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Shortbow",
              "kind": "ranged",
              "range": "80/320",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I watch both guards for an opening" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative so the rogue acts first.",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "applyCondition",
      "comment": "Only one of the two observers is Blinded.",
      "input": {
        "target": "monster:Blind Guard",
        "condition": "Blinded",
        "duration": "1 minute",
        "source": "blind-hide-regression"
      }
    },
    {
      "type": "assertState",
      "comment": "Checkpoint: Blind Guard is Blinded, Sighted Archer is not.",
      "expect": {
        "monsterConditions": {
          "name": "Blind Guard",
          "hasConditions": ["Blinded"]
        }
      }
    },
    {
      "type": "action",
      "input": { "text": "hide" },
      "comment": "There is still a sighted enemy with clear line of sight, so the rogue should not become Hidden.",
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Hide"
      }
    },
    {
      "type": "assertState",
      "comment": "Rules expectation: one blinded enemy does not matter if another hostile observer still sees the rogue clearly.",
      "expect": {
        "characterConditions": {
          "doesNotHaveConditions": ["Hidden"]
        }
      }
    }
  ]
}