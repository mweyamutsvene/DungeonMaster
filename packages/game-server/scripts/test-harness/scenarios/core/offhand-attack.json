{
  "name": "Off-hand Attack: Two-weapon fighting bonus attack",
  "description": "A Fighter with two light weapons makes a normal attack (action), then an off-hand attack (bonus action). Off-hand damage does NOT include ability modifier per D&D 5e rules.",
  "setup": {
    "character": {
      "name": "Dual Wielder Dex",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 16,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 10,
          "wisdom": 12,
          "charisma": 8
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 16,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "piercing",
            "properties": ["finesse", "light"]
          },
          {
            "name": "Shortsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 6,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": 3 },
            "damageType": "piercing",
            "properties": ["finesse", "light"]
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 10,
            "constitution": 10,
            "intelligence": 1,
            "wisdom": 1,
            "charisma": 1
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 10,
          "speed": 0,
          "attacks": []
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training dummy" },
      "expect": {
        "rollType": "initiative"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy with my shortsword" },
      "comment": "First attack (Action) - request attack roll",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "15 + 6 = 21 vs AC 10 - hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "4" },
      "comment": "4 + 3 = 7 damage. Dummy: 100 - 7 = 93 HP. Extra Attack chains to attack 2/2.",
      "expect": {
        "actionComplete": false
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "comment": "Chained Extra Attack 2/2: 12 + 6 = 18 vs AC 10 - hit",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "3" },
      "comment": "3 + 3 = 6 damage. Dummy: 93 - 6 = 87 HP. Extra Attack complete.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "offhand attack" },
      "comment": "Off-hand attack as a bonus action - requests attack roll",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "14" },
      "comment": "14 + 6 = 20 vs AC 10 - hit. Off-hand damage has NO ability modifier",
      "expect": {
        "hit": true,
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "5" },
      "comment": "5 + 0 = 5 damage (no modifier on off-hand). Dummy: 87 - 5 = 82 HP",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "assertState",
      "comment": "Combat continues - Dummy should be alive with reduced HP",
      "expect": {
        "combatStatus": "Active"
      }
    }
  ]
}
