  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I channel my holy power against the undead!" },
      "comment": "Start combat — server asks for initiative roll",
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to ensure Cleric acts first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "turn undead" },
      "comment": "Cleric uses Turn Undead — Skeleton (CR 0.25, WIS 1) destroyed by Destroy Undead; Ghast (CR 2, WIS 1) fails but CR > 0.5 so Frightened; Goblin (Humanoid) unaffected",
      "expect": {
        "actionComplete": true,
        "type": "SIMPLE_ACTION_COMPLETE"
      }
    },
    {
      "type": "assertState",
      "comment": "Skeleton (CR 0.25) should be destroyed (HP 0) by Destroy Undead at cleric level 5 (threshold CR 0.5)",
      "expect": {
        "monsterHp": {
          "name": "Skeleton Warrior",
          "exact": 0
        }
      }
    },
    {
      "type": "assertState",
      "comment": "Ghast (CR 2) failed the save but CR > 0.5 so should be Frightened (not destroyed)",
      "expect": {
        "monsterConditions": {
          "name": "Ghast",
          "hasConditions": ["Frightened"]
        }
      }
    },
    {
      "type": "assertState",
      "comment": "Goblin is not Undead so should have no conditions from Turn Undead",
      "expect": {
        "monsterConditions": {
          "name": "Goblin Ambusher",
          "doesNotHaveConditions": ["Frightened"]
        }
      }
    },
    {
      "type": "assertState",
      "comment": "Channel Divinity pool should drop from 2 to 1 after one use",
      "expect": {
        "characterResource": {
          "poolName": "channelDivinity:cleric",
          "current": 1
        }
      }
    }
