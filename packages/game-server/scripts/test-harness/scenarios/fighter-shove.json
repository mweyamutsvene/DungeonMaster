{
  "name": "Fighter Shove: Push and Prone",
  "description": "A Fighter uses the Shove action to push an enemy back and knock them prone. Tests the contested athletics check and shove mechanics.",
  "setup": {
    "character": {
      "name": "Grimgar the Strong",
      "className": "Fighter",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 20,
          "dexterity": 12,
          "constitution": 16,
          "intelligence": 8,
          "wisdom": 10,
          "charisma": 10
        },
        "maxHp": 44,
        "currentHp": 44,
        "armorClass": 18,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Warhammer",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 8,
            "damage": { "diceCount": 1, "diceSides": 8, "modifier": 5 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Goblin Scout",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 12,
          "hp": 12,
          "armorClass": 13,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Dagger",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 4, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare for battle" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "shove Goblin Scout" },
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Shove"
      }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn"
    },
    {
      "type": "action",
      "comment": "Move to get back in range after the push",
      "input": { "text": "move to 15, 10" },
      "expect": {
        "type": "MOVE_COMPLETE"
      }
    },
    {
      "type": "action",
      "input": { "text": "shove Goblin Scout prone" },
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "Shove"
      }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn"
    },
    {
      "type": "action",
      "input": { "text": "attack Goblin Scout" },
      "expect": {
        "rollType": "attack"
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "12" },
      "expect": {
        "hit": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "8" }
    }
  ]
}
