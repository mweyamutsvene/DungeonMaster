{
  "name": "Barbarian Reckless Attack: Advantage on melee STR attacks",
  "description": "A Barbarian uses Reckless Attack to gain advantage on melee attacks, then attacks. Tests the free action, advantage on attack rolls, and that it resets on next turn.",
  "setup": {
    "character": {
      "name": "Grimjaw",
      "className": "Barbarian",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 8,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 55,
        "currentHp": 55,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Greatsword",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 2, "diceSides": 6, "modifier": 4 },
            "damageType": "slashing"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" },
          { "name": "Reckless Attack", "description": "Gain advantage on melee STR attacks, but attacks against you have advantage." }
        ],
        "resourcePools": [
          { "name": "rage", "current": 3, "max": 3 }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10,
            "dexterity": 8,
            "constitution": 18,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 200,
          "hp": 200,
          "armorClass": 10,
          "speed": 0,
          "challengeRating": 0,
          "experienceValue": 0,
          "attacks": []
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training dummy" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "reckless attack" },
      "comment": "Use Reckless Attack — free action (classAction), grants advantage on melee STR attacks",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Dummy" },
      "comment": "Melee attack — should have advantage from Reckless Attack",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true,
        "advantage": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "Attack roll: 15 + 7 = 22 vs AC 10 → hit",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "8" },
      "comment": "Damage roll",
      "expect": { "actionComplete": true }
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn"
    },
    {
      "type": "action",
      "input": { "text": "reckless attack" },
      "comment": "Use Reckless Attack again should fail — already used this turn (flag persists through previous turn's end). Actually, the flag resets so this should work.",
      "expect": {
        "actionComplete": true
      }
    }
  ]
}
