{
  "name": "Barbarian Rage: Bonus action + damage bonus + B/P/S resistance",
  "description": "A Barbarian enters Rage (bonus action), attacks with rage damage bonus (+2), then takes bludgeoning damage with resistance (halved). Tests rage activation, resource spending, melee damage bonus, and B/P/S resistance.",
  "setup": {
    "character": {
      "name": "Korgath",
      "className": "Barbarian",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 18,
          "dexterity": 14,
          "constitution": 16,
          "intelligence": 8,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 55,
        "currentHp": 55,
        "armorClass": 15,
        "speed": 30,
        "proficiencyBonus": 3,
        "attacks": [
          {
            "name": "Greataxe",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 7,
            "damage": { "diceCount": 1, "diceSides": 12, "modifier": 4 },
            "damageType": "slashing"
          }
        ],
        "features": [
          { "name": "Extra Attack", "description": "Attack twice when you take the Attack action" },
          { "name": "Rage", "description": "Enter a Rage as a bonus action. Gain resistance to B/P/S damage and +2 melee damage." },
          { "name": "Reckless Attack", "description": "Gain advantage on melee STR attacks, but attacks against you have advantage." }
        ],
        "resourcePools": [
          { "name": "rage", "current": 3, "max": 3 }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Golem",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 16,
            "dexterity": 8,
            "constitution": 18,
            "intelligence": 1,
            "wisdom": 6,
            "charisma": 1
          },
          "maxHp": 200,
          "hp": 200,
          "armorClass": 5,
          "speed": 30,
          "challengeRating": 1,
          "experienceValue": 200,
          "attacks": [
            {
              "name": "Slam",
              "kind": "melee",
              "attackBonus": 10,
              "damage": { "diceCount": 1, "diceSides": 8, "modifier": 3 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I attack the training golem" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 18" },
      "comment": "High initiative to go first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "action",
      "input": { "text": "rage" },
      "comment": "Enter Rage — bonus action, spends 1 rage use. Activates +2 melee damage and B/P/S resistance.",
      "expect": {
        "actionComplete": true
      }
    },
    {
      "type": "action",
      "input": { "text": "attack Training Golem" },
      "comment": "Melee attack with Greataxe — should include +2 rage damage bonus",
      "expect": {
        "rollType": "attack",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "15" },
      "comment": "Attack roll: 15 + 7 = 22 vs AC 5 → hit",
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "8" },
      "comment": "Damage roll: 8 (die) + 4 (STR mod) + 2 (rage bonus) = 14 total slashing damage. Golem HP: 200 → 186"
    },
    {
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Training Golem", "exact": 186 }
      },
      "comment": "Verify rage damage bonus: 8 + 4 (STR) + 2 (rage) = 14. Golem: 200 - 14 = 186"
    },
    {
      "type": "endTurn"
    },
    {
      "type": "waitForTurn",
      "comment": "Monster attacks (Slam +10, 1d8+3 bludgeoning). Barbarian takes HALVED bludgeoning from rage resistance."
    },
    {
      "type": "assertState",
      "expect": {
        "characterHp": { "name": "Korgath", "min": 45, "max": 54 }
      },
      "comment": "Barbarian should take roughly halved bludgeoning damage. With 55 HP, even max hit (11) is halved to 5, so HP should be 50-55. Min accounts for possible extra attacks."
    },
    {
      "type": "action",
      "input": { "text": "rage" },
      "comment": "Trying to rage again while already raging should fail",
      "expect": {
        "error": true
      }
    }
  ]
}
