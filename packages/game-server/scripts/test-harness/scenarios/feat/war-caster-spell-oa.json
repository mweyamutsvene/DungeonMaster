{
  "name": "War Caster: Spell as Opportunity Attack",
  "description": "A Wizard with War Caster feat casts Fire Bolt as an opportunity attack when a Goblin flees, instead of making a melee weapon attack.",
  "setup": {
    "character": {
      "name": "Arcane Sentinel",
      "className": "Wizard",
      "level": 5,
      "position": { "x": 20, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8,
          "dexterity": 14,
          "constitution": 14,
          "intelligence": 18,
          "wisdom": 12,
          "charisma": 10
        },
        "maxHp": 32,
        "currentHp": 32,
        "armorClass": 12,
        "speed": 30,
        "proficiencyBonus": 3,
        "spellSaveDC": 15,
        "featIds": ["feat_war-caster"],
        "preparedSpells": [
          { "name": "Fire Bolt", "level": 0, "attackType": "ranged_spell", "damage": { "diceCount": 2, "diceSides": 10, "modifier": 0, "type": "fire" } }
        ],
        "spellSlots": { "1": 4, "2": 3, "3": 2 },
        "equipment": { "mainHand": "Quarterstaff" },
        "attacks": [
          {
            "name": "Quarterstaff",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 1,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Fleeing Goblin",
        "position": { "x": 25, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 8,
            "dexterity": 14,
            "constitution": 10,
            "intelligence": 10,
            "wisdom": 8,
            "charisma": 8
          },
          "maxHp": 50,
          "hp": 50,
          "armorClass": 5,
          "speed": 30,
          "challengeRating": 0.25,
          "experienceValue": 50,
          "attacks": [
            {
              "name": "Scimitar",
              "kind": "melee",
              "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I stand my ground against the goblin" },
      "expect": {
        "rollType": "initiative",
        "requiresPlayerInput": true
      }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 20" },
      "comment": "High initiative so Wizard goes first",
      "expect": {
        "combatStarted": true
      }
    },
    {
      "type": "configureAi",
      "input": { "defaultBehavior": "flee" },
      "comment": "Configure goblin to flee on its turn, triggering player OA"
    },
    {
      "type": "endTurn",
      "comment": "Wizard does nothing on first turn — goblin will flee next"
    },
    {
      "type": "waitForPlayerOa",
      "comment": "Wait for goblin to flee, triggering Wizard's opportunity attack (should be spell OA due to War Caster)",
      "timeout": 10000
    },
    {
      "type": "reactionRespond",
      "input": { "choice": "use", "spellName": "Fire Bolt" },
      "comment": "Wizard uses War Caster to cast Fire Bolt as the opportunity attack"
    },
    {
      "type": "playerOaRoll",
      "input": { "attackRoll": 15 },
      "comment": "Triggers move completion — server auto-resolves spell OA via AiSpellDelivery (no player rolls needed, attackRoll is unused)"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for AI turn processing to complete and player turn to resume",
      "timeout": 10000
    },
    {
      "type": "assertState",
      "expect": {
        "combatStatus": "Active"
      },
      "comment": "Combat should remain active (goblin has enough HP to survive even if Fire Bolt hits). The test validates the spell OA code path executed without errors."
    }
  ]
}
