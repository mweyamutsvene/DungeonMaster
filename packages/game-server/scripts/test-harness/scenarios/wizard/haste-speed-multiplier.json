{
  "name": "Haste speed_multiplier: doubled movement budget",
  "description": "Wizard casts Haste on self, then moves 55 ft in one move action. This exceeds base 30 ft but fits haste speed_multiplier x2 (60 ft).",
  "setup": {
    "character": {
      "name": "Fleet Arcanist",
      "className": "Wizard",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 14,
          "intelligence": 18, "wisdom": 12, "charisma": 10
        },
        "maxHp": 32,
        "currentHp": 32,
        "armorClass": 12,
        "speed": 30,
        "proficiencyBonus": 3,
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 15,
        "spellAttackBonus": 7,
        "spellSlots": { "1": 4, "2": 3, "3": 2 },
        "preparedSpells": [
          { "name": "Haste", "level": 3 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 1,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Dummy",
        "position": { "x": 80, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10, "dexterity": 10, "constitution": 10,
            "intelligence": 1, "wisdom": 1, "charisma": 1
          },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 5,
          "speed": 0,
          "challengeRating": 0,
          "attacks": [
            {
              "name": "Bump",
              "kind": "melee",
              "attackBonus": 0,
              "damage": { "diceCount": 1, "diceSides": 1, "modifier": 0 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ]
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "Speed test begins" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "input": { "text": "cast Haste on myself" },
      "expect": { "actionComplete": true, "type": "SIMPLE_ACTION_COMPLETE" }
    },
    {
      "type": "assertState",
      "expect": { "characterConcentration": "Haste" }
    },
    {
      "comment": "Move from x=10 to x=21 (11 cells = 55 ft). Should succeed only with speed_multiplier 2x.",
      "type": "action",
      "input": { "text": "move to (21, 10)" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "expect": { "characterPosition": { "x": 21, "y": 10 } }
    },
    {
      "type": "assertState",
      "expect": { "characterResource": { "poolName": "spellSlot_3", "current": 1, "max": 2 } }
    }
  ]
}
