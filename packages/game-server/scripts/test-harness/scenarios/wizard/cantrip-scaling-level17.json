{
  "name": "Wizard Cantrip Scaling Tier L17: Fire Bolt uses 4d10",
  "description": "Level 17 cantrip tier. Fire Bolt should scale to 4d10 damage.",
  "setup": {
    "character": {
      "name": "Archmage",
      "className": "Wizard",
      "level": 17,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 16,
          "intelligence": 20, "wisdom": 14, "charisma": 12
        },
        "maxHp": 110,
        "currentHp": 110,
        "armorClass": 14,
        "speed": 30,
        "proficiencyBonus": 6,
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 19,
        "spellAttackBonus": 11,
        "spellSlots": { "1": 4, "2": 3, "3": 3, "4": 3, "5": 3, "6": 1, "7": 1, "8": 1, "9": 1 },
        "preparedSpells": [
          { "name": "Fire Bolt", "level": 0 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff",
            "kind": "melee",
            "range": "melee",
            "attackBonus": 2,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Training Ogre",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 19, "dexterity": 8, "constitution": 16,
            "intelligence": 5, "wisdom": 7, "charisma": 7
          },
          "maxHp": 120,
          "hp": 120,
          "armorClass": 11,
          "speed": 40,
          "challengeRating": 2,
          "experienceValue": 450,
          "attacks": [
            {
              "name": "Greatclub",
              "kind": "melee",
              "attackBonus": 6,
              "damage": { "diceCount": 2, "diceSides": 8, "modifier": 4 },
              "damageType": "bludgeoning"
            }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I cast Fire Bolt" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "action",
      "input": { "text": "cast Fire Bolt at Training Ogre" },
      "expect": { "rollType": "attack", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "I rolled 10" },
      "expect": { "hit": true, "requiresPlayerInput": true }
    },
    {
      "comment": "Tier proof: 35 damage is valid for 4d10, above 3d10 cap.",
      "type": "rollResult",
      "input": { "text": "I rolled 35" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "expect": {
        "monsterHp": { "name": "Training Ogre", "exact": 85 }
      }
    }
  ]
}
