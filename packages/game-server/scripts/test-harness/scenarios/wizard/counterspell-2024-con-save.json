{
  "name": "Counterspell 2024: Target caster Con save vs counterspeller's save DC",
  "description": "D&D 5e 2024 Counterspell mechanic. The TARGET caster (the one being countered) makes a Constitution save against the COUNTERSPELLER's spell save DC. On fail → spell is countered. On success → spell proceeds normally. Per 2024 RAW: both casters still consume their spell slots (no refund on counter — the target's spell is cast, it just has no effect).\n\nThis scenario: Wizard A casts Fireball; Wizard B uses reaction to Counterspell. Wizard A's CON +2 vs Wizard B's DC 15. Con save is expected to fail → Fireball is countered, Target Dummy takes no damage, both Wizards' L3 slots consumed.",
  "setup": {
    "characters": [
      {
        "name": "Wizard A",
        "className": "Wizard",
        "level": 5,
        "position": { "x": 10, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 14,
            "intelligence": 18, "wisdom": 12, "charisma": 10
          },
          "maxHp": 32, "currentHp": 32, "armorClass": 12, "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "intelligence",
          "spellSaveDC": 15, "spellAttackBonus": 7,
          "spellSlots": { "1": 4, "2": 3, "3": 2 },
          "preparedSpells": [
            { "name": "Fire Bolt", "level": 0 },
            { "name": "Fireball", "level": 3 }
          ],
          "attacks": [
            { "name": "Quarterstaff", "kind": "melee", "attackBonus": 1, "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 }, "damageType": "bludgeoning" }
          ]
        }
      },
      {
        "name": "Wizard B",
        "className": "Wizard",
        "level": 5,
        "position": { "x": 15, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 14,
            "intelligence": 18, "wisdom": 12, "charisma": 10
          },
          "maxHp": 32, "currentHp": 32, "armorClass": 12, "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "intelligence",
          "spellSaveDC": 15, "spellAttackBonus": 7,
          "spellSlots": { "1": 4, "2": 3, "3": 2 },
          "preparedSpells": [
            { "name": "Fire Bolt", "level": 0 },
            { "name": "Counterspell", "level": 3 }
          ],
          "attacks": [
            { "name": "Quarterstaff", "kind": "melee", "attackBonus": 1, "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 }, "damageType": "bludgeoning" }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Target Dummy",
        "position": { "x": 30, "y": 10 },
        "statBlock": {
          "abilityScores": { "strength": 10, "dexterity": 10, "constitution": 10, "intelligence": 1, "wisdom": 1, "charisma": 1 },
          "maxHp": 100, "hp": 100, "armorClass": 10, "speed": 0,
          "challengeRating": 0,
          "attacks": [{ "name": "Slam", "kind": "melee", "attackBonus": 0, "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 }, "damageType": "bludgeoning" }]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Wizard A",
      "input": { "text": "Wizard A begins casting" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Wizard A",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Queue server-side d20=10 for the Wizard A Con save when Counterspell triggers. 10+2 CON mod = 12 < DC 15 → fail, Fireball countered.",
      "type": "queueDiceRolls",
      "input": { "values": [10], "label": "Counterspell target Con save" }
    },
    {
      "type": "waitForTurn",
      "actor": "Wizard A",
      "timeout": 15000
    },
    {
      "type": "action",
      "actor": "Wizard A",
      "input": { "text": "cast Fireball at Target Dummy" },
      "comment": "Engine should emit a reaction window for Wizard B (in sight, has Counterspell prepared, has L3 slot, has reaction)."
    },
    {
      "type": "waitForReaction",
      "input": { "reactionType": "counterspell" },
      "timeout": 15000
    },
    {
      "type": "reactionRespond",
      "input": { "choice": "use" }
    },
    {
      "comment": "Per 2024 RAW, both casters consume their L3 slot even though the Fireball was countered. Wizard A: 2→1.",
      "type": "assertState",
      "actor": "Wizard A",
      "expect": { "characterResource": { "poolName": "spellSlot_3", "current": 1, "max": 2 } }
    },
    {
      "type": "assertState",
      "actor": "Wizard B",
      "expect": { "characterResource": { "poolName": "spellSlot_3", "current": 1, "max": 2 } },
      "comment": "Wizard B's L3 slot spent on Counterspell."
    },
    {
      "type": "assertState",
      "expect": { "monsterHp": { "name": "Target Dummy", "exact": 100 } },
      "comment": "Target Dummy took no damage — Fireball was successfully countered."
    }
  ]
}
