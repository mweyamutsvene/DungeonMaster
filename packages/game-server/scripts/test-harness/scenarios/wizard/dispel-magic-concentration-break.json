{
  "name": "Dispel Magic: breaks target's concentration (2024 RAW)",
  "description": "D&D 5e 2024 Dispel Magic. Cleric casts Bless on herself (gains concentration on L1 Bless). Wizard then casts Dispel Magic at L3 on the Cleric. Bless is level 1 ≤ L3 slot → auto-dispel. Cleric's concentration ends.\n\nTests: (1) DispelMagicDeliveryHandler matches the spell by name and routes correctly (instead of falling through to BuffDebuffSpellDeliveryHandler). (2) Slot level comparison auto-dispels lower-level spells. (3) breakConcentration is invoked on the target, clearing resources.concentrationSpellName.",
  "setup": {
    "characters": [
      {
        "name": "Sister Mira",
        "className": "Cleric",
        "level": 5,
        "position": { "x": 10, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 12, "dexterity": 10, "constitution": 14,
            "intelligence": 10, "wisdom": 18, "charisma": 12
          },
          "maxHp": 40, "currentHp": 40, "armorClass": 16, "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "wisdom",
          "spellSaveDC": 15, "spellAttackBonus": 7,
          "spellSlots": { "1": 4, "2": 3, "3": 2 },
          "preparedSpells": [
            { "name": "Bless", "level": 1 }
          ],
          "attacks": [
            { "name": "Mace", "kind": "melee", "attackBonus": 4, "damage": { "diceCount": 1, "diceSides": 6, "modifier": 1 }, "damageType": "bludgeoning" }
          ]
        }
      },
      {
        "name": "Elara",
        "className": "Wizard",
        "level": 5,
        "position": { "x": 12, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 14,
            "intelligence": 18, "wisdom": 12, "charisma": 10
          },
          "maxHp": 32, "currentHp": 32, "armorClass": 12, "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "intelligence",
          "spellSaveDC": 15, "spellAttackBonus": 7,
          "spellSlots": { "1": 4, "2": 3, "3": 2 },
          "preparedSpells": [
            { "name": "Fire Bolt", "level": 0 },
            { "name": "Dispel Magic", "level": 3 }
          ],
          "attacks": [
            { "name": "Quarterstaff", "kind": "melee", "attackBonus": 1, "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 }, "damageType": "bludgeoning" }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Target Dummy",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": { "strength": 10, "dexterity": 10, "constitution": 10, "intelligence": 1, "wisdom": 1, "charisma": 1 },
          "maxHp": 100, "hp": 100, "armorClass": 10, "speed": 0,
          "challengeRating": 0,
          "attacks": [{ "name": "Slam", "kind": "melee", "attackBonus": 0, "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 }, "damageType": "bludgeoning" }]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Sister Mira",
      "input": { "text": "Mira begins a blessing" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Sister Mira",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Mira casts Bless on self — establishes concentration on Bless (L1 spell).",
      "type": "waitForTurn",
      "actor": "Sister Mira",
      "timeout": 15000
    },
    {
      "type": "action",
      "actor": "Sister Mira",
      "input": { "text": "cast Bless" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "actor": "Sister Mira",
      "expect": { "characterConcentration": "Bless" },
      "comment": "Mira is concentrating on Bless."
    },
    { "type": "endTurn", "actor": "Sister Mira" },

    {
      "type": "waitForTurn",
      "actor": "Elara",
      "timeout": 15000
    },
    {
      "comment": "Elara casts Dispel Magic at L3 slot targeting Mira. Bless is L1 ≤ 3 → auto-dispel. Mira's concentration ends.",
      "type": "action",
      "actor": "Elara",
      "input": { "text": "cast Dispel Magic at Sister Mira" },
      "expect": { "actionComplete": true, "type": "SIMPLE_ACTION_COMPLETE" }
    },
    {
      "type": "assertState",
      "actor": "Sister Mira",
      "expect": { "characterConcentration": null },
      "comment": "Bless concentration ended via Dispel Magic auto-dispel."
    },
    {
      "type": "assertState",
      "actor": "Elara",
      "expect": { "characterResource": { "poolName": "spellSlot_3", "current": 1, "max": 2 } },
      "comment": "Elara's L3 slot was consumed."
    }
  ]
}
