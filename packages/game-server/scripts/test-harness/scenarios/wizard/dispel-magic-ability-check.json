{
  "name": "Dispel Magic: higher-level concentration requires ability check",
  "description": "Covers the Dispel Magic ability-check branch when target concentration spell level is higher than cast slot level. First check fails and concentration remains; second check succeeds and concentration ends.",
  "setup": {
    "characters": [
      {
        "name": "Target Wizard",
        "className": "Wizard",
        "level": 7,
        "position": { "x": 10, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 14,
            "intelligence": 18, "wisdom": 12, "charisma": 10
          },
          "maxHp": 32,
          "currentHp": 32,
          "armorClass": 12,
          "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "intelligence",
          "spellSaveDC": 15,
          "spellAttackBonus": 7,
          "spellSlots": { "1": 4, "2": 3, "3": 3, "4": 1 },
          "preparedSpells": [
            { "name": "Greater Invisibility", "level": 4 }
          ],
          "attacks": [
            { "name": "Quarterstaff", "kind": "melee", "attackBonus": 1, "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 }, "damageType": "bludgeoning" }
          ]
        }
      },
      {
        "name": "Dispeller",
        "className": "Wizard",
        "level": 7,
        "position": { "x": 12, "y": 10 },
        "sheet": {
          "abilityScores": {
            "strength": 8, "dexterity": 14, "constitution": 14,
            "intelligence": 16, "wisdom": 12, "charisma": 10
          },
          "maxHp": 32,
          "currentHp": 32,
          "armorClass": 12,
          "speed": 30,
          "proficiencyBonus": 3,
          "spellcastingAbility": "intelligence",
          "spellSaveDC": 14,
          "spellAttackBonus": 6,
          "spellSlots": { "1": 4, "2": 3, "3": 3, "4": 1 },
          "preparedSpells": [
            { "name": "Dispel Magic", "level": 3 }
          ],
          "attacks": [
            { "name": "Quarterstaff", "kind": "melee", "attackBonus": 1, "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 }, "damageType": "bludgeoning" }
          ]
        }
      }
    ],
    "monsters": [
      {
        "name": "Target Dummy",
        "position": { "x": 40, "y": 10 },
        "statBlock": {
          "abilityScores": { "strength": 10, "dexterity": 10, "constitution": 10, "intelligence": 1, "wisdom": 1, "charisma": 1 },
          "maxHp": 100,
          "hp": 100,
          "armorClass": 10,
          "speed": 0,
          "challengeRating": 0,
          "attacks": [
            { "name": "Slam", "kind": "melee", "attackBonus": 0, "damage": { "diceCount": 1, "diceSides": 4, "modifier": 0 }, "damageType": "bludgeoning" }
          ]
        }
      }
    ],
    "aiConfig": { "defaultBehavior": "endTurn" }
  },
  "actions": [
    {
      "type": "initiate",
      "actor": "Target Wizard",
      "input": { "text": "Begin dispel check test" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "actor": "Target Wizard",
      "input": { "text": "20" },
      "expect": { "combatStarted": true }
    },
    {
      "type": "waitForTurn",
      "actor": "Target Wizard",
      "timeout": 15000
    },
    {
      "type": "action",
      "actor": "Target Wizard",
      "input": { "text": "cast Greater Invisibility on Target Wizard" },
      "expect": { "actionComplete": true }
    },
    {
      "type": "assertState",
      "actor": "Target Wizard",
      "expect": { "characterConcentration": "Greater Invisibility" }
    },
    { "type": "endTurn", "actor": "Target Wizard" },

    {
      "type": "queueDiceRolls",
      "input": { "values": [1, 20], "label": "Dispel check fail then success" }
    },
    {
      "type": "waitForTurn",
      "actor": "Dispeller",
      "timeout": 15000
    },
    {
      "comment": "Cast at base level 3 against level 4 concentration spell. First check: 1 + INT 3 + PB 3 = 7 vs DC 14 -> fail.",
      "type": "action",
      "actor": "Dispeller",
      "input": { "text": "cast Dispel Magic at Target Wizard" },
      "expect": { "actionComplete": true, "type": "SIMPLE_ACTION_COMPLETE" }
    },
    {
      "type": "assertState",
      "actor": "Target Wizard",
      "expect": { "characterConcentration": "Greater Invisibility" }
    },
    { "type": "endTurn", "actor": "Dispeller" },
    { "type": "waitForTurn", "actor": "Target Wizard", "timeout": 15000 },
    { "type": "endTurn", "actor": "Target Wizard" },

    {
      "type": "waitForTurn",
      "actor": "Dispeller",
      "timeout": 15000
    },
    {
      "comment": "Second Dispel uses queued d20=20. 20 + 6 = 26 vs DC 14 -> success.",
      "type": "action",
      "actor": "Dispeller",
      "input": { "text": "cast Dispel Magic at Target Wizard" },
      "expect": { "actionComplete": true, "type": "SIMPLE_ACTION_COMPLETE" }
    },
    {
      "type": "assertState",
      "actor": "Target Wizard",
      "expect": { "characterConcentration": null }
    },
    {
      "type": "assertState",
      "actor": "Dispeller",
      "expect": { "characterResource": { "poolName": "spellSlot_3", "current": 1, "max": 3 } }
    }
  ]
}
