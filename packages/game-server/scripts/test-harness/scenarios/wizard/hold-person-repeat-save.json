{
  "name": "Hold Person: Repeat WIS Save at End of Turn",
  "description": "A Wizard casts Hold Person on a humanoid target. The target fails the initial WIS save and becomes Paralyzed. At the end of the target's turn, it repeats the WIS save (turn-end save mechanic). Tests that the save-to-end ActiveEffect is created on initial failure and that the repeat save fires at end of turn.",
  "setup": {
    "character": {
      "name": "Enchanter Mage",
      "className": "Wizard",
      "level": 5,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 14,
          "intelligence": 18, "wisdom": 12, "charisma": 10
        },
        "maxHp": 32, "currentHp": 32, "armorClass": 12, "speed": 30,
        "proficiencyBonus": 3,
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 15,
        "spellAttackBonus": 7,
        "spellSlots": { "1": 4, "2": 3, "3": 2 },
        "preparedSpells": [
          { "name": "Hold Person", "level": 2 },
          { "name": "Fire Bolt", "level": 0 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff", "kind": "melee", "range": "melee",
            "attackBonus": 1,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Bandit",
        "position": { "x": 25, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 12, "dexterity": 12, "constitution": 12,
            "intelligence": 10, "wisdom": 6, "charisma": 10
          },
          "maxHp": 60, "hp": 60, "armorClass": 12, "speed": 30,
          "challengeRating": 0.125, "experienceValue": 25,
          "saveProficiencies": [],
          "attacks": [
            {
              "name": "Scimitar", "kind": "melee", "attackBonus": 3,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 1 },
              "damageType": "slashing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I ready my enchantment magic" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "20" },
      "comment": "High initiative so player goes first",
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Cast Hold Person on the Bandit — server auto-rolls WIS save. Bandit WIS 6 (modifier -2) vs DC 15: needs 17+ to pass. With seeded dice, this should fail.",
      "type": "action",
      "input": { "text": "cast Hold Person on Bandit" },
      "expect": {
        "type": "SIMPLE_ACTION_COMPLETE",
        "action": "CastSpell"
      }
    },
    {
      "type": "assertState",
      "comment": "Verify Bandit is Paralyzed after failing the WIS save",
      "expect": {
        "monsterConditions": { "name": "Bandit", "hasConditions": ["Paralyzed"] },
        "characterConcentration": "Hold Person"
      }
    },
    {
      "comment": "End wizard's turn. Bandit's turn begins (paralyzed, AI ends turn). At end of Bandit's turn, save-to-end fires: repeat WIS save vs DC 15.",
      "type": "endTurn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for wizard's turn to come back around"
    },
    {
      "type": "assertState",
      "comment": "After first repeat save: Bandit is still Paralyzed (d20(6) vs DC 15 → FAIL).",
      "expect": {
        "monsterConditions": { "name": "Bandit", "hasConditions": ["Paralyzed"] },
        "characterConcentration": "Hold Person"
      }
    },
    {
      "comment": "Round 2: Wizard ends turn. Bandit gets second repeat save at end of turn (d20(18) vs DC 15 → SUCCESS → Paralyzed removed).",
      "type": "endTurn"
    },
    {
      "type": "waitForTurn",
      "comment": "Wait for wizard's turn (round 3)"
    },
    {
      "type": "assertState",
      "comment": "After second repeat save: Bandit is NO LONGER Paralyzed (save succeeded, condition removed). Wizard still concentrating on Hold Person.",
      "expect": {
        "monsterConditions": { "name": "Bandit", "doesNotHaveConditions": ["Paralyzed"] },
        "characterConcentration": "Hold Person"
      }
    }
  ]
}
