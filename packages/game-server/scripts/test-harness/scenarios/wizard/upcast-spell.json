{
  "name": "Wizard Spell Upcasting: castAtLevel",
  "description": "Tests spell upcasting: a Wizard with no level-1 slots but a level-2 slot casts Burning Hands at level 2 (consuming the higher slot), then fails when no level-2 slots remain. Also tests casting Cure Wounds at level 2 for bonus healing.",
  "setup": {
    "character": {
      "name": "Elara the Wise",
      "className": "Wizard",
      "level": 3,
      "position": { "x": 10, "y": 10 },
      "sheet": {
        "abilityScores": {
          "strength": 8, "dexterity": 14, "constitution": 14,
          "intelligence": 18, "wisdom": 12, "charisma": 10
        },
        "maxHp": 20, "currentHp": 20, "armorClass": 12, "speed": 30,
        "proficiencyBonus": 2,
        "spellcastingAbility": "intelligence",
        "spellSaveDC": 14,
        "spellAttackBonus": 6,
        "spellSlots": { "1": 0, "2": 1 },
        "preparedSpells": [
          { "name": "Burning Hands", "level": 1 },
          { "name": "Cure Wounds", "level": 1 }
        ],
        "attacks": [
          {
            "name": "Quarterstaff", "kind": "melee", "range": "melee",
            "attackBonus": 0,
            "damage": { "diceCount": 1, "diceSides": 6, "modifier": -1 },
            "damageType": "bludgeoning"
          }
        ]
      }
    },
    "monsters": [
      {
        "name": "Skeleton",
        "position": { "x": 15, "y": 10 },
        "statBlock": {
          "abilityScores": {
            "strength": 10, "dexterity": 14, "constitution": 15,
            "intelligence": 6, "wisdom": 8, "charisma": 5
          },
          "maxHp": 50, "hp": 50, "armorClass": 13, "speed": 30,
          "challengeRating": 0.25, "experienceValue": 50,
          "attacks": [
            {
              "name": "Shortbow", "kind": "ranged", "attackBonus": 4,
              "damage": { "diceCount": 1, "diceSides": 6, "modifier": 2 },
              "damageType": "piercing"
            }
          ]
        }
      }
    ],
    "aiConfig": {
      "defaultBehavior": "endTurn"
    }
  },
  "actions": [
    {
      "type": "initiate",
      "input": { "text": "I prepare my spells" },
      "expect": { "rollType": "initiative", "requiresPlayerInput": true }
    },
    {
      "type": "rollResult",
      "input": { "text": "18" },
      "expect": { "combatStarted": true }
    },
    {
      "comment": "Upcast Burning Hands at level 2: no level-1 slot available, uses level-2 slot instead",
      "type": "action",
      "input": { "text": "cast Burning Hands at level 2 at Skeleton" },
      "expect": { "type": "SIMPLE_ACTION_COMPLETE", "action": "CastSpell" }
    },
    { "type": "endTurn" },
    { "type": "waitForTurn" },
    {
      "comment": "Try to upcast again: level-2 slot is now exhausted — should fail",
      "type": "action",
      "input": { "text": "cast Burning Hands at level 2 at Skeleton" },
      "expect": { "error": true, "errorContains": "spell slots remaining" }
    },
    {
      "comment": "Try to cast at base level too: also no level-1 slots — should fail",
      "type": "action",
      "input": { "text": "cast Burning Hands at Skeleton" },
      "expect": { "error": true, "errorContains": "spell slots remaining" }
    }
  ]
}
