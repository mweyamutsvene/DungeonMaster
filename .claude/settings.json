{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm exec tsx scripts/hooks/typecheck-after-edit.ts",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "pnpm exec tsx scripts/hooks/check-domain-purity.ts",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "pnpm exec tsx scripts/hooks/test-first-gate.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm exec tsx scripts/hooks/session-context.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm exec tsx scripts/hooks/post-impl-challenger.ts",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
