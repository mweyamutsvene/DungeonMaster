{
  "name": "dungeonmaster",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "cli": "pnpm --filter @dungeonmaster/cli dev",
    "scaffold": "tsx scripts/scaffold/main.ts",
    "test:golden": "pnpm -C packages/game-server typecheck && pnpm -C packages/game-server test && pnpm -C packages/game-server test:e2e:combat:mock -- --all"
  },
  "devDependencies": {
    "cheerio": "^1.1.2",
    "turbo": "^2.5.0",
    "typescript": "^5.6.3"
  }
}
